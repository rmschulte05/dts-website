{
  "name": "showcase-website",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "deploy": "astro build && wrangler pages deploy dist --project-name=dutchtorqueservice --branch=main",
    "deploy:preview": "astro build && wrangler pages deploy dist --project-name=dutchtorqueservice",
    "seo": "bash scripts/seo-agents/run-all.sh",
    "seo:research": "bash scripts/seo-agents/run-all.sh 1",
    "seo:write": "bash scripts/seo-agents/run-all.sh 2",
    "seo:facts": "bash scripts/seo-agents/run-all.sh 3",
    "seo:eeat": "bash scripts/seo-agents/run-all.sh 4",
    "seo:humanize": "bash scripts/seo-agents/run-all.sh 5",
    "seo:optimize": "bash scripts/seo-agents/run-all.sh 6",
    "seo:aeo": "bash scripts/seo-agents/run-all.sh 7",
    "copy": "bash scripts/copy-agents/run-all.sh",
    "copy:audit": "bash scripts/copy-agents/run-all.sh \"$1\" 1",
    "copy:rewrite": "bash scripts/copy-agents/run-all.sh \"$1\" 2",
    "copy:facts": "bash scripts/copy-agents/run-all.sh \"$1\" 3",
    "copy:seo": "bash scripts/copy-agents/run-all.sh \"$1\" 4",
    "copy:apply": "bash scripts/copy-agents/run-all.sh \"$1\" 5",
    "copy:all": "bash scripts/copy-agents/run-all-pages.sh"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource-variable/inter": "^5.2.8",
    "astro": "^6.1.8",
    "gsap": "^3.12.7",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.14",
    "tailwindcss": "^4.0.14",
    "wrangler": "^3.90.0"
  }
}
