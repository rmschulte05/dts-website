---
<!DOCTYPE html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#08090B" />
    <meta name="color-scheme" content="dark" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Dutch Torque Service" />
    <meta name="geo.region" content="NL-NB" />
    <meta name="geo.placename" content="Riethoven, Noord-Brabant" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og-image.jpg" />
    <meta property="og:locale" content="nl_NL" />
    <meta property="og:site_name" content="Dutch Torque Service" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og-image.jpg" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <title>{title}</title>

    <!-- Fonts: Inter Variable is self-hosted via @fontsource-variable/inter (imported in the
         layout frontmatter). One variable woff2 replaces seven separate weights, no third-party
         request (GDPR-safe), no render-blocking external stylesheet, font-display: swap built in. -->

    <!-- Structured data — LocalBusiness + WebSite + Person -->
    <script type="application/ld+json" set:html={JSON.stringify([localBusinessSchema, websiteSchema, personSchema])} />

    <!-- Per-page structured data slot -->
    <slot name="head" />
  </head>
  <body>
    <!-- Skip link — allows keyboard users to jump past nav directly to content -->
    <a href="#main-content" class="skip-link">Ga naar inhoud</a>
    <!-- Skip-link target: invisible anchor placed before page content -->
    <div id="main-content" tabindex="-1" style="outline:none;"></div>
    <slot />
    <style>
      .skip-link {
        position:    absolute;
        left:        1rem;
        top:         -3rem;
        z-index:     9999;
        padding:     0.5rem 1.25rem;
        border-radius: 0 0 8px 8px;
        background:  #7AAFC4;
        color:       #08090B;
        font-size:   0.8125rem;
        font-weight: 700;
        text-decoration: none;
        transition:  top 0.2s ease;
      }
      .skip-link:focus { top: 0; }
    </style>

    <script>
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      gsap.registerPlugin(ScrollTrigger);

      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!prefersReduced) {
        // Global scroll-reveal — fromTo so GSAP owns both states explicitly
        document.querySelectorAll('[data-animate]').forEach((el) => {
          const delay = parseFloat((el as HTMLElement).dataset.animateDelay ?? '0');
          const dir   = (el as HTMLElement).dataset.animateFrom ?? 'bottom';

          const fromVars: Record<string, unknown> = { opacity: 0 };
          const toVars:   Record<string, unknown> = { opacity: 1, duration: 0.85, delay, ease: 'power3.out',
            scrollTrigger: {
              trigger: el,
              start: 'top 96%',
              toggleActions: 'play none none none',
              once: true,
            }
          };

          if (dir === 'bottom') { fromVars.y = 40; toVars.y = 0; toVars.clearProps = 'transform'; }
          if (dir === 'left')   { fromVars.x = -40; toVars.x = 0; toVars.clearProps = 'transform'; }
          if (dir === 'right')  { fromVars.x = 40;  toVars.x = 0; toVars.clearProps = 'transform'; }
          if (dir === 'scale')  { fromVars.scale = 0.94; toVars.scale = 1; toVars.clearProps = 'transform'; }

          gsap.fromTo(el, fromVars, toVars);
        });

        // Fire triggers for elements already in view on load
        ScrollTrigger.refresh();
      }
    </script>
  </body>
</html>
