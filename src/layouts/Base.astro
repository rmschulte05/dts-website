---
import '@fontsource-variable/inter';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;  // e.g. "/" or "/werk"
}
const {
  title,
  description = 'Dutch Torque Service — Professionele kalibratie en service van momentsleutels',
  canonicalPath,
} = Astro.props;

const siteBase = 'https://www.dutchtorqueservice.nl';
const canonicalURL = siteBase + (canonicalPath ?? '/');

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": "https://www.dutchtorqueservice.nl/#business",
  "name": "Dutch Torque Service",
  "legalName": "Dutch Torque Service",
  "description": "Professionele momentsleutel kalibratie, reparatie en ISO 6789:2017 certificering. ±2% servicegarantie, ruim binnen de ISO 6789 tolerantie van ±4%. Geautoriseerd Snap-On dealer.",
  "url": "https://www.dutchtorqueservice.nl",
  "logo": "https://www.dutchtorqueservice.nl/logo/dts-logo-2x.webp",
  "image": "https://www.dutchtorqueservice.nl/og-image.jpg",
  "telephone": "+31613172774",
  "email": "info@dutchtorqueservice.nl",
  "taxID": "67183360",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Tonterstraat 42",
    "addressLocality": "Riethoven",
    "postalCode": "5561 AN",
    "addressCountry": "NL",
    "addressRegion": "Noord-Brabant"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 51.3397,
    "longitude": 5.4119
  },
  "areaServed": [
    { "@type": "Country", "name": "Netherlands" },
    { "@type": "Country", "name": "Belgium" },
    { "@type": "Country", "name": "Germany" },
    { "@type": "AdministrativeArea", "name": "Noord-Brabant" }
  ],
  "serviceType": [
    "Momentsleutel kalibratie",
    "Momentsleutel reparatie",
    "ISO 6789 certificering",
    "Momentsleutel justeren"
  ],
  "knowsAbout": [
    "ISO 6789:2017",
    "ISO 6789-1",
    "ISO 6789-2",
    "Momentsleutel kalibratie",
    "Type I momentsleutels (indicerend)",
    "Type II momentsleutels (instellend)",
    "Snap-On momentsleutels",
    "Traceerbare referentieapparatuur"
  ],
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "08:00",
      "closes": "17:00"
    }
  ],
  "priceRange": "€€",
  "inLanguage": "nl-NL",
  "foundingDate": "2026-01-01",
  "parentOrganization": {
    "@type": "Organization",
    "name": "Van Rootselaar Technic bv.",
    "description": "Voorganger; warme overdracht van momentsleutelwerkzaamheden per 1 januari 2026."
  },
  "sameAs": [
    "https://www.kvk.nl/zoeken/?source=all&q=67183360"
  ]
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "https://www.dutchtorqueservice.nl/#website",
  "url": "https://www.dutchtorqueservice.nl",
  "name": "Dutch Torque Service",
  "description": "Specialist in momentsleutel kalibratie, reparatie en certificering conform ISO 6789:2017",
  "inLanguage": "nl-NL",
  "publisher": { "@id": "https://www.dutchtorqueservice.nl/#business" },
