---
import Base from './Base.astro';
import NavIsland from '../components/modules/NavIsland.astro';
import FooterDTS from '../components/modules/FooterDTS.astro';

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  headline: string;
  category: string;
  readTime: string;
  publishDate: string;
  excerpt: string;
}
const { title, description, canonicalPath, headline, category, readTime, publishDate, excerpt } = Astro.props;

// Derive a category accent colour so the design feels contextual per article
const categoryColors: Record<string, string> = {
  'Kalibratie':          '#7AAFC4',
  'Norm & Certificering':'#64C48A',
  'Reparatie':           '#C48A64',
  'Kennisbank':          '#A89FD4',
  'Onderhoud':           '#D4927A',
};
const accent = categoryColors[category] ?? '#7AAFC4';
---

<Base title={title} description={description} canonicalPath={canonicalPath}>
  <slot name="head" slot="head" />

  <NavIsland currentPage="blog" />

  <!-- ── READING PROGRESS BAR ── -->
  <div id="progress-bar" style={`position:fixed; top:0; left:0; height:2px; width:0%; background: linear-gradient(90deg, ${accent}, color-mix(in srgb, ${accent} 60%, white)); z-index:9999; transition: width 0.1s linear;`}></div>

  <main>

    <!-- ══════════════════════════════════════════
         HERO
    ══════════════════════════════════════════ -->
    <section class="article-hero" style={`--accent: ${accent};`}>
      <!-- background texture -->
      <div class="hero-grid" aria-hidden="true"></div>
      <div class="hero-glow" aria-hidden="true" style={`background: radial-gradient(ellipse 70% 60% at 50% 0%, color-mix(in srgb, ${accent} 9%, transparent), transparent);`}></div>

      <div class="hero-inner">
        <!-- Breadcrumb -->
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span aria-hidden="true">›</span>
          <a href="/blog">Blog</a>
          <span aria-hidden="true">›</span>
          <span>{category}</span>
        </nav>

        <!-- Category pill + read time -->
        <div class="hero-meta-top">
          <span class="category-pill" style={`background: color-mix(in srgb, ${accent} 14%, transparent); color: ${accent}; border-color: color-mix(in srgb, ${accent} 30%, transparent);`}>{category}</span>
          <span class="meta-sep" aria-hidden="true"></span>
          <span class="read-time">{readTime} leestijd</span>
        </div>

        <!-- Headline -->
        <h1 class="article-headline">{headline}</h1>

        <!-- Excerpt / stand-first -->
        <p class="article-excerpt">{excerpt}</p>

        <!-- Author row -->
        <div class="author-row">
          <div class="author-avatar" style={`background: linear-gradient(135deg, color-mix(in srgb, ${accent} 30%, transparent), color-mix(in srgb, ${accent} 12%, transparent)); border-color: color-mix(in srgb, ${accent} 28%, transparent);`}>
            <span>JP</span>
          </div>
          <div class="author-info">
            <span class="author-name">Jan-Piet Schulte</span>
            <span class="author-role">Dutch Torque Service · {publishDate}</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         FEATURED IMAGE BAND
    ══════════════════════════════════════════ -->
    <section class="featured-image-section">
      <div class="featured-image-wrap">
        <slot name="featured-image">
          <!-- Default placeholder until a real photo is added -->
          <div class="featured-image-placeholder" style={`--accent: ${accent};`}>
            <div class="placeholder-grid" aria-hidden="true"></div>
            <div class="placeholder-icon">
              <svg width="56" height="56" viewBox="0 0 80 80" fill="none" aria-hidden="true">
                <circle cx="20" cy="40" r="14" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="20" cy="40" r="7" stroke="currentColor" stroke-width="1"/>
                <rect x="34" y="34" width="32" height="12" rx="3" stroke="currentColor" stroke-width="1.5"/>
                <rect x="66" y="31" width="10" height="18" rx="4" stroke="currentColor" stroke-width="1.5"/>
              </svg>
              <p>Uitgelichte afbeelding</p>
            </div>
            <!-- Decorative accent line -->
            <div class="placeholder-stripe" style={`background: linear-gradient(90deg, transparent, ${accent}, transparent); opacity: 0.25;`}></div>
          </div>
        </slot>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         ARTICLE BODY
    ══════════════════════════════════════════ -->
    <section class="article-body-section">
      <div class="article-body-inner">

        <!-- Decorative left rule -->
        <div class="article-rule" style={`background: linear-gradient(to bottom, transparent, ${accent}, transparent); opacity: 0.18;`} aria-hidden="true"></div>

        <!-- Prose content — paste agent HTML here -->
        <article class="prose" style={`--accent: ${accent};`}>
          <slot />
        </article>

      </div>
    </section>

    <!-- ══════════════════════════════════════════
         POST-ARTICLE CTA
    ══════════════════════════════════════════ -->
    <section class="post-cta-section">
      <div class="post-cta-wrap">
        <div class="post-cta-card" style={`--accent: ${accent};`}>
          <div class="post-cta-glow" style={`background: radial-gradient(circle at 80% 20%, color-mix(in srgb, ${accent} 8%, transparent), transparent 60%);`} aria-hidden="true"></div>
          <div class="post-cta-content">
            <span class="post-cta-eyebrow" style={`color: ${accent};`}>Dutch Torque Service — Riethoven, Noord-Brabant</span>
            <h2 class="post-cta-headline">Klaar om jouw momentsleutel<br/>te laten kalibreren?</h2>
            <p class="post-cta-body">Snel gecertificeerd conform ISO 6789:2017. Geen formulieren — gewoon bellen.</p>
            <div class="post-cta-actions">
              <a href="tel:+31613172774" class="btn btn-primary">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="1.5"/></svg>
                +31(0)6-131 72 774
              </a>
              <a href="/diensten/momentsleutel-kalibratie" class="btn btn-ghost">Bekijk kalibratie →</a>
            </div>
          </div>
        </div>

        <!-- Back to blog -->
        <div class="back-to-blog">
          <a href="/blog">← Terug naar kennisbank</a>
        </div>
      </div>
    </section>

  </main>

  <FooterDTS />
</Base>

<!-- ── READING PROGRESS SCRIPT ── -->
<script>
  const bar = document.getElementById('progress-bar');
  if (bar) {
    window.addEventListener('scroll', () => {
      const doc = document.documentElement;
      const scrolled = doc.scrollTop;
      const total = doc.scrollHeight - doc.clientHeight;
      bar.style.width = total > 0 ? (scrolled / total * 100) + '%' : '0%';
    }, { passive: true });
  }
</script>

<style>
/* ════════════════════════════════════════════
   HERO
════════════════════════════════════════════ */
.article-hero {
  position: relative;
  overflow: hidden;
  padding-top: clamp(8rem, 14vw, 11rem);
  padding-bottom: clamp(3rem, 5vw, 4.5rem);
  padding-inline: var(--page-px);
}
.hero-grid {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(122,175,196,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(122,175,196,0.03) 1px, transparent 1px);
  background-size: 40px 40px;
  mask-image: radial-gradient(ellipse 80% 100% at 50% 0%, black 30%, transparent 100%);
}
.hero-glow { position: absolute; inset: 0; pointer-events: none; }
.hero-inner { max-width: 800px; margin-inline: auto; position: relative; }

/* Breadcrumb */
.breadcrumb {
  display: flex; align-items: center; gap: 0.5rem;
  font-size: 0.72rem; color: rgba(154,174,184,0.5);
  margin-bottom: 2rem;
}
.breadcrumb a {
  color: rgba(122,175,196,0.6); text-decoration: none;
  transition: color 0.2s;
}
.breadcrumb a:hover { color: #7AAFC4; }
.breadcrumb span { opacity: 0.4; }
.breadcrumb span:last-child { opacity: 0.7; color: rgba(154,174,184,0.7); }

/* Category pill */
.hero-meta-top {
  display: flex; align-items: center; gap: 0.875rem;
  margin-bottom: 1.5rem;
}
.category-pill {
  font-size: 0.65rem; font-weight: 700;
  letter-spacing: 0.22em; text-transform: uppercase;
  padding: 0.35rem 0.85rem; border-radius: 99px;
  border: 1px solid;
}
.meta-sep {
  width: 1px; height: 14px;
  background: rgba(154,174,184,0.2);
}
.read-time {
  font-size: 0.72rem; color: rgba(154,174,184,0.45);
  letter-spacing: 0.08em;
}

/* Headline */
.article-headline {
  font-size: clamp(2rem, 4.5vw, 3.2rem);
  font-weight: 900; line-height: 1.08;
  letter-spacing: -0.03em; color: #ffffff;
  margin-bottom: 1.25rem;
}

/* Excerpt */
.article-excerpt {
  font-size: clamp(1rem, 1.8vw, 1.1rem);
  line-height: 1.8; color: #8EAAB8;
  max-width: 58ch; margin-bottom: 2rem;
}

/* Author */
.author-row {
  display: flex; align-items: center; gap: 0.875rem;
  padding-top: 1.5rem;
  border-top: 1px solid rgba(122,175,196,0.08);
}
.author-avatar {
  width: 36px; height: 36px; border-radius: 50%;
  border: 1px solid; display: flex; align-items: center;
  justify-content: center; flex-shrink: 0;
}
.author-avatar span {
  font-size: 0.6rem; font-weight: 800; color: #7AAFC4;
}
.author-info { display: flex; flex-direction: column; gap: 0.15rem; }
.author-name { font-size: 0.82rem; font-weight: 600; color: #C4D0D8; }
.author-role { font-size: 0.72rem; color: rgba(154,174,184,0.45); }

/* ════════════════════════════════════════════
   FEATURED IMAGE
════════════════════════════════════════════ */
.featured-image-section { padding-inline: var(--page-px); }
.featured-image-wrap {
  max-width: 800px; margin-inline: auto;
  margin-bottom: 3rem;
}
.featured-image-placeholder {
  aspect-ratio: 16 / 7;
  border-radius: 1.25rem; overflow: hidden;
  background: #0D1017;
  border: 1px solid rgba(122,175,196,0.10);
  position: relative;
}
.placeholder-grid {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(122,175,196,0.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(122,175,196,0.025) 1px, transparent 1px);
  background-size: 32px 32px;
}
.placeholder-icon {
  position: absolute; inset: 0;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 0.75rem;
  color: rgba(122,175,196,0.3);
}
.placeholder-icon p {
  font-size: 0.65rem; letter-spacing: 0.22em;
  text-transform: uppercase; font-weight: 500;
  color: rgba(122,175,196,0.3);
}
.placeholder-stripe {
  position: absolute; bottom: 0; left: 0; right: 0;
  height: 2px;
}

/* ════════════════════════════════════════════
   ARTICLE BODY
════════════════════════════════════════════ */
.article-body-section {
  padding-inline: var(--page-px);
  padding-bottom: clamp(4rem, 6vw, 6rem);
}
.article-body-inner {
  max-width: 800px; margin-inline: auto;
  position: relative;
}
.article-rule {
  display: none;
  position: absolute;
  left: -2.5rem; top: 0; bottom: 0;
  width: 1px;
}
@media (min-width: 1100px) {
  .article-rule { display: block; }
}

/* ════════════════════════════════════════════
   PROSE STYLES
════════════════════════════════════════════ */
.prose {
  --accent: #7AAFC4;
  font-size: 1.025rem;
  line-height: 1.88;
  color: #9AAEB8;
}

/* Author line (em/italic at top) */
.prose > p:first-child em {
  font-size: 0.75rem; font-style: normal;
  letter-spacing: 0.12em; color: rgba(154,174,184,0.4);
  text-transform: uppercase; font-weight: 500;
  display: block; margin-bottom: 2.5rem;
  padding-bottom: 1.5rem;
  border-bottom: 1px solid rgba(122,175,196,0.08);
}

/* Headings */
.prose h2 {
  font-size: clamp(1.25rem, 2.2vw, 1.55rem);
  font-weight: 800; color: #ffffff;
  letter-spacing: -0.025em; line-height: 1.2;
  margin-top: 3.5rem; margin-bottom: 1.1rem;
  display: flex; align-items: center; gap: 0.75rem;
}
.prose h2::before {
  content: '';
  display: inline-block;
  width: 4px; height: 1.2em;
  background: var(--accent);
  border-radius: 2px;
  flex-shrink: 0;
  opacity: 0.85;
}

.prose h3 {
  font-size: 1.05rem; font-weight: 700;
  color: #D4DFE6; letter-spacing: -0.01em;
  margin-top: 2.25rem; margin-bottom: 0.6rem;
  padding-left: 0.875rem;
  border-left: 2px solid color-mix(in srgb, var(--accent) 40%, transparent);
}

/* Paragraphs */
.prose p { margin-bottom: 1.35rem; }
.prose strong { color: #E8F0F4; font-weight: 650; }
.prose em { color: #B8C8D4; font-style: italic; }

/* Links */
.prose a {
  color: var(--accent);
  text-decoration-line: underline;
  text-underline-offset: 3px;
  text-decoration-thickness: 1px;
  text-decoration-color: color-mix(in srgb, var(--accent) 40%, transparent);
  transition: color 0.15s, text-decoration-color 0.15s;
}
.prose a:hover {
  color: color-mix(in srgb, var(--accent) 80%, white);
  text-decoration-color: var(--accent);
}

/* Lists */
.prose ul, .prose ol {
  margin-bottom: 1.35rem;
  padding-left: 1.5rem;
  display: flex; flex-direction: column; gap: 0.4rem;
}
.prose ul li, .prose ol li { line-height: 1.8; }
.prose ul li::marker { color: var(--accent); font-size: 0.85em; }
.prose ol li::marker { color: color-mix(in srgb, var(--accent) 70%, transparent); font-weight: 700; font-size: 0.9em; }

/* Numbered list — styled steps */
.prose ol {
  list-style: none;
  padding-left: 0;
  counter-reset: step;
  display: flex; flex-direction: column; gap: 0;
}
.prose ol li {
  counter-increment: step;
  display: grid;
  grid-template-columns: 2.5rem 1fr;
  gap: 0 1rem;
  padding: 1rem 0;
  border-bottom: 1px solid rgba(122,175,196,0.06);
  align-items: start;
}
.prose ol li:last-child { border-bottom: none; }
.prose ol li::before {
  content: counter(step, decimal-leading-zero);
  font-size: 0.72rem; font-weight: 800;
  color: var(--accent); letter-spacing: 0.06em;
  line-height: 1.8;
  background: color-mix(in srgb, var(--accent) 10%, transparent);
  border: 1px solid color-mix(in srgb, var(--accent) 22%, transparent);
  border-radius: 6px;
  display: flex; align-items: center; justify-content: center;
  height: 2rem; width: 2.25rem;
  margin-top: 0.1rem;
  flex-shrink: 0;
}
.prose ol li::marker { content: ''; }

/* Blockquote */
.prose blockquote {
  position: relative;
  border: none;
  margin: 2.25rem 0;
  padding: 1.5rem 1.75rem 1.5rem 3rem;
  background: linear-gradient(135deg, color-mix(in srgb, var(--accent) 6%, transparent), transparent 70%), #0E1118;
  border-radius: 0 1rem 1rem 0;
  border-left: 3px solid var(--accent);
}
.prose blockquote::before {
  content: '"';
  position: absolute; top: 0.25rem; left: 0.75rem;
  font-size: 3.5rem; line-height: 1;
  color: var(--accent); opacity: 0.25;
  font-family: Georgia, serif;
}
.prose blockquote p {
  color: #C4D0D8; font-style: italic;
  font-size: 1.05rem; margin-bottom: 0;
}

/* Callout box */
.prose .callout {
  background: color-mix(in srgb, var(--accent) 7%, #0E1118);
  border: 1px solid color-mix(in srgb, var(--accent) 22%, transparent);
  border-radius: 1rem; padding: 1.25rem 1.5rem;
  margin: 2rem 0; display: flex; gap: 0.875rem;
}
.prose .callout::before {
  content: '→';
  color: var(--accent); font-weight: 700;
  flex-shrink: 0; line-height: 1.88;
}
.prose .callout p { margin-bottom: 0; color: #C4D0D8; }

/* Tables */
.prose table {
  width: 100%; border-collapse: collapse;
  margin: 2rem 0; font-size: 0.88rem;
  border-radius: 1rem; overflow: hidden;
  border: 1px solid rgba(122,175,196,0.1);
}
.prose thead { background: color-mix(in srgb, var(--accent) 8%, #0E1118); }
.prose th {
  padding: 0.875rem 1.1rem;
  color: var(--accent); font-weight: 700;
  font-size: 0.68rem; letter-spacing: 0.14em;
  text-transform: uppercase; text-align: left;
  border-bottom: 1px solid color-mix(in srgb, var(--accent) 18%, transparent);
}
.prose td {
  padding: 0.875rem 1.1rem;
  color: #9AAEB8; vertical-align: top;
  border-bottom: 1px solid rgba(255,255,255,0.035);
}
.prose tr:last-child td { border-bottom: none; }
.prose tr:nth-child(even) td { background: rgba(255,255,255,0.015); }
.prose td strong { color: #D4DFE6; }

/* FAQ Accordion */
.prose details {
  background: #0C1016;
  border: 1px solid rgba(122,175,196,0.1);
  border-radius: 0.875rem;
  margin-bottom: 0.625rem;
  overflow: hidden;
  transition: border-color 0.25s;
}
.prose details + details { }
.prose details[open] {
  border-color: color-mix(in srgb, var(--accent) 35%, transparent);
}
.prose summary {
  padding: 1.1rem 1.5rem;
  cursor: pointer;
  font-weight: 700; color: #DDE8EE;
  font-size: 0.92rem; line-height: 1.45;
  list-style: none;
  display: flex; justify-content: space-between;
  align-items: center; gap: 1rem;
  user-select: none;
  transition: color 0.2s;
}
.prose details[open] summary { color: #ffffff; }
.prose summary::-webkit-details-marker { display: none; }
.prose summary::after {
  content: '';
  width: 18px; height: 18px; flex-shrink: 0;
  background: color-mix(in srgb, var(--accent) 15%, transparent);
  border: 1px solid color-mix(in srgb, var(--accent) 28%, transparent);
  border-radius: 50%;
  background-image: url("data:image/svg+xml,%3Csvg width='10' height='10' viewBox='0 0 10 10' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M5 2v6M2 5h6' stroke='%237AAFC4' stroke-width='1.5' stroke-linecap='round'/%3E%3C/svg%3E");
  background-repeat: no-repeat;
  background-position: center;
  transition: transform 0.25s ease, background-color 0.2s;
}
.prose details[open] summary::after {
  transform: rotate(45deg);
  background-color: color-mix(in srgb, var(--accent) 25%, transparent);
}
.prose details > p,
.prose details > ul,
.prose details > ol {
  padding: 0 1.5rem 1.25rem;
  font-size: 0.92rem; color: #8EAAB8; line-height: 1.82;
  margin-bottom: 0;
}
.prose details > p a { color: var(--accent); }

/* In-prose CTA card */
.prose .article-cta {
  padding: 2rem 2.5rem; border-radius: 1.25rem;
  background: linear-gradient(135deg, color-mix(in srgb, var(--accent) 8%, transparent), transparent 60%), #0E1118;
  border: 1px solid color-mix(in srgb, var(--accent) 22%, transparent);
  text-align: center; margin: 2.5rem 0;
}
.prose .article-cta h3 {
  border-left: none; padding-left: 0;
  margin-top: 0; font-size: 1.2rem; color: #fff;
}

/* Video embed */
.prose .video-embed {
  position: relative; padding-bottom: 56.25%; height: 0;
  overflow: hidden; border-radius: 1rem;
  margin: 1.75rem 0; background: #0E1118;
  border: 1px solid rgba(122,175,196,0.14);
}
.prose .video-embed iframe {
  position: absolute; top: 0; left: 0;
  width: 100%; height: 100%; border: none;
}

/* Definition / AEO paragraph */
.prose .aeo-definition {
  font-size: 1.05rem; color: #B8C8D4; font-style: italic;
  padding: 1.25rem 1.5rem;
  background: color-mix(in srgb, var(--accent) 5%, transparent);
  border-radius: 0.75rem;
  border: 1px solid color-mix(in srgb, var(--accent) 14%, transparent);
  margin-bottom: 1.75rem;
}

/* Horizontal rule */
.prose hr {
  border: none;
  border-top: 1px solid rgba(122,175,196,0.1);
  margin: 2.5rem 0;
}

/* ════════════════════════════════════════════
   POST-ARTICLE CTA
════════════════════════════════════════════ */
.post-cta-section {
  padding-inline: var(--page-px);
  padding-bottom: clamp(4rem, 7vw, 7rem);
}
.post-cta-wrap { max-width: 800px; margin-inline: auto; }
.post-cta-card {
  padding: clamp(2rem, 4vw, 3rem);
  border-radius: 1.75rem;
  background: #0D1017;
  border: 1px solid color-mix(in srgb, var(--accent) 22%, transparent);
  position: relative; overflow: hidden;
}
.post-cta-glow { position: absolute; inset: 0; pointer-events: none; }
.post-cta-content { position: relative; }
.post-cta-eyebrow {
  display: block;
  font-size: 0.68rem; font-weight: 700;
  letter-spacing: 0.28em; text-transform: uppercase;
  margin-bottom: 0.875rem; opacity: 0.9;
}
.post-cta-headline {
  font-size: clamp(1.5rem, 3vw, 2.1rem);
  font-weight: 900; color: #fff;
  letter-spacing: -0.025em; line-height: 1.15;
  margin-bottom: 0.75rem;
}
.post-cta-body {
  font-size: 0.97rem; line-height: 1.7;
  color: #8EAAB8; margin-bottom: 1.75rem;
}
.post-cta-actions { display: flex; flex-wrap: wrap; gap: 0.875rem; }

/* Buttons */
.btn {
  display: inline-flex; align-items: center; gap: 0.5rem;
