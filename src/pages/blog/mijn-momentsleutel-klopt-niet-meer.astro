        <tr><td>Aansprakelijkheid</td><td>Geen geldig certificaat bij incident = aansprakelijkheid</td></tr>
        <tr><td>ISO-audit</td><td>Ongekalibreerd gereedschap = directe nonconformiteit</td></tr>
        <tr><td>Garantie</td><td>Gebruik van ongekalibreerd gereedschap kan garantie ongeldig maken</td></tr>
      </tbody>
