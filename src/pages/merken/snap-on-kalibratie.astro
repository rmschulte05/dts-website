---
import Base from '../../layouts/Base.astro';
import NavIsland from '../../components/modules/NavIsland.astro';
import FooterDTS from '../../components/modules/FooterDTS.astro';
import PageSection from '../../components/ui/PageSection.astro';

const accent = '#7AAFC4';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Snap-On Momentsleutel Kalibratie en Reparatie",
  "provider": { "@id": "https://www.dutchtorqueservice.nl/#business" },
  "description": "Geautoriseerd Snap-On dealer voor Zuid-Noord-Brabant. Kalibratie en reparatie van Snap-On momentsleutels met originele onderdelen, conform ISO 6789:2017 en 2003. ±2% servicegarantie, ruim binnen de ±4% ISO-tolerantie.",
  "brand": { "@type": "Brand", "name": "Snap-on" },
  "areaServed": [
    { "@type": "Country", "name": "Netherlands" },
    { "@type": "Country", "name": "Belgium" },
    { "@type": "Country", "name": "Germany" },
    { "@type": "AdministrativeArea", "name": "Noord-Brabant" }
  ],
  "inLanguage": "nl-NL",
  "url": "https://www.dutchtorqueservice.nl/merken/snap-on-kalibratie"
};

const serviceCards = [
  {
    accent: '#7AAFC4',
    icon: '◎',
    title: 'Kalibratie',
    body: 'Conform ISO 6789:2017 en 2003, volledig protocol met as-found en as-left waarden.',
  },
  {
    accent: '#C4AF64',
    icon: '✦',
    title: 'Reparatie',
    body: 'Demontage, originele Snap-On onderdelen, hersamenstelling en kalibratie. Raming altijd vooraf.',
  },
  {
    accent: '#64C48A',
    icon: '⊕',
    title: 'Justering',
    body: 'Herinstelling op Newton-meterwaarden na val of slijtage. Altijd gevolgd door kalibratie en certificaat.',
  },
];

const faq = [
  {
    q: 'Kalibreren jullie ook Snap-On elektronische momentsleutels (Type IID)?',
    a: 'Ja. Wij kalibreren alle Snap-On momentsleutel types, inclusief digitale uitvoeringen (Type IID) conform ISO 6789:2017 en 2003.',
  },
  {
    q: 'Zijn jullie officieel erkend als Snap-On dealer?',
    a: 'Ja. Dutch Torque Service is een geautoriseerd Snap-On dealerbedrijf voor Zuid-Noord-Brabant.',
  },
  {
    q: 'Gebruikt u originele Snap-On onderdelen bij reparatie?',
    a: 'Ja. Als geautoriseerd dealer hebben wij toegang tot het originele Snap-On onderdelenassortiment.',
  },
  {
    q: 'Kan ik bij jullie ook nieuwe Snap-On gereedschappen kopen?',
    a: 'Ja, als Snap-On dealer leveren wij ook nieuw Snap-On gereedschap. Neem contact op voor beschikbaarheid en prijzen.',
  },
];
---

<Base
  title="Snap-On Kalibratie & Reparatie | Geautoriseerd Dealer DTS"
  description="Geautoriseerd Snap-On dealer voor Zuid-Noord-Brabant. Snap-On momentsleutel kalibratie en reparatie met originele onderdelen, conform ISO 6789:2017 en 2003."
  canonicalPath="/merken/snap-on-kalibratie"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(schema)} />

  <NavIsland currentPage="diensten" />

  <main>

    <!-- ══════════════════════════════════════
         HERO
    ══════════════════════════════════════ -->
    <PageSection class="hero-section">
        <div class="hero-inner">
          <!-- Eyebrow -->
          <div class="sec-eyebrow" data-animate>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Snap-On Specialist</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>

          <h1 class="hero-h1" data-animate data-animate-delay="0.08">
            Snap-On Kalibratie &amp; Reparatie.
          </h1>

          <p class="hero-subtitle" data-animate data-animate-delay="0.16">
            Als geautoriseerd Snap-On dealer hebben wij de kennis, de originele onderdelen en de gecertificeerde apparatuur om jouw Snap-On momentsleutel te kalibreren en repareren naar fabrieksnorm.
          </p>

          <div class="hero-ctas" data-animate data-animate-delay="0.22">
            <a href="/contact" class="btn btn-primary">Plan kalibratie</a>
            <a href="/diensten/momentsleutel-reparatie" class="btn btn-outline">Meer over reparatie</a>
          </div>

          <!-- Stats badges -->
          <div class="hero-badges" data-animate data-animate-delay="0.30">
            <span class="badge" style="background:rgba(122,175,196,0.10); border:1px solid rgba(122,175,196,0.28); color:#7AAFC4;">Geautoriseerd Dealer</span>
            <span class="badge" style="background:rgba(122,175,196,0.10); border:1px solid rgba(122,175,196,0.28); color:#7AAFC4;">Originele Onderdelen</span>
            <span class="badge" style="background:rgba(122,175,196,0.10); border:1px solid rgba(122,175,196,0.28); color:#7AAFC4;">ISO 6789:2017 en 2003</span>
          </div>
        </div>
    </PageSection>

    <!-- ══════════════════════════════════════
         WHY SNAP-ON SPECIALIST?
    ══════════════════════════════════════ -->
    <PageSection>
        <div class="sec-head" data-animate>
          <div class="sec-eyebrow">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Specialist</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="sec-title">Waarom een Snap-On specialist kiezen?</h2>
        </div>

        <div class="two-col-text" data-animate data-animate-delay="0.08">
          <div class="def-card">
            <p class="body-text">
              Snap-On is de marktleider in professioneel gereedschap voor de automotive- en industriesector. De toleranties en constructie-eisen van Snap-On momentsleutels zijn strenger dan bij gangbaar gereedschap, en dat vraagt om specialistische kennis bij kalibratie en reparatie.
            </p>
            <p class="body-text" style="margin-top:1.25rem;">
              Als geautoriseerd Snap-On dealer voor Zuid-Noord-Brabant hebben wij directe toegang tot originele Snap-On vervangingsonderdelen, de technische documentatie en de juiste kalibratiemethoden.
            </p>
          </div>
        </div>
    </PageSection>

    <!-- ══════════════════════════════════════
         OUR SNAP-ON SERVICES
    ══════════════════════════════════════ -->
    <PageSection class="[background:rgba(14,17,24,0.5)]">
        <div class="sec-head" data-animate>
          <div class="sec-eyebrow">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Diensten</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="sec-title">Onze Snap-On diensten.</h2>
        </div>

        <div class="why-grid">
          {serviceCards.map((card, i) => (
            <div class="why-card" data-animate data-animate-delay={String(i * 0.10)} style={`border-color:rgba(${card.accent === '#7AAFC4' ? '122,175,196' : card.accent === '#C4AF64' ? '196,175,100' : '100,196,138'},0.14);`}>
              <div class="why-icon" style={`color:${card.accent};`}>{card.icon}</div>
              <h3 class="why-title" style={`color:${card.accent};`}>{card.title}</h3>
              <p class="why-body">{card.body}</p>
            </div>
          ))}
        </div>

        <p class="body-text" style="margin-top:2rem;" data-animate data-animate-delay="0.32">
          Meer over <a href="/diensten/momentsleutel-kalibratie" style="color:#7AAFC4; text-decoration:underline;">kalibratie</a> en <a href="/diensten/momentsleutel-reparatie" style="color:#7AAFC4; text-decoration:underline;">reparatie</a>.
        </p>
    </PageSection>

    <!-- ══════════════════════════════════════
         MODELS WE CALIBRATE
    ══════════════════════════════════════ -->
    <PageSection>
        <div class="sec-head" data-animate>
          <div class="sec-eyebrow">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Modellen</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="sec-title">Welke Snap-On modellen kalibreren wij?</h2>
        </div>

        <div class="def-card" data-animate data-animate-delay="0.08">
          <p class="body-text">
            Wij kalibreren en repareren alle gangbare Snap-On momentsleutels, waaronder de <strong style="color:#C8D8E0;">QJFR</strong>, <strong style="color:#C8D8E0;">QJFR2</strong>, <strong style="color:#C8D8E0;">ATECH</strong> en andere modellen in de Snap-On momentsleutelrange. Type I (indicerend) en Type II (instellend), beide conform ISO 6789:2017 en 2003.
          </p>
          <p class="body-text" style="margin-top:1.25rem; font-style:italic; color:#6A8A98;">
            Staat jouw model er niet bij? <a href="/contact" style="color:#7AAFC4; text-decoration:underline;">Neem contact op</a>, we kijken altijd mee.
          </p>
        </div>
    </PageSection>

    <!-- ══════════════════════════════════════
         OTHER BRANDS
    ══════════════════════════════════════ -->
    <PageSection class="[background:rgba(14,17,24,0.5)]">
        <div class="sec-head" data-animate>
          <div class="sec-eyebrow">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Andere merken</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="sec-title">Wij kalibreren ook andere merken.</h2>
        </div>

        <div class="def-card" data-animate data-animate-delay="0.08">
          <p class="body-text">
            Naast Snap-On kalibreren en repareren wij ook Stahlwille, Gedore, Facom, Hazet, Würth, Proto en andere kwaliteitsmerken. Elke sleutel verdient vakkundige service.
          </p>
          <p class="body-text" style="margin-top:1.25rem;">
            <a href="/diensten/momentsleutel-kalibratie" style="color:#7AAFC4; text-decoration:underline;">Bekijk alle kalibratiemogelijkheden →</a>
          </p>
        </div>
    </PageSection>

    <!-- ══════════════════════════════════════
         FAQ
    ══════════════════════════════════════ -->
    <PageSection>
        <div class="sec-head" data-animate>
          <div class="sec-eyebrow">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">FAQ</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="sec-title">Veelgestelde vragen.</h2>
        </div>

        <div class="faq-list" data-animate data-animate-delay="0.08">
          {faq.map(item => (
            <details>
              <summary>{item.q}</summary>
              <div class="faq-body">{item.a}</div>
            </details>
          ))}
        </div>
    </PageSection>

    <!-- ══════════════════════════════════════
         CTA
    ══════════════════════════════════════ -->
    <PageSection>
        <div class="sec-head sec-head--flush" data-animate>
          <div class="sec-eyebrow">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Direct starten</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="sec-title">Jouw Snap-On momentsleutel in goede handen.</h2>
          <p class="sec-sub">
            Bel ons voor een snelle diagnose of plan de kalibratie van jouw Snap-On gereedschap direct in.
          </p>
          <div class="sec-ctas">
            <a href="tel:+31613172774" class="btn btn-primary">Bel +31(0)6-131 72 774</a>
            <a href="mailto:info@dutchtorqueservice.nl" class="btn btn-outline">info@dutchtorqueservice.nl</a>
          </div>
        </div>
    </PageSection>

  </main>

  <FooterDTS />

</Base>

<style>
  /* ── Hero ── */
  .hero-section {
    padding-top: clamp(7rem, 14vw, 11rem);
  }
  .hero-inner {
    max-width: 780px;
    margin-inline: auto;
    text-align: center;
  }
  .hero-h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: #fff;
    margin-bottom: 1.75rem;
  }
  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.7;
    color: #8EAAB8;
    margin-bottom: 2.5rem;
    max-width: 60ch;
    margin-inline: auto;
    text-align: center;
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    margin-bottom: 3rem;
    justify-content: center;
  }
  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    justify-content: center;
  }
  .body-text {
    font-size: 0.975rem;
    line-height: 1.8;
    color: #8EAAB8;
  }

  /* ── Cards ── */
  .def-card {
    background: #0E1118;
    border: 1px solid rgba(122,175,196,0.14);
    border-radius: 1.5rem;
    padding: clamp(1.5rem, 3vw, 2.5rem);
    max-width: 820px;
  }

  /* ── Service cards / Why grid ── */
  .why-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
  }
  .why-card {
    background: #0E1118;
    border: 1px solid rgba(122,175,196,0.14);
    border-radius: 1.5rem;
    padding: 2rem;
    position: relative;
    isolation: isolate;
    overflow: hidden;
    transition: border-color 0.35s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
                box-shadow 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .why-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 110%, rgba(122,175,196,0.10) 0%, transparent 65%);
    opacity: 0;
    transition: opacity 0.45s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
    z-index: 0;
    border-radius: inherit;
  }
  .why-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: -60%;
    width: 40%;
    height: 100%;
    background: linear-gradient(
      115deg,
      transparent 0%,
      rgba(255,255,255,0.05) 45%,
      rgba(255,255,255,0.09) 50%,
      rgba(255,255,255,0.05) 55%,
      transparent 100%
    );
    transform: skewX(-18deg);
    transition: left 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
    z-index: 0;
  }
  .why-card > * { position: relative; z-index: 1; }
  .why-card:hover,
  .why-card:focus-visible {
    border-color: rgba(122,175,196,0.35);
    transform: translateY(-4px);
    box-shadow: 0 12px 36px rgba(0,0,0,0.45), 0 0 0 1px rgba(122,175,196,0.14);
  }
  .why-card:hover::before,
  .why-card:focus-visible::before { opacity: 1; }
  .why-card:hover::after,
  .why-card:focus-visible::after { left: 120%; }

  .why-icon {
    font-size: 1.5rem;
    font-weight: 900;
    margin-bottom: 1rem;
  }
  .why-title {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.625rem;
  }
  .why-body {
    font-size: 0.875rem;
    line-height: 1.75;
    color: #8EAAB8;
  }

  /* ── FAQ ── */
  .faq-list {
    max-width: 820px;
  }
  details {
    border: 1px solid rgba(122,175,196,0.12);
    border-radius: 1rem;
    background: #0E1118;
    margin-bottom: 0.75rem;
    overflow: hidden;
    position: relative;
    transition: border-color 0.35s cubic-bezier(0.22, 1, 0.36, 1),
                box-shadow 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  details::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: linear-gradient(180deg, #7AAFC4 0%, #5A95B0 100%);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    border-radius: 3px 0 0 3px;
    z-index: 1;
  }
  details:hover,
  details:focus-within {
    border-color: rgba(122,175,196,0.30);
    box-shadow: 0 4px 20px rgba(0,0,0,0.30), 0 0 0 1px rgba(122,175,196,0.10);
  }
  details:hover::before,
  details:focus-within::before { transform: scaleY(1); }
  details[open] { border-color: rgba(122,175,196,0.30); }
  details[open]::before { transform: scaleY(1); }
  summary {
    padding: 1.25rem 1.5rem;
    cursor: pointer;
    font-weight: 700;
    color: #E8F0F4;
    font-size: 0.975rem;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    transition: color 0.2s;
  }
  details:hover summary { color: #fff; }
  summary::-webkit-details-marker { display: none; }
  summary::after {
    content: '+';
    color: #7AAFC4;
    font-size: 1.25rem;
    font-weight: 300;
    flex-shrink: 0;
    transition: transform 0.25s, color 0.2s;
  }
  details:hover summary::after { color: #A0C8D8; }
  details[open] summary::after { transform: rotate(45deg); }
  .faq-body {
    padding: 0 1.5rem 1.5rem;
    font-size: 0.9rem;
    line-height: 1.8;
    color: #8EAAB8;
  }
  .faq-body a {
    color: #7AAFC4;
    text-decoration: none;
    background-image: linear-gradient(currentColor, currentColor);
    background-position: 0 100%;
    background-repeat: no-repeat;
    background-size: 0% 1px;
    transition: background-size 0.35s cubic-bezier(0.22, 1, 0.36, 1), color 0.2s;
  }
  .faq-body a:hover,
  .faq-body a:focus-visible {
    color: #A0C8D8;
    background-size: 100% 1px;
  }</style>
