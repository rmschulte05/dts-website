---
import Base from '../layouts/Base.astro';
import NavIsland from '../components/modules/NavIsland.astro';
import FooterDTS from '../components/modules/FooterDTS.astro';
import PageSection from '../components/ui/PageSection.astro';

const faqs = [
  {
    question: 'Hoe lang duurt een kalibratie?',
    answer: 'Wij kalibreren jouw momentsleutel snel na ontvangst. Heb je spoed? Neem dan even contact op, bij beschikbaarheid is een <a href="/contact">kalibratie op dezelfde dag</a> mogelijk na overleg. Na afronding ontvang je direct het kalibratiecertificaat per e-mail.',
  },
  {
    question: 'Welke merken kalibreren jullie?',
    answer: 'Wij kalibreren alle gangbare merken, waaronder <strong>Snap-On, Stahlwille, Gedore, Facom, Hazet, Würth</strong> en vele andere fabrikanten. Als <a href="/merken/snap-on-kalibratie">geautoriseerd Snap-On dealer</a> hebben wij de originele testapparatuur en documentatie die Snap-On voorschrijft. Het merk doet er dus niet toe, de precisie telt altijd.',
  },
  {
    question: 'Hoe moet ik mijn momentsleutel opsturen?',
    answer: 'Pak je momentsleutel stevig in, bij voorkeur in de originele doos of goed omwikkeld met bubbeltjesplastic. Voeg een briefje toe met jouw naam en contactgegevens zodat wij je onmiddellijk kunnen bereiken. Wij ontvangen sleutels van werkplaatsen door heel Nederland. Stuur het pakket naar:<br><br><strong>Dutch Torque Service</strong><br>Tonterstraat 42<br>5561 AN Riethoven<br><br>Na ontvangst bevestigen wij dit per e-mail en houden wij je op de hoogte van de voortgang.',
  },
  {
    question: 'Wat kost een kalibratie?',
    answer: 'De prijs is afhankelijk van het type momentsleutel, het merk en het aantal meetpunten. We werken transparant en zonder verborgen kosten. <a href="/contact">Stuur ons een bericht voor een prijsopgave</a>, we reageren binnen één werkdag. Meer weten over wat er bij <a href="/diensten/momentsleutel-kalibratie">een kalibratie</a> komt kijken?',
  },
  {
    question: 'Wat is het verschil tussen justeren en kalibreren?',
    answer: '<strong>Kalibreren</strong> is het meten en documenteren van de werkelijke waarden van jouw momentsleutel ten opzichte van de nominale waarde, zonder de sleutel aan te passen. Je krijgt een certificaat met de gemeten afwijkingen.<br><br><strong><a href="/diensten/momentsleutel-justeren">Justeren</a></strong> is het daadwerkelijk corrigeren van de sleutel zodat die weer binnen de toegestane tolerantie valt. Wij doen beide en geven na een kalibratie + justering altijd een nieuw certificaat af, inclusief de waarden vóór en na de ingreep (as-found en as-left).',
  },
  {
    question: 'Hoe lang is een kalibratiecertificaat geldig?',
    answer: 'ISO 6789:2017 en 2003 schrijft formeel geen vaste geldigheidsduur voor, dat is afhankelijk van het kwaliteitshandboek van jouw eigen organisatie of dat van jouw klant. Als richtlijn hanteren de meeste bedrijven een <strong>jaarlijkse kalibratie</strong>. Onze aanbeveling: kalibreer altijd opnieuw na een val, een incident of bij twijfel over de nauwkeurigheid. Zekerheid kost minder dan een foutieve verbinding.',
  },
  {
    question: 'Kalibreren jullie ook op locatie?',
    answer: 'Soms wel, soms niet, dat hangt af van de hoeveelheid gereedschap. Voor grotere batches of bedrijven met een uitgebreid machinepark kan kalibratie op locatie bespreekbaar zijn. <a href="/contact">Bel ons even</a>, dan kijken we samen wat het beste werkt.',
  },
  {
    question: 'Wat als mijn sleutel niet te herstellen is?',
    answer: 'We geven je altijd een <strong>eerlijk en onafhankelijk advies</strong>, ook als dat betekent dat <a href="/diensten/momentsleutel-reparatie">reparatie</a> niet meer zinvol is. Je ontvangt een beknopt rapport van onze bevindingen zodat je het kunt archiveren. Als geautoriseerd <a href="/merken/snap-on-kalibratie">Snap-On dealer</a> kun je via ons direct een vervangend Snap-On gereedschap bestellen.',
  },
  {
    question: 'Wat staat er in een kalibratiecertificaat?',
    answer: 'Ons kalibratiecertificaat voldoet aan de eisen van <a href="/diensten/iso-6789-certificering">ISO 6789:2017 en 2003</a> en bevat minimaal:<ul style="margin-top:0.75rem; padding-left:1.25rem; list-style:disc;"><li>Meetwaarden <strong>vóór</strong> kalibratie (as-found)</li><li>Meetwaarden <strong>na</strong> kalibratie / justering (as-left)</li><li>Gebruikte referentieapparatuur en traceerbaarheid</li><li>Meetpunten en nauwkeurigheidsklasse</li><li>Naam en handtekening van de uitvoerende technicus</li><li>Aanbevolen volgend kalibratieinterval</li></ul><br>Het certificaat is direct bruikbaar voor audits en kwaliteitssystemen.',
  },
  {
    question: 'Ik ben geen groot bedrijf, kalibreren jullie ook voor kleine werkplaatsen?',
    answer: 'Absoluut. Wij kalibreren voor <strong>eenmanszaken, kleine werkplaatsen en grote productiebedrijven</strong>, zonder onderscheid in service of kwaliteit. Eén momentsleutel is al genoeg om te beginnen. Stuur je sleutel gewoon op, <a href="/diensten/momentsleutel-kalibratie">een kalibratie</a> is voor iedereen. Het gaat om vakmanschap, of je nu drie sleutels hebt of driehonderd.',
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": f.answer.replace(/<[^>]+>/g, ''),
    },
  })),
};

// Note: LocalBusiness JSON-LD with @id #business is already emitted globally by Base.astro.
// Removing the duplicate inline node prevents `@id` collision in the page's JSON-LD graph.
---

<Base
  title="Momentsleutel Kalibratie FAQ | Dutch Torque Service"
  description="Veelgestelde vragen over momentsleutel kalibratie, ISO 6789:2017 en 2003 certificering en doorlooptijden bij Dutch Torque Service in Riethoven. Stuur op →"
  canonicalPath="/faq"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <NavIsland currentPage="faq" />

  <main>
    <!-- HERO -->
    <PageSection hero center animate>
        <div class="sec-eyebrow">
          <span class="w-8 h-px opacity-75" style="background:#7AAFC4;"></span>
          <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">FAQ</span>
          <span class="w-8 h-px opacity-75" style="background:#7AAFC4;"></span>
        </div>
        <h1 class="font-black tracking-tight text-white" style="font-size: clamp(2.5rem, 6vw, 4.5rem); line-height: 1.05;">
          Veelgestelde vragen over momentsleutel kalibratie.
        </h1>
        <p class="sec-sub">
          Alles wat je wilt weten over momentsleutel kalibratie, reparatie en certificering bij Dutch Torque Service.
        </p>
    </PageSection>

    <!-- FAQ ACCORDION -->
    <PageSection>
        <div class="mx-auto" style="max-width: 800px;">
          {faqs.map((faq, i) => (
            <details data-animate data-animate-delay={String(Math.min(i * 0.05, 0.4))}>
              <summary>{faq.question}</summary>
              <div class="faq-body" set:html={faq.answer} />
            </details>
          ))}
        </div>
    </PageSection>

    <!-- CTA -->
    <PageSection center animate>
        <h2 class="text-3xl md:text-4xl font-black tracking-tight text-white mb-4">Staat jouw vraag er niet bij?</h2>
        <p class="mb-8 mx-auto" style="color: #9AAEB8; max-width: 40ch; font-size: 1.05rem; line-height: 1.75;">
          Bel ons direct. We nemen de tijd voor je vraag.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="tel:+31613172774" class="btn btn-primary">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="1.5"/></svg>
            +31(0)6-131 72 774
          </a>
          <a href="mailto:info@dutchtorqueservice.nl" class="btn btn-outline">
            info@dutchtorqueservice.nl
          </a>
        </div>
    </PageSection>
  </main>

  <FooterDTS />
</Base>

<style>
  details {
    border: 1px solid rgba(122,175,196,0.12);
    border-radius: 1rem;
    background: #0E1118;
    margin-bottom: 0.75rem;
    overflow: hidden;
    transition: border-color 0.3s cubic-bezier(0.22, 1, 0.36, 1),
                background 0.3s cubic-bezier(0.22, 1, 0.36, 1),
                box-shadow 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  details[open] {
    border-color: rgba(122,175,196,0.32);
    box-shadow: 0 4px 24px rgba(122,175,196,0.07);
  }
  /* Subtle accent tint on hover when closed */
  details:not([open]):hover {
    background: rgba(122,175,196,0.035);
    border-color: rgba(122,175,196,0.24);
  }
  summary {
    padding: 1.25rem 1.5rem;
    cursor: pointer;
    font-weight: 700;
    color: #E8F0F4;
    font-size: 0.975rem;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    transition: color 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }
  details:not([open]) summary:hover { color: #ffffff; }
  details[open] summary { color: #ffffff; }
  summary::-webkit-details-marker {
    display: none;
  }
  /* Icon: SVG + circle that rotates to × on open */
  summary::after {
    content: '';
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background-color: rgba(122,175,196,0.10);
    border: 1px solid rgba(122,175,196,0.25);
    background-image: url("data:image/svg+xml,%3Csvg width='10' height='10' viewBox='0 0 10 10' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M5 2v6M2 5h6' stroke='%237AAFC4' stroke-width='1.5' stroke-linecap='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: center;
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
                background-color 0.25s ease,
                box-shadow 0.25s ease;
  }
  details:not([open]) summary:hover::after {
    background-color: rgba(122,175,196,0.20);
    box-shadow: 0 0 10px rgba(122,175,196,0.28);
  }
  details[open] summary::after {
    transform: rotate(45deg);
    background-color: rgba(122,175,196,0.22);
  }
  .faq-body {
    padding: 0 1.5rem 1.5rem;
    font-size: 0.975rem;
    line-height: 1.8;
    color: #A8BDC7;
  }
  /* Inline links, animated underline grows L→R */
  .faq-body a {
    color: #7AAFC4;
    text-decoration: none;
    background-image: linear-gradient(#7AAFC4, #9BC8D9);
    background-repeat: no-repeat;
    background-size: 0% 1px;
    background-position: left bottom;
    transition: color 0.25s cubic-bezier(0.22, 1, 0.36, 1),
                background-size 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .faq-body a:hover,
  .faq-body a:focus-visible {
    color: #9BC8D9;
    background-size: 100% 1px;
  }
</style>
