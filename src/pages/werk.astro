---
import Base from '../layouts/Base.astro';
import NavIsland from '../components/modules/NavIsland.astro';
import FooterDTS from '../components/modules/FooterDTS.astro';
import { cases } from '../data/cases.ts';

const serviceColors: Record<string, string> = {
  'Kalibratie':    '#7AAFC4',
  'Reparatie':     '#C48A64',
  'Certificering': '#64C48A',
  'Justeren':      '#C4AF64',
  'Reiniging':     '#9696C4',
};

function shortDate(d: string) {
  const parts = d.split(' ');
  const monthMap: Record<string,string> = {
    januari:'Jan', februari:'Feb', maart:'Mrt', april:'Apr', mei:'Mei',
    juni:'Jun', juli:'Jul', augustus:'Aug', september:'Sep',
    oktober:'Okt', november:'Nov', december:'Dec',
  };
  return `${monthMap[parts[1]] ?? parts[1]} ${parts[2]}`;
}

const filters = [
  { label: 'Alle Cases',   key: 'alle',          color: '#B8C8D4' },
  { label: 'Kalibratie',   key: 'Kalibratie',    color: '#7AAFC4' },
  { label: 'Reparatie',    key: 'Reparatie',     color: '#C48A64' },
  { label: 'Certificering',key: 'Certificering', color: '#64C48A' },
  { label: 'Justeren',     key: 'Justeren',      color: '#C4AF64' },
  { label: 'Reiniging',    key: 'Reiniging',     color: '#9696C4' },
];

const features = [
  {
    n: '01',
    label: 'ISO 6789 Gecertificeerd',
    body: 'Elk gereedschap wordt gekalibreerd conform ISO 6789 — type I en type II. U ontvangt een volledig kalibratieprotocol.',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none">
      <rect x="4" y="4" width="20" height="20" rx="3" stroke="currentColor" stroke-width="1.5"/>
      <path d="M9 14l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>`,
    accent: '#64C48A',
  },
  {
    n: '02',
    label: '5-Punts Verificatie',
    body: 'We meten op vijf meetpunten over het volledige torquebereik. Elke afwijking wordt nauwkeurig geregistreerd.',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none">
      <circle cx="14" cy="14" r="10" stroke="currentColor" stroke-width="1.4"/>
      <circle cx="14" cy="14" r="4"  stroke="currentColor" stroke-width="1.4"/>
      <circle cx="14" cy="14" r="1.5" fill="currentColor"/>
      <line x1="14" y1="4"  x2="14" y2="7"  stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      <line x1="4"  y1="14" x2="7"  y2="14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      <line x1="21" y1="14" x2="24" y2="14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
    </svg>`,
    accent: '#7AAFC4',
  },
  {
    n: '03',
    label: '±2% Nauwkeurigheid',
    body: 'Kalibratie-uitslag valt altijd binnen de ±2% tolerantie van de ISO norm. Geen compromissen op precisie.',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none">
      <rect x="4" y="10" width="20" height="12" rx="2" stroke="currentColor" stroke-width="1.5"/>
      <line x1="4"  y1="16" x2="24" y2="16" stroke="currentColor" stroke-width="0.75" stroke-opacity="0.5"/>
      <line x1="8"  y1="10" x2="8"  y2="7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="14" y1="10" x2="14" y2="5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="20" y1="10" x2="20" y2="7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>`,
    accent: '#C4AF64',
  },
  {
    n: '04',
    label: '48u Doorlooptijd',
    body: 'Van inleveren tot gecalibreerd en gecertificeerd gereedschap — standaard binnen 48 uur terug in uw werkplaats.',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none">
      <circle cx="14" cy="16" r="9" stroke="currentColor" stroke-width="1.4"/>
      <path d="M14 9v7l4 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M9 4h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <path d="M14 4v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>`,
    accent: '#9696C4',
  },
];
---

<Base title="Ons Werk — Dutch Torque Service">
  <NavIsland currentPage="werk" />

  <div class="werk-page">

    <!-- ── MECHANICAL BACKGROUND LAYER ── -->
    <div class="mech-bg" aria-hidden="true">
      <!-- Dot grid -->
      <div class="mech-dots"></div>
      <!-- Precision gauge SVG — top right -->
      <svg class="mech-gauge" viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- Outer ring -->
        <circle cx="200" cy="200" r="190" stroke="#7AAFC4" stroke-width="0.5"/>
        <!-- Middle ring -->
        <circle cx="200" cy="200" r="150" stroke="#7AAFC4" stroke-width="0.3"/>
        <!-- Inner ring -->
        <circle cx="200" cy="200" r="80"  stroke="#7AAFC4" stroke-width="0.5"/>
        <!-- Crosshairs -->
        <line x1="200" y1="10"  x2="200" y2="390" stroke="#7AAFC4" stroke-width="0.4"/>
        <line x1="10"  y1="200" x2="390" y2="200" stroke="#7AAFC4" stroke-width="0.4"/>
        <!-- Diagonal hairlines -->
        <line x1="65"  y1="65"  x2="335" y2="335" stroke="#7AAFC4" stroke-width="0.25"/>
        <line x1="335" y1="65"  x2="65"  y2="335" stroke="#7AAFC4" stroke-width="0.25"/>
        <!-- Tick marks — every 30° -->
        {Array.from({length: 12}, (_, i) => {
          const angle = (i * 30 - 90) * Math.PI / 180;
          const isMajor = i % 3 === 0;
          const r1 = 190;
          const r2 = isMajor ? 175 : 182;
          const x1 = 200 + r1 * Math.cos(angle);
          const y1 = 200 + r1 * Math.sin(angle);
          const x2 = 200 + r2 * Math.cos(angle);
          const y2 = 200 + r2 * Math.sin(angle);
          return <line x1={x1} y1={y1} x2={x2} y2={y2} stroke="#7AAFC4" stroke-width={isMajor ? "1.2" : "0.5"}/>;
        })}
        <!-- Center dot -->
        <circle cx="200" cy="200" r="4" fill="#7AAFC4"/>
        <circle cx="200" cy="200" r="2" fill="#08090B"/>
        <!-- Arc indicator -->
        <path d="M 200 50 A 150 150 0 0 1 350 200" stroke="#7AAFC4" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <!-- Scan lines -->
      <div class="mech-scan"></div>
    </div>

    <!-- ── HERO ── -->
    <section class="werk-hero">
      <div class="werk-container">
        <div class="werk-hero-inner">

          <div class="werk-hero-text">
            <div class="flex items-center gap-3 mb-6">
              <span class="block w-8 h-px" style="background:#7AAFC4;"></span>
              <span class="eyebrow-text">Ons Werk</span>
            </div>
            <h1 class="werk-headline">
              ELKE SLEUTEL<br/>GECERTIFICEERD.
            </h1>
            <p class="werk-sub">
              Een overzicht van uitgevoerd kalibratie- en servicewerk.
              Elk geval gedocumenteerd, gemeten en gecertificeerd conform ISO&nbsp;6789.
            </p>
          </div>

          <div class="werk-hero-stats">
            <div class="stat-block">
              <div class="stat-value">{cases.length}</div>
              <div class="stat-label">Cases</div>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-block">
              <div class="stat-value">100%</div>
              <div class="stat-label">ISO Cert.</div>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-block">
              <div class="stat-value">±2%</div>
              <div class="stat-label">Nauwkeurig</div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ── FILTER BAR ── -->
    <div class="filter-bar-wrap">
      <div class="werk-container">
        <div class="filter-bar">
          <div class="filter-left">
            <span class="filter-label">Filter op dienst</span>
            <div class="filter-pills">
              {filters.map((f, i) => (
                <button
                  class={`filter-pill${i === 0 ? ' active' : ''}`}
                  data-filter={f.key}
                  style={`--pill-color: ${f.color};`}
                >
                  {i > 0 && <span class="pill-dot" style={`background:${f.color};`}></span>}
                  {f.label}
                </button>
              ))}
            </div>
          </div>
          <span class="filter-count" id="filter-count">{cases.length} resultaten</span>
        </div>
      </div>
    </div>

    <!-- ── CASES GRID ── -->
    <section class="werk-grid-section">
      <div class="werk-container">
        <div class="werk-grid">

          {cases.map((c) => {
            const isCert = c.services.includes('Certificering');
            return (
              <article class="werk-card" data-services={c.services.join(',')}>
                <!-- Image -->
                <div class="werk-card-img">
                  {isCert && (
                    <div class="cert-badge">
                      <span class="cert-dot"></span>
                      Gecertificeerd
                    </div>
                  )}
                  {c.before ? (
                    <img src={c.before} alt={c.model} class="w-full h-full object-cover" loading="lazy"/>
                  ) : (
                    <div class="img-placeholder">
                      <div class="img-grid"></div>
                      <svg width="52" height="22" viewBox="0 0 80 32" fill="none" class="relative z-10 opacity-[0.18]">
                        <circle cx="12" cy="16" r="10" stroke="#7AAFC4" stroke-width="1.5"/>
                        <circle cx="12" cy="16" r="5"  stroke="#7AAFC4" stroke-width="1"/>
                        <rect x="22" y="12" width="38" height="8" rx="2" stroke="#7AAFC4" stroke-width="1.5"/>
                        <rect x="60" y="10" width="14" height="12" rx="3" stroke="#7AAFC4" stroke-width="1.5"/>
                      </svg>
                    </div>
                  )}
                  <!-- Accent line bottom-left -->
                  <div class="img-accent"></div>
                </div>

                <!-- Body -->
                <div class="werk-card-body">
                  <div class="card-top-row">
                    <span class="card-type">{c.type}</span>
                    {isCert && (
                      <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                        <circle cx="8" cy="8" r="7" stroke="#64C48A" stroke-width="1.2"/>
                        <path d="M5 8l2 2 4-4" stroke="#64C48A" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    )}
                  </div>
                  <h2 class="card-model">{c.model}</h2>
                  <div class="card-rule"></div>
                  <div class="card-specs">
                    <div class="spec-row">
                      <span class="spec-k">Bereik</span>
                      <span class="spec-v">{c.range}</span>
                    </div>
                    <div class="spec-row">
                      <span class="spec-k">Diensten</span>
                      <span class="spec-v spec-svc">
                        {c.services.map((s, si) => (
                          <span style={`color:${serviceColors[s] ?? '#7AAFC4'}`}>
                            {s}{si < c.services.length - 1 ? <span style="color:rgba(255,255,255,0.15)"> · </span> : ''}
                          </span>
                        ))}
                      </span>
                    </div>
                    <div class="spec-row">
                      <span class="spec-k">Datum</span>
                      <span class="spec-v">{shortDate(c.date)}</span>
                    </div>
                  </div>
                </div>
              </article>
            );
          })}

          <!-- CTA card -->
          <div class="cta-card">
            <div class="cta-watermark">DTS</div>
            <div class="cta-content">
              <p class="cta-eyebrow">Dutch Torque Service</p>
              <h3 class="cta-heading">OFFERTE<br/>AANVRAGEN?</h3>
              <p class="cta-body">Onze ISO-gecertificeerde technici zorgen dat jouw gereedschap weer op specificatie is — binnen 48 uur.</p>
              <a href="/contact" class="cta-btn">
                Plan een service
                <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                  <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ── WHY DTS FEATURES ── -->
    <section class="features-section">
      <div class="werk-container">

        <!-- Header -->
        <div class="features-header">
          <div class="flex items-center gap-3">
            <span class="block w-8 h-px" style="background:#7AAFC4;"></span>
            <span class="eyebrow-text">Waarom DTS</span>
            <span class="block w-8 h-px" style="background:#7AAFC4;"></span>
          </div>
          <h2 class="features-title">De standaard<br/>waarvoor wij staan.</h2>
        </div>

        <!-- 2×2 feature cards -->
        <div class="features-grid">
          {features.map((f, i) => (
            <div class={`feature-card feature-card--${i % 2 === 0 ? 'a' : 'b'}`}>
              <!-- Top row: number + icon -->
              <div class="fc-top">
                <span class="fc-num" style={`color:${f.accent};`}>{f.n}</span>
                <div class="fc-icon" style={`color:${f.accent}; border-color:${f.accent}33; background:${f.accent}12;`}>
                  <Fragment set:html={f.icon} />
                </div>
              </div>
              <!-- Rule -->
              <div class="fc-rule" style={`background:${f.accent}30;`}></div>
              <!-- Text -->
              <h3 class="fc-label">{f.label}</h3>
              <p class="fc-body">{f.body}</p>
              <!-- Decorative corner mark -->
              <div class="fc-corner" style={`border-color:${f.accent}40;`}></div>
            </div>
          ))}
        </div>

      </div>
    </section>

  </div>

  <FooterDTS />
</Base>

<style>
  /* ── PAGE SHELL ── */
  .werk-page {
    background: #08090B;
    min-height: 100vh;
    overflow-x: hidden;
    position: relative;
  }

  /* Shared container — used instead of .page-container to avoid double-margin issues */
  .werk-container {
    width: 100%;
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: var(--page-px);
  }

  .eyebrow-text {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: #7AAFC4;
  }

  /* ── MECHANICAL BACKGROUND ── */
  .mech-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }

  .mech-dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(122,175,196,0.035) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  .mech-gauge {
    position: absolute;
    top: -80px;
    right: -120px;
    width: clamp(360px, 45vw, 560px);
    height: auto;
    opacity: 0.055;
  }

  .mech-scan {
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 3px,
      rgba(122,175,196,0.012) 3px,
      rgba(122,175,196,0.012) 4px
    );
  }

  /* ── HERO ── */
  .werk-hero {
    position: relative;
    z-index: 1;
    padding-top: clamp(8rem, 15vw, 12rem);
    padding-bottom: clamp(4rem, 7vw, 6.5rem);
    border-bottom: 1px solid rgba(122,175,196,0.08);
  }

  .werk-hero-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 4rem;
    row-gap: 3.5rem;
  }

  .werk-hero-text { flex: 1; min-width: 280px; }

  .werk-headline {
    font-size: clamp(2.8rem, 7.5vw, 6.5rem);
    font-weight: 900;
    line-height: 0.92;
    letter-spacing: -0.025em;
    color: #fff;
    margin-bottom: 1.5rem;
  }

  .werk-sub {
    font-size: 1rem;
    line-height: 1.75;
    color: #A0B4BE;
    max-width: 46ch;
  }

  .werk-hero-stats {
    display: flex;
    align-items: stretch;
    border: 1px solid rgba(122,175,196,0.18);
    border-radius: 1.1rem;
    overflow: hidden;
    background: rgba(122,175,196,0.04);
    flex-shrink: 0;
  }

  .stat-block {
    padding: 1.5rem 2.25rem;
    text-align: center;
  }
  .stat-value {
    font-size: 1.9rem;
    font-weight: 900;
    line-height: 1;
    margin-bottom: 0.4rem;
    background: linear-gradient(135deg, #9BC5D8, #7AAFC4);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .stat-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(122,175,196,0.50);
    white-space: nowrap;
  }
  .stat-divider {
    width: 1px;
    background: rgba(122,175,196,0.14);
    flex-shrink: 0;
  }

  /* ── FILTER BAR ── */
  .filter-bar-wrap {
    position: sticky;
    top: 0;
    z-index: 40;
    background: #0C0F14;
    border-top: 1px solid rgba(122,175,196,0.12);
    border-bottom: 1px solid rgba(122,175,196,0.12);
    padding-block: 1.25rem;
    box-shadow: 0 4px 24px rgba(0,0,0,0.40);
  }

  .filter-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .filter-left {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .filter-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.30);
    white-space: nowrap;
    padding-right: 1rem;
    border-right: 1px solid rgba(122,175,196,0.14);
  }

  .filter-pills { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  .filter-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    height: 36px;
    padding: 0 16px;
    border-radius: 100px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.10);
    color: rgba(255,255,255,0.55);
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .filter-pill:hover {
    background: rgba(255,255,255,0.08);
    border-color: var(--pill-color, rgba(122,175,196,0.5));
    color: var(--pill-color, #7AAFC4);
  }
  .filter-pill.active {
    background: var(--pill-color, #7AAFC4);
    border-color: var(--pill-color, #7AAFC4);
    color: #08090B;
    box-shadow: 0 0 14px color-mix(in srgb, var(--pill-color, #7AAFC4) 40%, transparent);
  }
  .filter-pill.active .pill-dot {
    background: rgba(0,0,0,0.50) !important;
    box-shadow: none;
  }

  .pill-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
    box-shadow: 0 0 4px currentColor;
  }

  .filter-count {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(122,175,196,0.45);
    white-space: nowrap;
    background: rgba(122,175,196,0.06);
    border: 1px solid rgba(122,175,196,0.14);
    padding: 5px 12px;
    border-radius: 100px;
    transition: color 0.2s ease;
  }

  /* Hidden card state */
  .werk-card[data-filtered] {
    display: none;
  }

  /* ── CASES GRID ── */
  .werk-grid-section {
    position: relative;
    z-index: 1;
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  .werk-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 1.25rem;
  }
  @media (min-width: 600px)  { .werk-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .werk-grid { grid-template-columns: repeat(3, 1fr); } }

  /* ── CASE CARD ── */
  .werk-card {
    background: #0D1017;
    border: 1px solid rgba(122,175,196,0.14);
    border-radius: 1.1rem;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    cursor: pointer;
    transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
    box-shadow: 0 2px 16px rgba(0,0,0,0.30);
  }
  .werk-card:hover {
    border-color: rgba(122,175,196,0.32);
    box-shadow: 0 12px 40px rgba(0,0,0,0.50), 0 0 0 1px rgba(122,175,196,0.08);
    transform: translateY(-3px);
  }

  .werk-card-img {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #090B0F;
  }

  .img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  .img-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(122,175,196,0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(122,175,196,0.05) 1px, transparent 1px);
    background-size: 28px 28px;
  }

  .cert-badge {
    position: absolute;
    top: 10px;
    left: 10px;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 4px 10px;
    border-radius: 100px;
    background: rgba(6,8,10,0.80);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(100,196,138,0.28);
    font-size: 0.575rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #64C48A;
  }
  .cert-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
