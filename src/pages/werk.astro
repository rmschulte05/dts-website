---
import Base from '../layouts/Base.astro';
import NavIsland from '../components/modules/NavIsland.astro';
import FooterDTS from '../components/modules/FooterDTS.astro';

// Cases page is in placeholder state until the first published case studies land.
// The route stays live and indexable so SEO equity (links, sitemap entry,
// keyword authority on "momentsleutel kalibratie cases") is preserved.

const features = [
  {
    n: '01',
    label: 'ISO 6789 Gecertificeerd',
    body: 'Elk gereedschap wordt gekalibreerd conform ISO 6789:2017 en 2003, type I en type II. U ontvangt een volledig kalibratieprotocol.',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none">
      <rect x="4" y="4" width="20" height="20" rx="3" stroke="currentColor" stroke-width="1.5"/>
      <path d="M9 14l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>`,
    accent: '#64C48A',
  },
  {
    n: '02',
    label: '5-Punts Verificatie',
    body: 'We meten op vijf meetpunten over het volledige torquebereik. Elke afwijking wordt nauwkeurig geregistreerd.',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none">
      <circle cx="14" cy="14" r="10" stroke="currentColor" stroke-width="1.4"/>
      <circle cx="14" cy="14" r="4"  stroke="currentColor" stroke-width="1.4"/>
      <circle cx="14" cy="14" r="1.5" fill="currentColor"/>
      <line x1="14" y1="4"  x2="14" y2="7"  stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      <line x1="4"  y1="14" x2="7"  y2="14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      <line x1="21" y1="14" x2="24" y2="14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
    </svg>`,
    accent: '#7AAFC4',
  },
  {
    n: '03',
    label: '±2% Nauwkeurigheid',
    body: 'Wij garanderen ±2%, ruim binnen de ±4% ISO 6789:2017 en 2003 tolerantie. Geen compromissen op precisie.',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none">
      <rect x="4" y="10" width="20" height="12" rx="2" stroke="currentColor" stroke-width="1.5"/>
      <line x1="4"  y1="16" x2="24" y2="16" stroke="currentColor" stroke-width="0.75" stroke-opacity="0.5"/>
      <line x1="8"  y1="10" x2="8"  y2="7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="14" y1="10" x2="14" y2="5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="20" y1="10" x2="20" y2="7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>`,
    accent: '#C4AF64',
  },
  {
    n: '04',
    label: 'Snelle Doorlooptijd',
    body: 'Van inleveren tot gecalibreerd en gecertificeerd gereedschap weer snel terug in uw werkplaats.',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none">
      <circle cx="14" cy="16" r="9" stroke="currentColor" stroke-width="1.4"/>
      <path d="M14 9v7l4 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M9 4h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <path d="M14 4v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>`,
    accent: '#9696C4',
  },
];

// Service categories shown as a card grid (the "what kind of work" placeholder)
const services = [
  {
    title: 'Kalibratie',
    body: 'Meting op 5 meetpunten over het volledige bereik. As-found en as-left waarden in een audit-proof protocol.',
    href: '/diensten/momentsleutel-kalibratie',
    accent: '#7AAFC4',
  },
  {
    title: 'Reparatie',
    body: 'Volledige revisie van klikmechanisme, ratel of veer, gevolgd door hercalibratie. Originele Snap-On onderdelen direct beschikbaar.',
    href: '/diensten/momentsleutel-reparatie',
    accent: '#C48A64',
  },
  {
    title: 'Justeren',
    body: 'Sleutel buiten tolerantie? Wij stellen hem opnieuw in op de juiste Newton-meterwaarden conform de fabrieksspecificatie.',
    href: '/diensten/momentsleutel-justeren',
    accent: '#C4AF64',
  },
  {
    title: 'ISO Certificering',
    body: 'Officieel ISO 6789:2017 en 2003 kalibratiecertificaat, geschikt voor ISO 9001, IATF 16949 en VCA kwaliteitssystemen.',
    href: '/diensten/iso-6789-certificering',
    accent: '#64C48A',
  },
];
---

<Base
  title="Ons Werk, Momentsleutel Kalibratie & Reparatie | Dutch Torque Service"
  description="Een blik op het werk van Dutch Torque Service: ISO 6789:2017 en 2003 kalibratie, reparatie en certificering van momentsleutels. Cases volgen binnenkort."
  canonicalPath="/werk"
>
  <NavIsland currentPage="werk" />

  <div class="werk-page">

    <!-- ── MECHANICAL BACKGROUND LAYER ── -->
    <div class="mech-bg" aria-hidden="true">
      <div class="mech-dots"></div>
      <svg class="mech-gauge" viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="200" cy="200" r="190" stroke="#7AAFC4" stroke-width="0.5"/>
        <circle cx="200" cy="200" r="150" stroke="#7AAFC4" stroke-width="0.3"/>
        <circle cx="200" cy="200" r="80"  stroke="#7AAFC4" stroke-width="0.5"/>
        <line x1="200" y1="10"  x2="200" y2="390" stroke="#7AAFC4" stroke-width="0.4"/>
        <line x1="10"  y1="200" x2="390" y2="200" stroke="#7AAFC4" stroke-width="0.4"/>
        <line x1="65"  y1="65"  x2="335" y2="335" stroke="#7AAFC4" stroke-width="0.25"/>
        <line x1="335" y1="65"  x2="65"  y2="335" stroke="#7AAFC4" stroke-width="0.25"/>
        {Array.from({length: 12}, (_, i) => {
          const angle = (i * 30 - 90) * Math.PI / 180;
          const isMajor = i % 3 === 0;
          const r1 = 190;
          const r2 = isMajor ? 175 : 182;
          const x1 = 200 + r1 * Math.cos(angle);
          const y1 = 200 + r1 * Math.sin(angle);
          const x2 = 200 + r2 * Math.cos(angle);
          const y2 = 200 + r2 * Math.sin(angle);
          return <line x1={x1} y1={y1} x2={x2} y2={y2} stroke="#7AAFC4" stroke-width={isMajor ? "1.2" : "0.5"}/>;
        })}
        <circle cx="200" cy="200" r="4" fill="#7AAFC4"/>
        <circle cx="200" cy="200" r="2" fill="#08090B"/>
        <path d="M 200 50 A 150 150 0 0 1 350 200" stroke="#7AAFC4" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <div class="mech-scan"></div>
    </div>

    <!-- ── HERO ── -->
    <section class="werk-hero">
      <div class="werk-container">
        <div class="werk-hero-inner">

          <div class="werk-hero-text">
            <div class="flex items-center gap-3 mb-6">
              <span class="block w-8 h-px" style="background:#7AAFC4;"></span>
              <span class="eyebrow-text">Ons Werk</span>
            </div>
            <h1 class="werk-headline">
              ELKE SLEUTEL<br/>GECERTIFICEERD.
            </h1>
            <p class="werk-sub">
              Een korte introductie tot het werk van Dutch Torque Service: kalibratie, reparatie, justering en
              certificering van momentsleutels conform ISO&nbsp;6789:2017 en 2003. Casevoorbeelden uit de
              werkplaats volgen binnenkort.
            </p>
          </div>

          <div class="werk-hero-stats">
            <div class="stat-block">
              <div class="stat-value">ISO</div>
              <div class="stat-label">6789 Cert.</div>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-block">
              <div class="stat-value">±2%</div>
              <div class="stat-label">Nauwkeurig</div>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-block">
              <div class="stat-value">5</div>
              <div class="stat-label">Meetpunten</div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ── WHAT WE DO (placeholder for cases grid) ── -->
    <section class="services-section">
      <div class="werk-container">

        <div class="services-header">
          <div class="flex items-center gap-3">
            <span class="block w-8 h-px" style="background:#7AAFC4;"></span>
            <span class="eyebrow-text">Het Werk</span>
            <span class="block w-8 h-px" style="background:#7AAFC4;"></span>
          </div>
          <h2 class="services-title">Wat wij doen, in vier disciplines.</h2>
          <p class="services-intro">
            Wij werken aan momentsleutels van Snap-On, Stahlwille, Gedore, Facom, Hazet, Würth en alle andere
            kwaliteitsmerken. Hieronder een overzicht van de diensten die wij dagelijks uitvoeren in ons lab in
            Riethoven, Noord-Brabant.
          </p>
        </div>

        <div class="services-grid">
          {services.map((s) => (
            <a class="service-card" href={s.href} style={`--accent: ${s.accent};`}>
              <div class="sc-rule"></div>
              <h3 class="sc-title">{s.title}</h3>
              <p class="sc-body">{s.body}</p>
              <span class="sc-link">
                Meer over deze dienst
                <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <div class="sc-corner" aria-hidden="true"></div>
            </a>
          ))}
        </div>

        <!-- Coming-soon notice for actual case studies -->
        <div class="cases-notice">
          <span class="cases-notice-dot"></span>
          <p>
            <strong>Casevoorbeelden volgen binnenkort.</strong>
            Wij documenteren ons werk zorgvuldig, maar publiceren pas zodra wij voldoende afgeronde
            case-foto's en meetprotocollen kunnen tonen. Vragen over een specifieke sleutel of merk?
            <a href="/contact">Neem contact op</a>, dan vertellen wij je precies wat wij voor jou kunnen doen.
          </p>
        </div>

      </div>
    </section>

    <!-- ── WHY DTS FEATURES ── -->
    <section class="features-section">
      <div class="werk-container">

        <div class="features-header">
          <div class="flex items-center gap-3">
            <span class="block w-8 h-px" style="background:#7AAFC4;"></span>
            <span class="eyebrow-text">Waarom DTS</span>
            <span class="block w-8 h-px" style="background:#7AAFC4;"></span>
          </div>
          <h2 class="features-title">De standaard<br/>waarvoor wij staan.</h2>
        </div>

        <div class="features-grid">
          {features.map((f, i) => (
            <div class={`feature-card feature-card--${i % 2 === 0 ? 'a' : 'b'}`}>
              <div class="fc-top">
                <span class="fc-num" style={`color:${f.accent};`}>{f.n}</span>
                <div class="fc-icon" style={`color:${f.accent}; border-color:${f.accent}33; background:${f.accent}12;`}>
                  <Fragment set:html={f.icon} />
                </div>
              </div>
              <div class="fc-rule" style={`background:${f.accent}30;`}></div>
              <h3 class="fc-label">{f.label}</h3>
              <p class="fc-body">{f.body}</p>
              <div class="fc-corner" style={`border-color:${f.accent}40;`}></div>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- ── CTA ── -->
    <section class="cta-section">
      <div class="werk-container">
        <div class="cta-card">
          <div class="cta-watermark">DTS</div>
          <div class="cta-content">
            <p class="cta-eyebrow">Dutch Torque Service</p>
            <h3 class="cta-heading">OFFERTE<br/>AANVRAGEN?</h3>
            <p class="cta-body">Wij zorgen dat jouw gereedschap weer op specificatie is.</p>
            <a href="/contact" class="cta-btn">
              Neem contact op
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

  </div>

  <FooterDTS />
</Base>

<style>
  /* ── PAGE SHELL ── */
  .werk-page {
    background: #08090B;
    min-height: 100vh;
    overflow-x: hidden;
    position: relative;
  }

  .werk-container {
    width: 100%;
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: var(--page-px);
  }

  .eyebrow-text {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: #7AAFC4;
  }

  /* ── MECHANICAL BACKGROUND ── */
  .mech-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }
  .mech-dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(122,175,196,0.035) 1px, transparent 1px);
    background-size: 40px 40px;
  }
  .mech-gauge {
    position: absolute;
    top: -80px;
    right: -120px;
    width: clamp(360px, 45vw, 560px);
    height: auto;
    opacity: 0.055;
  }
  .mech-scan {
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 3px,
      rgba(122,175,196,0.012) 3px,
      rgba(122,175,196,0.012) 4px
    );
  }

  /* ── HERO ── */
  .werk-hero {
    position: relative;
    z-index: 1;
    padding-top: clamp(8rem, 15vw, 12rem);
    padding-bottom: clamp(4rem, 7vw, 6.5rem);
    border-bottom: 1px solid rgba(122,175,196,0.08);
  }
  .werk-hero-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 4rem;
    row-gap: 3.5rem;
  }
  .werk-hero-text { flex: 1; min-width: 280px; }
  .werk-headline {
    font-size: clamp(2.8rem, 7.5vw, 6.5rem);
    font-weight: 900;
    line-height: 0.92;
    letter-spacing: -0.025em;
    color: #fff;
    margin-bottom: 1.5rem;
  }
  .werk-sub {
    font-size: 1rem;
    line-height: 1.75;
    color: #A0B4BE;
    max-width: 56ch;
  }
  .werk-hero-stats {
    display: flex;
    align-items: stretch;
    border: 1px solid rgba(122,175,196,0.18);
    border-radius: 1.1rem;
    overflow: hidden;
    background: rgba(122,175,196,0.04);
    flex-shrink: 0;
  }
  .stat-block {
    padding: 1.5rem 2.25rem;
    text-align: center;
  }
  .stat-value {
    font-size: 1.9rem;
    font-weight: 900;
    line-height: 1;
    margin-bottom: 0.4rem;
    background: linear-gradient(135deg, #9BC5D8, #7AAFC4);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .stat-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(122,175,196,0.50);
    white-space: nowrap;
  }
  .stat-divider {
    width: 1px;
    background: rgba(122,175,196,0.14);
    flex-shrink: 0;
  }
  @media (max-width: 639px) {
    .stat-block { padding: 1rem 1.25rem; }
  }

  /* ── SERVICES SECTION (placeholder for cases) ── */
  .services-section {
    position: relative;
    z-index: 1;
    padding-block: clamp(4rem, 8vw, 7rem);
  }
  .services-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.25rem;
    margin-bottom: clamp(3rem, 5vw, 4.5rem);
  }
  .services-title {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 900;
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: #fff;
  }
  .services-intro {
    font-size: 1rem;
    line-height: 1.75;
    color: #9AAEB8;
    max-width: 60ch;
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 640px)  { .services-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .services-grid { grid-template-columns: repeat(4, 1fr); } }

  .service-card {
    position: relative;
    padding: 2rem 1.75rem 1.75rem;
    border-radius: 1.25rem;
    border: 1px solid color-mix(in srgb, var(--accent) 16%, transparent);
    background: linear-gradient(140deg, color-mix(in srgb, var(--accent) 6%, transparent) 0%, transparent 60%),
                #0E1118;
    overflow: hidden;
    isolation: isolate;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    transition:
      border-color 0.4s cubic-bezier(0.22, 1, 0.36, 1),
      transform    0.4s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow   0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .service-card::after {
    content: '';
    position: absolute;
    top: 0; left: -60%;
    width: 40%; height: 100%;
    background: linear-gradient(115deg,
      transparent 0%,
      rgba(255,255,255,0.04) 45%,
      rgba(255,255,255,0.09) 50%,
      rgba(255,255,255,0.04) 55%,
      transparent 100%);
    transform: skewX(-18deg);
    transition: left 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
    z-index: 0;
  }
  .service-card > * { position: relative; z-index: 1; }
  .service-card:hover,
  .service-card:focus-visible {
    border-color: color-mix(in srgb, var(--accent) 50%, transparent);
    transform: translateY(-4px);
    box-shadow:
      0 14px 36px rgba(0,0,0,0.45),
      0 0 28px color-mix(in srgb, var(--accent) 12%, transparent);
  }
  .service-card:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--accent) 70%, transparent);
    outline-offset: 3px;
  }
  .service-card:hover::after,
  .service-card:focus-visible::after { left: 120%; }

  .sc-rule {
    height: 2px;
    width: 36px;
    background: var(--accent);
    border-radius: 2px;
    opacity: 0.85;
  }
  .sc-title {
    font-size: 1.2rem;
    font-weight: 900;
    color: #fff;
    letter-spacing: -0.01em;
    line-height: 1.15;
  }
  .sc-body {
    font-size: 0.85rem;
    line-height: 1.65;
    color: #8EAAB8;
    flex: 1;
  }
  .sc-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-top: 0.25rem;
    transition: gap 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .service-card:hover .sc-link,
  .service-card:focus-visible .sc-link { gap: 0.7rem; }
  .sc-corner {
    position: absolute;
    bottom: 0.875rem;
    right: 0.875rem;
    width: 14px;
    height: 14px;
    border-right: 1.5px solid var(--accent);
    border-bottom: 1.5px solid var(--accent);
    border-radius: 0 0 4px 0;
    opacity: 0.30;
    transition: opacity 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .service-card:hover .sc-corner,
  .service-card:focus-visible .sc-corner { opacity: 0.70; }

  /* Coming-soon notice */
  .cases-notice {
    margin-top: clamp(2.5rem, 4vw, 3.5rem);
    padding: 1.25rem 1.5rem;
    border-radius: 1rem;
    background: rgba(122,175,196,0.05);
    border: 1px solid rgba(122,175,196,0.18);
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
  }
  .cases-notice-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #7AAFC4;
    box-shadow: 0 0 8px rgba(122,175,196,0.7);
    margin-top: 0.55rem;
    flex-shrink: 0;
  }
  .cases-notice p {
    font-size: 0.9rem;
    line-height: 1.7;
    color: #B8C8D4;
  }
  .cases-notice strong { color: #fff; font-weight: 700; }
  .cases-notice a {
    color: #7AAFC4;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .cases-notice a:hover { color: #B8D4E0; }

  /* ── FEATURES SECTION ── */
  .features-section {
    position: relative;
    z-index: 1;
    padding-block: clamp(4rem, 8vw, 7rem);
    background: #080A0E;
    border-top: 1px solid rgba(122,175,196,0.10);
    border-bottom: 1px solid rgba(122,175,196,0.10);
  }
  .features-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.25rem;
    margin-bottom: clamp(3rem, 5vw, 4.5rem);
  }
  .features-title {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 900;
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: #fff;
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 640px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .feature-card {
    position: relative;
    border-radius: 1.5rem;
    padding: 2.5rem;
    overflow: hidden;
    isolation: isolate;
    border: 1px solid rgba(122,175,196,0.13);
    transition: border-color 0.35s cubic-bezier(0.22, 1, 0.36, 1),
                box-shadow 0.35s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
