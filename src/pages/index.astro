---
import Base from '../layouts/Base.astro';
import WrenchBackground from '../components/modules/WrenchBackground.astro';
import NavIsland from '../components/modules/NavIsland.astro';
import HeroDTS from '../components/modules/HeroDTS.astro';
import AboutSnippet from '../components/modules/AboutSnippet.astro';
import Services from '../components/modules/Services.astro';
import CoreValues from '../components/modules/CoreValues.astro';
import FooterDTS from '../components/modules/FooterDTS.astro';

const servicesSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Diensten Dutch Torque Service",
  "inLanguage": "nl-NL",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Momentsleutel Kalibratie",
      "description": "Professionele kalibratie op 5 meetpunten conform ISO 6789:2017 en 2003",
      "url": "https://www.dutchtorqueservice.nl/diensten/momentsleutel-kalibratie"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Momentsleutel reparatie",
      "description": "Volledig herstel van momentsleutels, van Snap-On tot Stahlwille",
      "url": "https://www.dutchtorqueservice.nl/diensten/momentsleutel-reparatie"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Momentsleutel Justeren",
      "description": "Herinstelling op juiste Newton-meterwaarden na slijtage of val",
      "url": "https://www.dutchtorqueservice.nl/diensten/momentsleutel-justeren"
    },
    {
      "@type": "ListItem",
      "position": 4,
      "name": "ISO 6789:2017 en 2003 Certificering",
      "description": "Officieel kalibratiecertificaat, audit-proof voor gecertificeerde bedrijven",
      "url": "https://www.dutchtorqueservice.nl/diensten/iso-6789-certificering"
    }
  ]
};
---

<Base
  title="Momentsleutel Kalibratie ISO 6789:2017 en 2003 | Dutch Torque Service"
  description="Momentsleutel kalibratie en ISO 6789:2017 en 2003 certificering. ±2% servicegarantie binnen ±4% ISO-tolerantie. Geautoriseerd Snap-On dealer voor NL, BE en DE."
  canonicalPath="/"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(servicesSchema)} />

  <!-- Fixed background layer: wrench stays put while page scrolls -->
  <WrenchBackground />

  <NavIsland currentPage="home" />

  <main>
    <HeroDTS />
    <AboutSnippet />
    <Services />
    <CoreValues />
  </main>

  <FooterDTS />

</Base>
