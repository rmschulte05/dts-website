---
import Base from '../../layouts/Base.astro';
import NavIsland from '../../components/modules/NavIsland.astro';
import FooterDTS from '../../components/modules/FooterDTS.astro';
import PageSection from '../../components/ui/PageSection.astro';
import ChatExplainer from '../../components/modules/ChatExplainer.astro';

const accent = '#7AAFC4';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "ISO 6789 Certificaat Momentsleutel",
    "provider": { "@id": "https://www.dutchtorqueservice.nl/#business" },
    "description": "Officieel ISO 6789:2017 kalibratiecertificaat voor momentsleutels. Audit-proof, volledig traceerbaar. Voor ISO 9001, IATF 16949 en VCA gecertificeerde bedrijven.",
    "areaServed": "NL",
    "url": "https://www.dutchtorqueservice.nl/diensten/iso-6789-certificering"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Is mijn kalibratiecertificaat geldig voor een ISO 9001 audit?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja. Ons certificaat voldoet aan de documentatie-eisen van ISO 9001 voor meetmiddelbeheer, met traceerbare referentieapparatuur en volledige meetwaardenregistratie."
        }
      },
      {
        "@type": "Question",
        "name": "Hoe lang is een certificaat geldig?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "ISO 6789:2017 schrijft geen vaste geldigheidsduur voor — dat bepaalt jouw eigen kwaliteitshandboek. De aanbevolen minimumfrequentie is jaarlijks. Na een incident (val, overbelasting) is directe herkeuring nodig."
        }
      },
      {
        "@type": "Question",
        "name": "Kalibreren jullie ook voor IATF 16949 gecertificeerde bedrijven?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja. Onze werkwijze en documentatie zijn geschikt voor IATF 16949-eisen aan meetmiddelbeheer."
        }
      },
      {
        "@type": "Question",
        "name": "Wat als mijn sleutel buiten tolerantie valt bij de as-found meting?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Als de sleutel buiten tolerantie zit, kun je hem ook laten justeren — dan voeren wij de as-left meting daarna uit. Beide waarden staan op het certificaat. Je betaalt een eerlijke prijs — altijd vooraf gecommuniceerd."
        }
      }
    ]
  }
];

const certChecklist = [
  { item: 'Instrumentgegevens: merk, type, serienummer, bereik' },
  { item: 'As-found meetwaarden op minimaal 5 meetpunten (voor de ingreep)' },
  { item: 'As-left meetwaarden na kalibratie/justering' },
  { item: 'Toegestane tolerantie conform ISO 6789:2017' },
  { item: 'Gebruikte referentieapparatuur met eigen kalibratiestatus' },
  { item: 'Naam en kwalificatie van de uitvoerende technicus' },
  { item: 'Datum van kalibratie' },
  { item: 'Aanbevolen volgend kalibratieinterval' },
];

const typeTable = [
  { label: 'Voorbeelden', typeI: 'Balksleutel, digitale meter', typeII: 'Kliksleutel, voorinstelbare sleutel' },
  { label: 'Meetpunten', typeI: 'Min. 5 over het bereik', typeII: 'Min. 5 bij het ingestelde punt' },
  { label: 'Herhalingen', typeI: 'Min. 3 per punt', typeII: 'Min. 5 per punt' },
  { label: 'Tolerantie', typeI: '±4%', typeII: '±4%' },
];

const whyCards = [
  {
    accent: '#7AAFC4',
    icon: '◎',
    title: 'Traceerbare referentieapparatuur',
    body: 'Onze referentieapparatuur heeft altijd een actuele kalibratiestatus. Die staat gewoon op jouw certificaat — volledig herleidbaar naar nationaal referentiemateriaal.',
  },
  {
    accent: '#C4AF64',
    icon: '✦',
    title: 'Audit-proof documentatie',
    body: 'Klaar voor ISO 9001, IATF 16949, VCA audits. Volledige meetwaardenregistratie conform normeisen.',
  },
  {
    accent: '#64C48A',
    icon: '48u',
    title: 'Binnen 48 uur',
    body: 'Certificaat per e-mail na afronding. Standaard doorlooptijd: 48 uur na ontvangst van jouw sleutel.',
  },
];

const faq = [
  {
    q: 'Is mijn kalibratiecertificaat geldig voor een ISO 9001 audit?',
    a: 'Ja. Ons certificaat voldoet aan de documentatie-eisen van ISO 9001 voor meetmiddelbeheer, met traceerbare referentieapparatuur en volledige meetwaardenregistratie.',
  },
  {
    q: 'Hoe lang is een certificaat geldig?',
    a: 'ISO 6789:2017 schrijft geen vaste geldigheidsduur voor — dat bepaalt jouw eigen kwaliteitshandboek. De aanbevolen minimumfrequentie is jaarlijks. Na een incident (val, overbelasting) is directe herkeuring nodig.',
  },
  {
    q: 'Kalibreren jullie ook voor IATF 16949 gecertificeerde bedrijven?',
    a: 'Ja. Onze werkwijze en documentatie zijn geschikt voor IATF 16949-eisen aan meetmiddelbeheer.',
  },
  {
    q: 'Wat als mijn sleutel buiten tolerantie valt bij de as-found meting?',
    a: 'Als de sleutel buiten tolerantie zit, kun je hem ook <a href="/diensten/momentsleutel-justeren">laten justeren</a> — dan voeren wij de as-left meting daarna uit. Beide waarden staan op het certificaat. Je betaalt een eerlijke prijs — altijd vooraf gecommuniceerd.',
  },
];
---

<Base
  title="ISO 6789 Certificaat Momentsleutel | Dutch Torque Service"
  description="Officieel ISO 6789:2017 kalibratiecertificaat voor momentsleutels. Audit-proof, volledig traceerbaar. Voor ISO 9001, IATF 16949 en VCA. Stuur op →"
  canonicalPath="/diensten/iso-6789-certificering"
>
  {schema.map(s => (
    <script slot="head" type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}

  <NavIsland currentPage="diensten" />

  <main>

    <!-- ══════════════════════════════════════
         HERO
    ══════════════════════════════════════ -->
    <PageSection class="hero-section">
        <div class="hero-inner">
          <!-- Eyebrow -->
          <div class="eyebrow-row" data-animate>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Certificering</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>

          <h1 class="hero-h1" data-animate data-animate-delay="0.08">
            ISO 6789 Certificaat.
          </h1>

          <p class="hero-subtitle" data-animate data-animate-delay="0.16">
            Officieel ISO 6789:2017 kalibratiecertificaat, volledig traceerbaar. Gewoon audit-proof — binnen 48 uur in je inbox.
          </p>

          <div class="hero-ctas" data-animate data-animate-delay="0.22">
            <a href="/contact" class="btn btn-primary">Plan certificering</a>
            <a href="/diensten/momentsleutel-kalibratie" class="btn btn-outline">Momentsleutel kalibreren laten</a>
          </div>

          <!-- Stats badges -->
          <div class="hero-badges" data-animate data-animate-delay="0.30">
            <span class="badge" style="background:rgba(122,175,196,0.10); border:1px solid rgba(122,175,196,0.28); color:#7AAFC4;">ISO 6789:2017</span>
            <span class="badge" style="background:rgba(122,175,196,0.10); border:1px solid rgba(122,175,196,0.28); color:#7AAFC4;">Volledig Traceerbaar</span>
            <span class="badge" style="background:rgba(122,175,196,0.10); border:1px solid rgba(122,175,196,0.28); color:#7AAFC4;">Audit-Proof</span>
          </div>
        </div>
    </PageSection>

    <!-- WHAT IS X — CHAT UI -->
    <PageSection>
      <ChatExplainer
        question="Heb ik echt een ISO 6789 certificaat nodig?"
        answer="Als je werkt in een gecertificeerde omgeving, met klanten die kwaliteitseisen stellen, of als je gereedschap inzet op kritische verbindingen: ja. Het certificaat bewijst traceerbaarheid en nauwkeurigheid (±2% koppelmoment), audit-proof. Twijfel? Laat je <a href='/diensten/momentsleutel-kalibratie'>momentsleutel kalibreren</a>."
        accent="#64C48A"
        reactions={[
          { emoji: '📜', count: 22 },
          { emoji: '✅', count: 31 },
          { emoji: '🏆', count: 14 },
        ]}
      />
    </PageSection>

    <!-- ══════════════════════════════════════
         WHO NEEDS A CERTIFICATE?
    ══════════════════════════════════════ -->
    <PageSection class="[background:rgba(14,17,24,0.5)]">
        <div class="section-header" data-animate>
          <div class="eyebrow-row">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Doelgroep</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="section-h2">Wie heeft een ISO 6789 certificaat nodig?</h2>
        </div>

        <div class="def-card" data-animate data-animate-delay="0.08">
          <p class="body-text" style="margin-bottom:1.25rem;">
            Werk je voor een gecertificeerd bedrijf, of lever je aan klanten met kwaliteitseisen? Dan heb je dit nodig.
          </p>
          <ul class="needs-list">
            <li>Bedrijven gecertificeerd conform <strong style="color:#C8D8E0;">ISO 9001</strong> (kwaliteitsmanagement)</li>
            <li>Bedrijven gecertificeerd conform <strong style="color:#C8D8E0;">IATF 16949</strong> (automotive kwaliteitsmanagement)</li>
            <li>Bedrijven met <strong style="color:#C8D8E0;">VCA- of VCA**</strong>-certificering</li>
            <li>Overheidscontracten of aanbestedingen — de opdrachtgever vraagt gewoon om papier.</li>
            <li>Bedrijven die garantieclaims willen voorkomen bij kritische verbindingen</li>
            <li>Elke werkplaats die niet aansprakelijk wil zijn als een wielmoer loslaat — want dat is wat er op het spel staat.</li>
          </ul>
        </div>
    </PageSection>

    <!-- ══════════════════════════════════════
         WHAT'S IN A DTS CERTIFICATE?
    ══════════════════════════════════════ -->
    <PageSection>
        <div class="section-header" data-animate>
          <div class="eyebrow-row">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Inhoud certificaat</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="section-h2">Wat staat er in een DTS-certificaat?</h2>
        </div>

        <div class="def-card" data-animate data-animate-delay="0.08">
          <p class="body-text" style="margin-bottom:1.25rem;">Dit staat er in elk DTS-certificaat — geen vage samenvattingen, gewoon alle meetwaarden.</p>
          <ul class="cert-checklist">
            {certChecklist.map(row => (
              <li>
                <span class="cert-check" style={`color:${accent};`}>✓</span>
                {row.item}
              </li>
            ))}
          </ul>
        </div>
    </PageSection>

    <!-- ══════════════════════════════════════
         TYPE I VS TYPE II TABLE
    ══════════════════════════════════════ -->
    <PageSection class="[background:rgba(14,17,24,0.5)]">
        <div class="section-header" data-animate>
          <div class="eyebrow-row">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Instrumenttypen</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="section-h2">Type I en Type II — welke norm geldt?</h2>
        </div>

        <p class="body-text" style="margin-bottom:2rem;" data-animate data-animate-delay="0.04">
          De ISO 6789:2017 norm heeft voor elk type sleutel zijn eigen eisen — meetpunten, herhalingen, tolerantie. Toch even checken welke op jouw sleutel van toepassing is.
        </p>

        <div class="table-wrap" data-animate data-animate-delay="0.08">
          <table class="incl-table type-table">
            <thead>
              <tr>
                <th></th>
                <th>Type I (Indicerend)</th>
                <th>Type II (Instellend)</th>
              </tr>
            </thead>
            <tbody>
              {typeTable.map(row => (
                <tr>
                  <td class="row-label">{row.label}</td>
                  <td>{row.typeI}</td>
                  <td>{row.typeII}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <p class="body-text" style="margin-top:1.5rem;" data-animate data-animate-delay="0.12">
          Meer over het verschil: <a href="/blog/iso-6789-type-1-type-2-uitgelegd" style="color:#7AAFC4; text-decoration:underline;">ISO 6789 Type I en Type II uitgelegd →</a>
        </p>
    </PageSection>

    <!-- ══════════════════════════════════════
         WHY DTS
    ══════════════════════════════════════ -->
    <PageSection>
        <div class="section-header" data-animate>
          <div class="eyebrow-row">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Waarom DTS?</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="section-h2">Waarom klanten hun sleutel naar DTS sturen.</h2>
        </div>

        <div class="why-grid">
          {whyCards.map((card, i) => (
            <div class="why-card" data-animate data-animate-delay={String(i * 0.10)} style={`border-color:rgba(${card.accent === '#7AAFC4' ? '122,175,196' : card.accent === '#C4AF64' ? '196,175,100' : '100,196,138'},0.14);`}>
              <div class="why-icon" style={`color:${card.accent};`}>{card.icon}</div>
              <h3 class="why-title" style={`color:${card.accent};`}>{card.title}</h3>
              <p class="why-body">{card.body}</p>
            </div>
          ))}
        </div>
    </PageSection>

    <!-- ══════════════════════════════════════
         FAQ
    ══════════════════════════════════════ -->
    <PageSection class="[background:rgba(14,17,24,0.5)]">
        <div class="section-header" data-animate>
          <div class="eyebrow-row">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">FAQ</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="section-h2">Veelgestelde vragen over ISO 6789:2017 certificering.</h2>
        </div>

        <div class="faq-list" data-animate data-animate-delay="0.08">
          {faq.map(item => (
            <details>
              <summary>{item.q}</summary>
              <div class="faq-body" set:html={item.a}></div>
            </details>
          ))}
        </div>
    </PageSection>

    <!-- ══════════════════════════════════════
         CTA
    ══════════════════════════════════════ -->
    <PageSection class="cta-section">
        <div class="cta-inner" data-animate>
          <div class="eyebrow-row">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Direct starten</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="section-h2">Klaar voor jouw audit?</h2>
          <p class="body-text cta-body">
            Bel ons of stuur jouw sleutel landelijk op. Ons lab in Riethoven, Noord-Brabant bezorgt binnen 48 uur een geldig ISO 6789:2017 certificaat in je inbox.
          </p>
          <div class="cta-btns">
            <a href="tel:+31613172774" class="btn btn-primary">Bel +31(0)6-131 72 774</a>
            <a href="mailto:info@dutchtorqueservice.nl" class="btn btn-outline">Stuur een e-mail</a>
          </div>
        </div>
    </PageSection>

  </main>

  <FooterDTS />

</Base>

<style>
  /* ── Hero ── */
  .hero-section {
    padding-top: clamp(7rem, 14vw, 11rem);
  }
  .hero-inner {
    max-width: 780px;
  }
  .eyebrow-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .hero-h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: #fff;
    margin-bottom: 1.25rem;
  }
  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.7;
    color: #8EAAB8;
    margin-bottom: 2rem;
    max-width: 60ch;
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    margin-bottom: 2.5rem;
  }
  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }

  /* ── Section common ── */
  .section-header {
    margin-bottom: 3rem;
  }
  .section-h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: #E8F0F4;
    margin-top: 0.75rem;
  }
  .body-text {
    font-size: 0.975rem;
    line-height: 1.8;
    color: #8EAAB8;
  }

  /* ── Cards ── */
  .def-card {
    background: #0E1118;
    border: 1px solid rgba(122,175,196,0.14);
    border-radius: 1.5rem;
    padding: clamp(1.5rem, 3vw, 2.5rem);
    max-width: 820px;
  }

  /* ── Who needs list ── */
  .needs-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .needs-list li {
    font-size: 0.925rem;
    line-height: 1.7;
    color: #8EAAB8;
    padding-left: 1.5rem;
    position: relative;
  }
  .needs-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: #7AAFC4;
    font-weight: 600;
  }

  /* ── Cert checklist ── */
  .cert-checklist {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }
  .cert-checklist li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.925rem;
    line-height: 1.7;
    color: #C8D8E0;
  }
  .cert-check {
    font-weight: 700;
    font-size: 1rem;
    flex-shrink: 0;
    margin-top: 0.1em;
  }

  /* ── Table ── */
  .table-wrap {
    overflow-x: auto;
  }
  .incl-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }
  .incl-table thead th {
    text-align: left;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    padding: 0 1rem 1rem 1rem;
    border-bottom: 1px solid rgba(122,175,196,0.12);
  }
  .incl-table tbody tr {
    border-bottom: 1px solid rgba(122,175,196,0.07);
    transition: background 0.15s;
  }
  .incl-table tbody tr:hover {
    background: rgba(122,175,196,0.04);
  }
  .incl-table tbody td {
    padding: 1rem;
    color: #C8D8E0;
    font-weight: 500;
    vertical-align: middle;
  }
  .type-table .row-label {
    color: rgba(255,255,255,0.45);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  /* ── Why DTS ── */
  .why-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
  }
  .why-card {
    background: #0E1118;
    border: 1px solid rgba(122,175,196,0.14);
    border-radius: 1.5rem;
    padding: 2rem;
    transition: border-color 0.2s;
  }
  .why-card:hover {
    border-color: rgba(122,175,196,0.30);
  }
  .why-icon {
    font-size: 1.5rem;
    font-weight: 900;
    margin-bottom: 1rem;
  }
  .why-title {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.625rem;
  }
  .why-body {
    font-size: 0.875rem;
    line-height: 1.75;
    color: #8EAAB8;
  }

  /* ── FAQ ── */
  .faq-list {
    max-width: 820px;
  }
  details {
    border: 1px solid rgba(122,175,196,0.12);
    border-radius: 1rem;
    background: #0E1118;
    margin-bottom: 0.75rem;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  details[open] {
    border-color: rgba(122,175,196,0.30);
  }
  summary {
    padding: 1.25rem 1.5rem;
    cursor: pointer;
    font-weight: 700;
    color: #E8F0F4;
    font-size: 0.975rem;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }
  summary::-webkit-details-marker { display: none; }
  summary::after {
    content: '+';
    color: #7AAFC4;
    font-size: 1.25rem;
    font-weight: 300;
    flex-shrink: 0;
    transition: transform 0.25s;
  }
  details[open] summary::after { transform: rotate(45deg); }
  .faq-body {
    padding: 0 1.5rem 1.5rem;
    font-size: 0.9rem;
    line-height: 1.8;
    color: #8EAAB8;
  }
  .faq-body a { color: #7AAFC4; text-decoration: underline; }

  /* ── CTA ── */
  .cta-section {
    border-top: 1px solid rgba(122,175,196,0.08);
