---
import Base from '../../layouts/Base.astro';
import NavIsland from '../../components/modules/NavIsland.astro';
import FooterDTS from '../../components/modules/FooterDTS.astro';
import PageSection from '../../components/ui/PageSection.astro';
import ChatExplainer from '../../components/modules/ChatExplainer.astro';

const accent = '#7AAFC4';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Momentsleutel Justeren",
  "provider": { "@id": "https://www.dutchtorqueservice.nl/#business" },
  "description": "Professioneel momentsleutel justeren op de juiste Newton-meterwaarden conform ISO 6789:2017. Gecertificeerd.",
  "areaServed": "NL",
  "url": "https://www.dutchtorqueservice.nl/diensten/momentsleutel-justeren"
};

const steps = [
  {
    n: '01',
    title: 'Inspectie',
    body: 'Visuele en mechanische inspectie van de sleutel. Wij brengen schade, slijtage en interne beschadigingen in kaart.',
  },
  {
    n: '02',
    title: 'Justering',
    body: 'Wij stellen de sleutel opnieuw in op de juiste Newton-meterwaarden — conform de fabrieksspecificatie. Is er meer aan de hand? Dan adviseren wij <a href="/diensten/momentsleutel-reparatie">momentsleutel reparatie</a> voordat we verder gaan.',
  },
  {
    n: '03',
    title: 'Kalibratie & certificaat',
    body: 'Meting na justering op 5 meetpunten conform ISO 6789:2017. Volledig protocol met as-left waarden en geldig certificaat.',
  },
];

const adviesTable = [
  { situatie: 'Kleine afwijking (< 6%), geen mechanische schade', aanpak: 'Justeren + <a href="/diensten/momentsleutel-kalibratie">hercalibratie</a>' },
  { situatie: 'Grote afwijking of click voelt anders', aanpak: '<a href="/diensten/momentsleutel-reparatie">Reparatie</a> + justering + kalibratie' },
  { situatie: 'Sleutel is gevallen zonder zichtbare schade', aanpak: 'Justeren + <a href="/diensten/momentsleutel-kalibratie">kalibreren</a> (interne schade mogelijk)' },
];

const faq = [
  {
    q: 'Is justeren hetzelfde als kalibreren?',
    a: 'Nee. Kalibreren = meten en documenteren. Justeren = corrigeren. Na het justeren meten we altijd opnieuw — zo documenteren we de nieuwe waarden in een <a href="/diensten/momentsleutel-kalibratie">kalibratierapport</a>.',
  },
  {
    q: 'Hoe weet ik of mijn sleutel gejusteerd moet worden?',
    a: 'Als de kalibratie een afwijking buiten de ISO 6789:2017-tolerantie aantoont, is justering nodig. Signalen zijn ook: klik te vroeg/laat, val, of overbelasting. Twijfel je? Stuur je sleutel op — wij kijken er even naar. Is er meer kapot, dan adviseren wij <a href="/diensten/momentsleutel-reparatie">reparatie</a> eerst.',
  },
  {
    q: 'Hoeveel kost justeren?',
    a: 'Afhankelijk van type en merk. Neem contact op voor een prijsindicatie.',
  },
];
---

<Base
  title="Momentsleutel Justeren | Dutch Torque Service — ISO 6789:2017 Gecertificeerd"
  description="Momentsleutel buiten tolerantie? Wij stellen hem opnieuw in op de juiste Nm-waarden. Conform ISO 6789:2017. Bel +31(0)6-131 72 774."
  canonicalPath="/diensten/momentsleutel-justeren"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(schema)} />

  <NavIsland currentPage="diensten" />

  <main>

    <!-- ══════════════════════════════════════
         HERO
    ══════════════════════════════════════ -->
    <PageSection class="hero-section">
        <div class="hero-inner">
          <!-- Eyebrow -->
          <div class="sec-eyebrow" data-animate>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Justeren</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>

          <h1 class="hero-h1" data-animate data-animate-delay="0.08">
            Momentsleutel Justeren.
          </h1>

          <p class="hero-subtitle" data-animate data-animate-delay="0.16">
            Sleutel buiten tolerantie door slijtage of een incident? Wij stellen hem gewoon opnieuw in op de juiste Newton-meterwaarden — conform ISO 6789:2017.
          </p>

          <div class="hero-ctas" data-animate data-animate-delay="0.22">
            <a href="/contact" class="btn btn-primary">Plan justering</a>
            <a href="/diensten/momentsleutel-kalibratie" class="btn btn-outline">Hoe kalibratie werkt</a>
          </div>

          <!-- Stats badges -->
          <div class="hero-badges" data-animate data-animate-delay="0.30">
            <span class="badge" style="background:rgba(122,175,196,0.10); border:1px solid rgba(122,175,196,0.28); color:#7AAFC4;">±2% Nauwkeurig</span>
            <span class="badge" style="background:rgba(122,175,196,0.10); border:1px solid rgba(122,175,196,0.28); color:#7AAFC4;">Snelle Doorlooptijd</span>
            <span class="badge" style="background:rgba(122,175,196,0.10); border:1px solid rgba(122,175,196,0.28); color:#7AAFC4;">ISO 6789:2017</span>
          </div>
        </div>
    </PageSection>

    <!-- WHAT IS X — CHAT UI -->
    <PageSection>
      <ChatExplainer
        question="Wanneer moet ik mijn sleutel laten justeren?"
        answer='Als de gemeten waarden buiten de toegestane tolerantie vallen. Dit kan na intensief gebruik, een val of gewoon door veroudering. Na justering <a href="/diensten/momentsleutel-kalibratie">kalibreren we opnieuw</a> en ontvang je een nieuw <a href="/diensten/iso-6789-certificering">ISO 6789:2017 certificaat</a>.'
        accent="#C4AF64"
        reactions={[
          { emoji: '🎯', count: 13 },
          { emoji: '✅', count: 17 },
          { emoji: '👍', count: 8 },
        ]}
      />
    </PageSection>

    <!-- ══════════════════════════════════════
         WHEN DO YOU NEED IT?
    ══════════════════════════════════════ -->
    <PageSection class="[background:rgba(14,17,24,0.5)]">
        <div class="sec-head" data-animate>
          <div class="sec-eyebrow">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Wanneer nodig?</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="sec-title">Wanneer is justeren nodig?</h2>
        </div>

        <div class="def-card" data-animate data-animate-delay="0.08">
          <p class="body-text" style="margin-bottom:1.25rem;">
            Dit zijn de situaties waarbij je sleutel gejusteerd moet worden:
          </p>
          <ul class="needs-list">
            <li>Na een <strong style="color:#C8D8E0;">val</strong> — ook zonder zichtbare schade kan de interne mechaniek verschoven zijn</li>
            <li>Na <strong style="color:#C8D8E0;">overbelasting</strong> — het aanzetten boven de maximale torquewaarde</li>
            <li>Als kalibratie een <strong style="color:#C8D8E0;">afwijking buiten ISO-tolerantie</strong> aantoont</li>
            <li>Als de klik <strong style="color:#C8D8E0;">te vroeg of te laat</strong> voelt bij gebruik</li>
            <li>Als je sleutel lang heeft gestaan of ook zwaar gebruikt is zonder onderhoud</li>
          </ul>
        </div>
    </PageSection>

    <!-- ══════════════════════════════════════
         PROCESS
    ══════════════════════════════════════ -->
    <PageSection>
        <div class="sec-head" data-animate>
          <div class="sec-eyebrow">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Ons proces</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="sec-title">In 3 stappen je sleutel afstellen op norm.</h2>
        </div>

        <div class="steps-grid">
          {steps.map((step, i) => (
            <div class="step-card" data-animate data-animate-delay={String(i * 0.08)}>
              <div class="step-number" style={`color:${accent};`}>{step.n}</div>
              <h3 class="step-title">{step.title}</h3>
              <p class="step-body" set:html={step.body} />
            </div>
          ))}
        </div>
    </PageSection>

    <!-- ══════════════════════════════════════
         JUSTEREN OR REPAREREN TABLE
    ══════════════════════════════════════ -->
    <PageSection class="[background:rgba(14,17,24,0.5)]">
        <div class="sec-head" data-animate>
          <div class="sec-eyebrow">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Advies</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="sec-title">Alleen justeren of ook repareren?</h2>
        </div>

        <div class="table-wrap" data-animate data-animate-delay="0.08">
          <table class="incl-table">
            <thead>
              <tr>
                <th>Situatie</th>
                <th>Aanpak</th>
              </tr>
            </thead>
            <tbody>
              {adviesTable.map(row => (
                <tr>
                  <td>{row.situatie}</td>
                  <td class="incl-detail" set:html={row.aanpak} />
                </tr>
              ))}
            </tbody>
          </table>
        </div>
    </PageSection>

    <!-- ══════════════════════════════════════
         FAQ
    ══════════════════════════════════════ -->
    <PageSection>
        <div class="sec-head" data-animate>
          <div class="sec-eyebrow">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">FAQ</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="sec-title">Veelgestelde vragen over het justeren.</h2>
        </div>

        <div class="faq-list" data-animate data-animate-delay="0.08">
          {faq.map(item => (
            <details>
              <summary>{item.q}</summary>
              <div class="faq-body" set:html={item.a} />
            </details>
          ))}
        </div>
    </PageSection>

    <!-- ══════════════════════════════════════
         CTA
    ══════════════════════════════════════ -->
    <PageSection>
        <div class="sec-head sec-head--flush" data-animate>
          <div class="sec-eyebrow">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Direct starten</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="sec-title">Gewoon opsturen — wij regelen de rest.</h2>
          <p class="sec-sub">
            Stuur ons jouw sleutel op of bel direct. Justering inclusief een geldig <a href="/diensten/iso-6789-certificering">ISO 6789:2017 certificaat</a>. Gevestigd in Riethoven (Noord-Brabant), maar wij ontvangen sleutels vanuit heel Nederland.
          </p>
          <div class="sec-ctas">
            <a href="tel:+31613172774" class="btn btn-primary">Bel +31(0)6-131 72 774</a>
            <a href="mailto:info@dutchtorqueservice.nl" class="btn btn-outline">Mail ons een vraag</a>
          </div>
        </div>
    </PageSection>

  </main>

  <FooterDTS />

</Base>

<style>
  /* ── Hero ── */
  .hero-section {
    padding-top: clamp(7rem, 14vw, 11rem);
  }
  .hero-inner {
    max-width: 780px;
    margin-inline: auto;
    text-align: center;
  }
  .hero-h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: #fff;
    margin-bottom: 1.75rem;
  }
  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.7;
    color: #8EAAB8;
    margin-bottom: 2.5rem;
    max-width: 60ch;
    margin-inline: auto;
    text-align: center;
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    margin-bottom: 3rem;
    justify-content: center;
  }
  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    justify-content: center;
  }
  .body-text {
    font-size: 0.975rem;
    line-height: 1.8;
    color: #8EAAB8;
  }

  /* ── Cards ── */
  .def-card {
    background: #0E1118;
    border: 1px solid rgba(122,175,196,0.14);
    border-radius: 1.5rem;
    padding: clamp(1.5rem, 3vw, 2.5rem);
    max-width: 820px;
  }

  /* ── Needs list ── */
  .needs-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .needs-list li {
    font-size: 0.925rem;
    line-height: 1.7;
    color: #8EAAB8;
    padding-left: 1.5rem;
    position: relative;
  }
  .needs-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: #7AAFC4;
    font-weight: 600;
  }

  /* ── Steps ── */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.25rem;
  }
  .step-card {
    background: #0E1118;
    border: 1px solid rgba(122,175,196,0.14);
    border-radius: 1.5rem;
    padding: 1.75rem;
  }
  .step-number {
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  .step-title {
    font-size: 1rem;
    font-weight: 700;
    color: #E8F0F4;
    margin-bottom: 0.625rem;
  }
  .step-body {
    font-size: 0.875rem;
    line-height: 1.75;
    color: #8EAAB8;
  }
  .step-body a { color: #7AAFC4; text-decoration: underline; }

  /* ── Table ── */
  .table-wrap {
    overflow-x: auto;
  }
  .incl-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }
  .incl-table thead th {
    text-align: left;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    padding: 0 1rem 1rem 1rem;
    border-bottom: 1px solid rgba(122,175,196,0.12);
  }
  .incl-table tbody tr {
    border-bottom: 1px solid rgba(122,175,196,0.07);
    transition: background 0.15s;
  }
  .incl-table tbody tr:hover {
    background: rgba(122,175,196,0.04);
  }
  .incl-table tbody td {
    padding: 1rem;
    color: #C8D8E0;
    font-weight: 500;
    vertical-align: middle;
  }
  .incl-detail {
    color: #6A8A98 !important;
    font-weight: 400 !important;
    font-size: 0.85rem;
  }
  .incl-detail a { color: #7AAFC4; text-decoration: underline; }

  /* ── FAQ ── */
  .faq-list {
    max-width: 820px;
    margin-inline: auto;
  }
  details {
    border: 1px solid rgba(122,175,196,0.12);
    border-radius: 1rem;
    background: #0E1118;
    margin-bottom: 0.75rem;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  details[open] {
    border-color: rgba(122,175,196,0.30);
  }
  summary {
    padding: 1.25rem 1.5rem;
    cursor: pointer;
    font-weight: 700;
    color: #E8F0F4;
    font-size: 0.975rem;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }
  summary::-webkit-details-marker { display: none; }
  summary::after {
    content: '+';
    color: #7AAFC4;
    font-size: 1.25rem;
    font-weight: 300;
    flex-shrink: 0;
    transition: transform 0.25s;
  }
  details[open] summary::after { transform: rotate(45deg); }
  .faq-body {
    padding: 0 1.5rem 1.5rem;
    font-size: 0.9rem;
    line-height: 1.8;
    color: #8EAAB8;
  }
  .faq-body a { color: #7AAFC4; text-decoration: underline; }</style>
