---
import Base from '../../layouts/Base.astro';
import NavIsland from '../../components/modules/NavIsland.astro';
import FooterDTS from '../../components/modules/FooterDTS.astro';
import PageSection from '../../components/ui/PageSection.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Diensten Dutch Torque Service",
  "description": "Overzicht van alle momentsleutel diensten van Dutch Torque Service: kalibratie, reparatie, justeren en ISO 6789:2017 certificering.",
  "url": "https://www.dutchtorqueservice.nl/diensten",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "item": {
        "@type": "Service",
        "name": "Momentsleutel Kalibratie",
        "description": "Professionele kalibratie van momentsleutels conform ISO 6789:2017 met ±2% nauwkeurigheidsgarantie en volledig gedocumenteerd certificaat.",
        "url": "https://www.dutchtorqueservice.nl/diensten/momentsleutel-kalibratie",
        "provider": { "@id": "https://www.dutchtorqueservice.nl/#business" },
        "areaServed": [
          { "@type": "Country", "name": "Nederland" },
          { "@type": "AdministrativeArea", "name": "Noord-Brabant" }
        ]
      }
    },
    {
      "@type": "ListItem",
      "position": 2,
      "item": {
        "@type": "Service",
        "name": "Momentsleutel Reparatie",
        "description": "Reparatie van alle merken momentsleutels. Van mechanische slijtage tot interne beschadigingen — wij stellen jouw gereedschap weer volledig in orde.",
        "url": "https://www.dutchtorqueservice.nl/diensten/momentsleutel-reparatie",
        "provider": { "@id": "https://www.dutchtorqueservice.nl/#business" },
        "areaServed": [
          { "@type": "Country", "name": "Nederland" },
          { "@type": "AdministrativeArea", "name": "Noord-Brabant" }
        ]
      }
    },
    {
      "@type": "ListItem",
      "position": 3,
      "item": {
        "@type": "Service",
        "name": "Momentsleutel Justeren",
        "description": "Nauwkeurig bijstellen van momentsleutels die buiten tolerantie zijn geraakt, inclusief her-kalibratie en certificering na de ingreep.",
        "url": "https://www.dutchtorqueservice.nl/diensten/momentsleutel-justeren",
        "provider": { "@id": "https://www.dutchtorqueservice.nl/#business" },
        "areaServed": [
          { "@type": "Country", "name": "Nederland" },
          { "@type": "AdministrativeArea", "name": "Noord-Brabant" }
        ]
      }
    },
    {
      "@type": "ListItem",
      "position": 4,
      "item": {
        "@type": "Service",
        "name": "ISO 6789:2017 Certificering",
        "description": "Officiële ISO 6789:2017 certificering van momentsleutels voor kwaliteitssystemen, audits en inspecties. Volledig traceerbaar en audit-proof.",
        "url": "https://www.dutchtorqueservice.nl/diensten/iso-6789-certificering",
        "provider": { "@id": "https://www.dutchtorqueservice.nl/#business" },
        "areaServed": [
          { "@type": "Country", "name": "Nederland" },
          { "@type": "AdministrativeArea", "name": "Noord-Brabant" }
        ]
      }
    }
  ]
};

const services = [
  {
    href: '/diensten/momentsleutel-kalibratie',
    label: 'Kalibratie',
    cta: 'Hoe kalibratie werkt',
    accent: '#7AAFC4',
    eyebrow: 'ISO 6789:2017',
    title: 'Momentsleutel Kalibratie',
    desc: 'Wij meten en documenteren de werkelijke waarden van jouw momentsleutel met ±2% nauwkeurigheid. Binnen 48 uur klaar, inclusief volledig traceerbaar certificaat.',
    icon: `<svg width="32" height="32" viewBox="0 0 80 80" fill="none"><circle cx="20" cy="40" r="14" stroke="currentColor" stroke-width="1.5"/><circle cx="20" cy="40" r="7" stroke="currentColor" stroke-width="1"/><rect x="34" y="34" width="32" height="12" rx="3" stroke="currentColor" stroke-width="1.5"/><rect x="66" y="31" width="10" height="18" rx="4" stroke="currentColor" stroke-width="1.5"/></svg>`,
  },
  {
    href: '/diensten/momentsleutel-reparatie',
    label: 'Reparatie',
    cta: 'Reparatie bekijken',
    accent: '#C48A64',
    eyebrow: 'Alle merken',
    title: 'Momentsleutel Reparatie',
    desc: 'Van mechanische slijtage tot interne beschadigingen — wij repareren momentsleutels van alle merken. Diagnose altijd gratis, reparatie pas na jouw akkoord. Na reparatie altijd opnieuw gecertificeerd.',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    href: '/diensten/momentsleutel-justeren',
    label: 'Justeren',
    cta: 'Hoe justeren werkt',
    accent: '#C4AF64',
    eyebrow: 'Nauwkeurig bijstellen',
    title: 'Momentsleutel Justeren',
    desc: 'Is jouw momentsleutel buiten tolerantie geraakt? Wij stellen hem nauwkeurig bij tot binnen ±2% van de opgegeven waarde. Inclusief her-kalibratie en nieuw certificaat.',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/><path d="M19.07 4.93a10 10 0 010 14.14M4.93 4.93a10 10 0 000 14.14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
  {
    href: '/diensten/iso-6789-certificering',
    label: 'Certificering',
    cta: 'Certificaat bekijken',
    accent: '#64C48A',
    eyebrow: 'Audit-proof',
    title: 'ISO 6789:2017 Certificering',
    desc: 'Officiële certificering conform ISO 6789:2017 voor kwaliteitssystemen, audits en inspecties. Volledig gedocumenteerd met meetwaarden voor en na — transparant en traceerbaar.',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none"><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>`,
  },
];
---

<Base
  title="Momentsleutel Diensten | Dutch Torque Service"
  description="Momentsleutel kalibreren, repareren of certificeren? Dutch Torque Service: ±2% nauwkeurig, klaar binnen 48 uur. ISO 6789:2017 conform, Noord-Brabant. Stuur op."
  canonicalPath="/diensten"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <NavIsland currentPage="diensten" />

  <main>
    <!-- HERO -->
    <PageSection hero center animate>
        <div class="flex items-center justify-center gap-3 mb-6">
          <span class="w-8 h-px opacity-75" style="background:#7AAFC4;"></span>
          <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Diensten</span>
          <span class="w-8 h-px opacity-75" style="background:#7AAFC4;"></span>
        </div>
        <h1 class="font-black tracking-tight text-white mb-5" style="font-size: clamp(2.5rem, 6vw, 4.5rem); line-height: 1.05;">
          Momentsleutel Diensten.
        </h1>
        <p class="mx-auto" style="font-size: clamp(1rem, 1.6vw, 1.15rem); line-height: 1.75; color: #9AAEB8; max-width: 56ch;">
          Alles voor jouw momentsleutel — van kalibratie en certificering tot volledige reparatie. Klaar binnen 48 uur, gecertificeerd conform ISO 6789:2017.
        </p>
    </PageSection>

    <!-- SERVICE CARDS 2x2 GRID -->
    <PageSection>
        <!-- Section intro — centred above grid -->
        <div class="text-center mb-10" data-animate>
          <div class="flex items-center justify-center gap-3 mb-4">
            <span class="w-8 h-px opacity-60" style="background:#7AAFC4;"></span>
            <span class="text-[10px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Kies jouw dienst</span>
            <span class="w-8 h-px opacity-60" style="background:#7AAFC4;"></span>
          </div>
          <p class="mx-auto" style="color:#9AAEB8; max-width:50ch; font-size:0.95rem; line-height:1.7;">
            Twijfel je welke dienst je eigenlijk nodig hebt? Bel even — we adviseren je gratis en eerlijk.
          </p>
        </div>

        <div class="service-grid">
          {services.map((svc, i) => (
            <a
              href={svc.href}
              class="service-card group relative flex flex-col items-center text-center"
              data-card-pop
              data-card-index={String(i)}
              style={`padding: 2.5rem 2rem; border-radius: 1.5rem; background: linear-gradient(140deg, color-mix(in srgb, ${svc.accent} 7%, transparent) 0%, transparent 55%), #0E1118; border: 1px solid color-mix(in srgb, ${svc.accent} 15%, transparent); box-shadow: 0 2px 16px rgba(0,0,0,0.28); transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s; text-decoration: none;`}
            >
              <!-- Icon -->
              <div class="mb-5 w-16 h-16 rounded-2xl flex items-center justify-center" style={`background: color-mix(in srgb, ${svc.accent} 12%, transparent); border: 1px solid color-mix(in srgb, ${svc.accent} 20%, transparent); color: ${svc.accent};`}>
                <Fragment set:html={svc.icon} />
              </div>

              <!-- Eyebrow -->
              <p class="text-[10px] font-semibold tracking-[0.28em] uppercase mb-2" style={`color: ${svc.accent}; opacity: 0.8;`}>{svc.eyebrow}</p>

              <!-- Title -->
              <h2 class="text-xl font-black text-white mb-3" style="letter-spacing: -0.01em; line-height: 1.2;">{svc.title}</h2>

              <!-- Description -->
              <p class="mb-6 flex-1" style="font-size: 0.875rem; line-height: 1.75; color: #8EAAB8; max-width: 32ch; margin-inline: auto;">{svc.desc}</p>

              <!-- CTA link -->
              <span class="inline-flex items-center gap-2 text-sm font-semibold mt-auto" style={`color: ${svc.accent};`}>
                {svc.cta}
                <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>

              <!-- Corner bracket -->
              <div class="absolute bottom-4 right-4 w-4 h-4" style={`border-right: 1.5px solid ${svc.accent}; border-bottom: 1.5px solid ${svc.accent}; border-radius: 0 0 4px 0; opacity: 0.2;`}></div>
            </a>
          ))}
        </div>
    </PageSection>

    <!-- MERKEN / SNAP-ON -->
    <PageSection center animate>
          <div class="flex items-center justify-center gap-3 mb-5">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Merken</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4;"></span>
          </div>
          <h2 class="text-3xl md:text-4xl font-black tracking-tight text-white mb-4">Geautoriseerd Snap-On Dealer.</h2>
          <p class="mx-auto mb-8" style="color: #9AAEB8; max-width: 52ch; font-size: 1rem; line-height: 1.75;">
            Dutch Torque Service is geautoriseerd Snap-On dealer voor de regio Zuid-Noord-Brabant. Wij kalibreren en repareren Snap-On momentsleutels — met hetzelfde ISO 6789:2017 protocol als al onze andere sleutels.
          </p>
          <a href="/merken/snap-on-kalibratie" class="btn btn-outline">
            Snap-On kalibratie &amp; dealer
            <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
    </PageSection>

    <!-- CTA -->
    <PageSection center animate>
        <h2 class="text-3xl md:text-4xl font-black tracking-tight text-white mb-4">Sleutel moet gecheckt? Stuur hem op.</h2>
        <p class="mb-8 mx-auto" style="color: #9AAEB8; max-width: 44ch; font-size: 1.05rem; line-height: 1.75;">
          Wij werken landelijk — stuur je sleutel gewoon op of kom langs in Riethoven. Eerlijk advies, altijd gratis.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/contact" class="btn btn-primary">
            Neem contact op
            <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="tel:+31613172774" class="btn btn-outline">+31(0)6-131 72 774</a>
        </div>
    </PageSection>
  </main>

  <FooterDTS />
</Base>

<style>
  .service-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  @media (max-width: 640px) {
    .service-grid { grid-template-columns: 1fr; }
  }

  .service-card {
    opacity: 0;
    transform: translateY(48px) scale(0.94);
  }
  .service-card:hover {
    transform: translateY(-3px) scale(1) !important;
    box-shadow: 0 8px 32px rgba(0,0,0,0.45) !important;
  }
</style>

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  document.querySelectorAll<HTMLElement>('[data-card-pop]').forEach((card) => {
    const i = parseInt(card.dataset.cardIndex ?? '0', 10);
    gsap.to(card, {
      opacity: 1,
      y: 0,
      scale: 1,
      duration: 0.65,
      delay: i * 0.12,
      ease: 'back.out(1.1)',
      scrollTrigger: {
        trigger: card,
        start: 'top 88%',
        toggleActions: 'play none none none',
      },
    });
  });
</script>
