---
import Base from '../../layouts/Base.astro';
import NavIsland from '../../components/modules/NavIsland.astro';
import FooterDTS from '../../components/modules/FooterDTS.astro';
import PageSection from '../../components/ui/PageSection.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Diensten Dutch Torque Service",
  "description": "Overzicht van alle momentsleutel diensten van Dutch Torque Service: kalibratie, reparatie, justeren en ISO 6789:2017 en 2003 certificering.",
  "url": "https://www.dutchtorqueservice.nl/diensten",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "item": {
        "@type": "Service",
        "name": "Momentsleutel Kalibratie",
        "description": "Professionele kalibratie van momentsleutels conform ISO 6789:2017 en 2003 met ±2% nauwkeurigheidsgarantie en volledig gedocumenteerd certificaat.",
        "url": "https://www.dutchtorqueservice.nl/diensten/momentsleutel-kalibratie",
        "provider": { "@id": "https://www.dutchtorqueservice.nl/#business" },
        "areaServed": [
          { "@type": "Country", "name": "Netherlands" },
          { "@type": "Country", "name": "Belgium" },
          { "@type": "Country", "name": "Germany" },
          { "@type": "AdministrativeArea", "name": "Noord-Brabant" }
        ],
        "inLanguage": "nl-NL"
      }
    },
    {
      "@type": "ListItem",
      "position": 2,
      "item": {
        "@type": "Service",
        "name": "Momentsleutel reparatie",
        "description": "Reparatie van alle merken momentsleutels. Van mechanische slijtage tot interne beschadigingen, wij stellen jouw gereedschap weer volledig in orde.",
        "url": "https://www.dutchtorqueservice.nl/diensten/momentsleutel-reparatie",
        "provider": { "@id": "https://www.dutchtorqueservice.nl/#business" },
        "areaServed": [
          { "@type": "Country", "name": "Netherlands" },
          { "@type": "Country", "name": "Belgium" },
          { "@type": "Country", "name": "Germany" },
          { "@type": "AdministrativeArea", "name": "Noord-Brabant" }
        ],
        "inLanguage": "nl-NL"
      }
    },
    {
      "@type": "ListItem",
      "position": 3,
      "item": {
        "@type": "Service",
        "name": "Momentsleutel Justeren",
        "description": "Nauwkeurig bijstellen van momentsleutels die buiten tolerantie zijn geraakt, inclusief her-kalibratie en certificering na de ingreep.",
        "url": "https://www.dutchtorqueservice.nl/diensten/momentsleutel-justeren",
        "provider": { "@id": "https://www.dutchtorqueservice.nl/#business" },
        "areaServed": [
          { "@type": "Country", "name": "Netherlands" },
          { "@type": "Country", "name": "Belgium" },
          { "@type": "Country", "name": "Germany" },
          { "@type": "AdministrativeArea", "name": "Noord-Brabant" }
        ],
        "inLanguage": "nl-NL"
      }
    },
    {
      "@type": "ListItem",
      "position": 4,
      "item": {
        "@type": "Service",
        "name": "ISO 6789:2017 en 2003 Certificering",
        "description": "Officiële ISO 6789:2017 en 2003 certificering van momentsleutels voor kwaliteitssystemen, audits en inspecties.",
        "url": "https://www.dutchtorqueservice.nl/diensten/iso-6789-certificering",
        "provider": { "@id": "https://www.dutchtorqueservice.nl/#business" },
        "areaServed": [
          { "@type": "Country", "name": "Netherlands" },
          { "@type": "Country", "name": "Belgium" },
          { "@type": "Country", "name": "Germany" },
          { "@type": "AdministrativeArea", "name": "Noord-Brabant" }
        ],
        "inLanguage": "nl-NL"
      }
    }
  ]
};

const services = [
  {
    href: '/diensten/momentsleutel-kalibratie',
    label: 'Kalibratie',
    cta: 'Hoe kalibratie werkt',
    accent: '#7AAFC4',
    eyebrow: 'ISO 6789:2017 en 2003',
    title: 'Momentsleutel Kalibratie',
    desc: 'Wij meten en documenteren de werkelijke waarden van jouw momentsleutel binnen onze ±2% servicegarantie (ruim binnen de ±4% ISO 6789:2017 en 2003 tolerantie). Inclusief certificaat.',
    icon: `<svg width="32" height="32" viewBox="0 0 80 80" fill="none"><circle cx="20" cy="40" r="14" stroke="currentColor" stroke-width="1.5"/><circle cx="20" cy="40" r="7" stroke="currentColor" stroke-width="1"/><rect x="34" y="34" width="32" height="12" rx="3" stroke="currentColor" stroke-width="1.5"/><rect x="66" y="31" width="10" height="18" rx="4" stroke="currentColor" stroke-width="1.5"/></svg>`,
  },
  {
    href: '/diensten/momentsleutel-reparatie',
    label: 'Reparatie',
    cta: 'Reparatie bekijken',
    accent: '#C48A64',
    eyebrow: 'Alle merken',
    title: 'Momentsleutel reparatie',
    desc: 'Van mechanische slijtage tot interne beschadigingen, wij repareren momentsleutels van alle merken. Diagnose altijd gratis, reparatie pas na jouw akkoord. Na reparatie altijd opnieuw gecertificeerd.',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    href: '/diensten/momentsleutel-justeren',
    label: 'Justeren',
    cta: 'Hoe justeren werkt',
    accent: '#C4AF64',
    eyebrow: 'Nauwkeurig bijstellen',
    title: 'Momentsleutel Justeren',
    desc: 'Is jouw momentsleutel buiten tolerantie geraakt? Wij stellen hem nauwkeurig bij tot binnen onze ±2% servicegarantie. Inclusief her-kalibratie en nieuw certificaat met as-left waarden.',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/><path d="M19.07 4.93a10 10 0 010 14.14M4.93 4.93a10 10 0 000 14.14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
  {
    href: '/diensten/iso-6789-certificering',
    label: 'Certificering',
    cta: 'Certificaat bekijken',
    accent: '#64C48A',
    eyebrow: 'Audit-proof',
    title: 'ISO 6789:2017 en 2003 Certificering',
    desc: 'Officiële certificering conform ISO 6789:2017 en 2003 voor kwaliteitssystemen, audits en inspecties. Volledig gedocumenteerd met meetwaarden voor en na.',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none"><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>`,
  },
];
---

<Base
  title="Momentsleutel Diensten | Dutch Torque Service"
  description="Momentsleutel kalibreren, repareren of certificeren? Dutch Torque Service: ±2% nauwkeurig, snelle doorlooptijd. ISO 6789:2017 en 2003 conform, Noord-Brabant. Stuur op."
  canonicalPath="/diensten"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <NavIsland currentPage="diensten" />

  <main>
    <!-- HERO -->
    <PageSection hero center animate>
        <div class="sec-eyebrow">
          <span class="w-8 h-px opacity-75" style="background:#7AAFC4;"></span>
          <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Diensten</span>
          <span class="w-8 h-px opacity-75" style="background:#7AAFC4;"></span>
        </div>
        <h1 class="font-black tracking-tight text-white" style="font-size: clamp(2.5rem, 6vw, 4.5rem); line-height: 1.05;">
          Momentsleutel Diensten.
        </h1>
        <p class="sec-sub" style="font-size: clamp(1rem, 1.6vw, 1.15rem);">
          Alles voor jouw momentsleutel <br> Van kalibratie en certificering tot volledige reparatie. <br> Gecertificeerd conform ISO 6789:2017 en 2003.
        </p>
        <!-- Scroll hint -->
        <div class="scroll-hint" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path d="M4 7l5 5 5-5" stroke="#7AAFC4" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
    </PageSection>

    <!-- SERVICE CARDS 2x2 GRID -->
    <PageSection>
        <!-- Section intro, sec-head drives all spacing + centering -->
        <div class="sec-head" data-animate>
          <div class="sec-eyebrow">
            <span class="w-8 h-px opacity-60" style="background:#7AAFC4;"></span>
            <span class="text-[10px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Kies jouw dienst</span>
            <span class="w-8 h-px opacity-60" style="background:#7AAFC4;"></span>
          </div>
          <p class="sec-sub">
            Twijfel je welke dienst je eigenlijk nodig hebt? Bel even, we adviseren je gratis en eerlijk.
          </p>
        </div>

        <div class="service-grid">
          {services.map((svc, i) => (
            <a
              href={svc.href}
              class="service-card group relative flex flex-col items-center text-center"
              data-card-pop
              data-card-index={String(i)}
              style={`padding: 2.5rem 2rem; border-radius: 1.5rem; background: linear-gradient(140deg, color-mix(in srgb, ${svc.accent} 7%, transparent) 0%, transparent 55%), #0E1118; border: 1px solid color-mix(in srgb, ${svc.accent} 15%, transparent); box-shadow: 0 2px 16px rgba(0,0,0,0.28); transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s; text-decoration: none;`}
            >
              <!-- Icon -->
              <div class="mb-5 w-16 h-16 rounded-2xl flex items-center justify-center" style={`background: color-mix(in srgb, ${svc.accent} 12%, transparent); border: 1px solid color-mix(in srgb, ${svc.accent} 20%, transparent); color: ${svc.accent};`}>
                <Fragment set:html={svc.icon} />
              </div>

              <!-- Eyebrow -->
              <p class="text-[10px] font-semibold tracking-[0.28em] uppercase mb-2" style={`color: ${svc.accent}; opacity: 0.8;`}>{svc.eyebrow}</p>

              <!-- Title -->
              <h2 class="text-xl font-black text-white mb-3" style="letter-spacing: -0.01em; line-height: 1.2;">{svc.title}</h2>

              <!-- Description -->
              <p class="mb-6 flex-1" style="font-size: 0.875rem; line-height: 1.75; color: #8EAAB8; max-width: 32ch; margin-inline: auto;">{svc.desc}</p>

              <!-- CTA link -->
              <span class="inline-flex items-center gap-2 text-sm font-semibold mt-auto" style={`color: ${svc.accent};`}>
                {svc.cta}
                <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>

              <!-- Corner bracket -->
              <div class="absolute bottom-4 right-4 w-4 h-4" style={`border-right: 1.5px solid ${svc.accent}; border-bottom: 1.5px solid ${svc.accent}; border-radius: 0 0 4px 0; opacity: 0.2;`}></div>
            </a>
          ))}
        </div>
    </PageSection>

    <!-- MERKEN / SNAP-ON -->
    <PageSection center animate>
          <div class="sec-eyebrow">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Merken</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4;"></span>
          </div>
          <h2 class="sec-title">Geautoriseerd Snap-On Dealer.</h2>
          <p class="sec-sub">
            Dutch Torque Service is geautoriseerd Snap-On dealer voor de regio Zuid-Noord-Brabant. Wij kalibreren en repareren Snap-On momentsleutels met hetzelfde ISO 6789:2017 en 2003 protocol als al onze andere sleutels.
          </p>
          <div class="sec-ctas">
            <a href="/merken/snap-on-kalibratie" class="btn btn-outline">
              Snap-On kalibratie &amp; dealer
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
    </PageSection>

    <!-- CTA -->
    <PageSection center animate>
        <h2 class="sec-title">Je sleutel moet worden gecheckt? Stuur hem op.</h2>
        <p class="sec-sub">
          Wij werken landelijk en internationaal, stuur je sleutel gewoon op of kom langs in Riethoven. Eerlijk advies, altijd gratis.
        </p>
        <div class="sec-ctas">
          <a href="/contact" class="btn btn-primary">
            Neem contact op
            <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="tel:+31613172774" class="btn btn-outline">+31(0)6-131 72 774</a>
        </div>
    </PageSection>
  </main>

  <FooterDTS />
</Base>

<style>
  .scroll-hint {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    border: 1px solid rgba(122, 175, 196, 0.25);
    margin-top: 0.5rem;
    animation: bounceY 2.2s ease-in-out infinite;
  }
  @keyframes bounceY {
    0%, 100% { transform: translateY(0); opacity: 0.6; }
    50%       { transform: translateY(6px); opacity: 1; }
  }

  .service-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  @media (max-width: 640px) {
    .service-grid { grid-template-columns: 1fr; }
  }

  .service-card {
    opacity: 0;
    transform: translateY(36px) scale(0.96);
    will-change: opacity, transform;
    isolation: isolate;
    overflow: hidden;
  }
  .service-card.is-visible {
    opacity: 1;
    transform: none;
  }

  /* Radial glow halo, fades in from bottom on hover */
  .service-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 110%, rgba(122,175,196,0.12) 0%, transparent 68%);
    opacity: 0;
    transition: opacity 0.45s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
    z-index: 0;
    border-radius: inherit;
  }

  /* Shine sweep, diagonal highlight that crosses the card */
  .service-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: -60%;
    width: 40%;
    height: 100%;
    background: linear-gradient(
      115deg,
      transparent 0%,
      rgba(255,255,255,0.06) 45%,
      rgba(255,255,255,0.11) 50%,
      rgba(255,255,255,0.06) 55%,
      transparent 100%
    );
    transform: skewX(-18deg);
    transition: left 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
    z-index: 0;
  }

  /* Keep all card children above pseudo layers */
  .service-card > * {
    position: relative;
    z-index: 1;
  }

  .service-card:hover,
  .service-card:focus-visible {
    transform: translateY(-4px) scale(1.01) !important;
    box-shadow: 0 16px 48px rgba(0,0,0,0.55) !important;
  }
  .service-card:hover::before,
  .service-card:focus-visible::before {
    opacity: 1;
  }
  .service-card:hover::after,
  .service-card:focus-visible::after {
    left: 120%;
  }

  /* Arrow nudge on the CTA chevron inside card */
  .service-card svg {
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .service-card:hover svg,
  .service-card:focus-visible svg {
    transform: translateX(4px);
  }
</style>

<script>
  import gsap from 'gsap';

  const grid = document.querySelector<HTMLElement>('.service-grid');
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.service-card'));

  function animateCards() {
    gsap.timeline({ defaults: { ease: 'power3.out' } })
      .to(cards[0], { opacity: 1, y: 0, scale: 1, duration: 0.55, delay: 0.05 })
      .to(cards[1], { opacity: 1, y: 0, scale: 1, duration: 0.55 }, '-=0.42')
      .to(cards[2], { opacity: 1, y: 0, scale: 1, duration: 0.55 }, '-=0.38')
      .to(cards[3], { opacity: 1, y: 0, scale: 1, duration: 0.55 }, '-=0.38');
  }

  if (grid && cards.length) {
    const observer = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting) {
        observer.disconnect();
        animateCards();
      }
    }, { threshold: 0.05 });
    observer.observe(grid);
  }
</script>
