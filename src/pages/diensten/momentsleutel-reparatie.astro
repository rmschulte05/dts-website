---
import Base from '../../layouts/Base.astro';
import NavIsland from '../../components/modules/NavIsland.astro';
import FooterDTS from '../../components/modules/FooterDTS.astro';
import PageSection from '../../components/ui/PageSection.astro';
import ChatExplainer from '../../components/modules/ChatExplainer.astro';

const accent = '#7AAFC4';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Momentsleutel reparatie",
  "name": "Momentsleutel reparatie",
  "provider": { "@id": "https://www.dutchtorqueservice.nl/#business" },
  "description": "Professionele Momentsleutel reparatie van alle merken. Gratis diagnose, raming vooraf, ISO 6789:2017 en 2003 gecertificeerd resultaat. ±2% servicegarantie, ruim binnen de ±4% ISO-tolerantie.",
  "areaServed": [
    { "@type": "Country", "name": "Netherlands" },
    { "@type": "Country", "name": "Belgium" },
    { "@type": "Country", "name": "Germany" },
    { "@type": "AdministrativeArea", "name": "Noord-Brabant" }
  ],
  "inLanguage": "nl-NL",
  "url": "https://www.dutchtorqueservice.nl/diensten/momentsleutel-reparatie"
};

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "Hoe verloopt een Momentsleutel reparatie bij Dutch Torque Service?",
  "description": "Ontvangst, gratis diagnose, kostenraming, reparatie pas na akkoord, hersamenstelling, en kalibratie conform ISO 6789:2017 en 2003 met certificaat.",
  "inLanguage": "nl-NL",
  "totalTime": "PT2H",
  "step": [
    { "@type": "HowToStep", "position": 1, "name": "Ontvangst & registratie", "text": "We registreren jouw sleutel met merk, type en serienummer, en bevestigen ontvangst per e-mail." },
    { "@type": "HowToStep", "position": 2, "name": "Gratis diagnose", "text": "Visuele en mechanische inspectie. We brengen de schade in kaart: klik-mechanisme, veer, ratel of kalibratie-drift." },
    { "@type": "HowToStep", "position": 3, "name": "Kostenraming & akkoord", "text": "Je ontvangt een heldere raming. Wij repareren pas na jouw akkoord. Geen verborgen kosten." },
    { "@type": "HowToStep", "position": 4, "name": "Reparatie & vervanging slijtdelen", "text": "Demontage, reiniging, vervanging van defecte onderdelen, hersmering en hersamenstelling." },
    { "@type": "HowToStep", "position": 5, "name": "Kalibratie & certificaat", "text": "Na elke reparatie kalibreren wij de sleutel conform ISO 6789:2017 en 2003 en leveren een volledig protocol met as-left waarden." }
  ]
};

const steps = [
  {
    n: '01',
    title: 'Ontvangst & registratie',
    body: 'We registreren jouw sleutel met merk, type en serienummer, en bevestigen ontvangst per e-mail.',
  },
  {
    n: '02',
    title: 'Gratis diagnose',
    body: 'Visuele en mechanische inspectie. We brengen de schade in kaart: klik-mechanisme, veer, ratel of kalibratie-drift.',
  },
  {
    n: '03',
    title: 'Kostenraming & akkoord',
    body: 'Je ontvangt een heldere raming. Wij repareren pas na jouw akkoord. Geen verborgen kosten.',
  },
  {
    n: '04',
    title: 'Reparatie & vervanging slijtdelen',
    body: 'Demontage, reiniging, vervanging van defecte onderdelen, hersmering en hersamenstelling.',
  },
  {
    n: '05',
    title: 'Kalibratie & certificaat',
    body: 'Na elke reparatie kalibreren wij de sleutel conform ISO 6789:2017 en 2003 en leveren een volledig <a href="/diensten/iso-6789-certificering" style="color:#7AAFC4; text-decoration:underline;">ISO 6789:2017 en 2003 protocol</a>.',
  },
];

const repairTable = [
  { situatie: 'Afwijking < 6%, geen mechanische schade', advies: '<a href="/diensten/momentsleutel-justeren" style="color:#7AAFC4; text-decoration:underline;">Justeren</a> + <a href="/diensten/momentsleutel-kalibratie" style="color:#7AAFC4; text-decoration:underline;">kalibreren</a>, goedkoopst' },
  { situatie: 'Afwijking > 6% of klik voelt anders', advies: 'Reparatie: vervanging slijtdelen' },
  { situatie: 'Reparatiekosten > 70% van de nieuwprijs', advies: 'Vervangingsadvies (wij leveren als <a href="/merken/snap-on-kalibratie" style="color:#7AAFC4; text-decoration:underline;">Snap-On dealer</a> ook nieuw)' },
  { situatie: 'Premium merk (Snap-On, Stahlwille)', advies: 'Reparatie loont vrijwel altijd, kwaliteitsbasis is degelijk' },
];

const merken = [
  { naam: 'Snap-On',     tagline: 'Originele onderdelen direct beschikbaar via geautoriseerd dealer.', accent: '#C4AF64', link: '/merken/snap-on-kalibratie' },
  { naam: 'Stahlwille',  tagline: 'Premium Duits precisiegereedschap. Volledige revisie mogelijk.',    accent: '#7AAFC4' },
  { naam: 'Gedore',      tagline: 'Industriestandaard. Slijtdelen en hercalibratie ISO 6789:2017 en 2003.',    accent: '#7AAFC4' },
  { naam: 'Facom',       tagline: 'Frans precisiegereedschap. Mechanische revisie en kalibratie.',     accent: '#7AAFC4' },
  { naam: 'Hazet',       tagline: 'Duitse kwaliteit. Reparatie inclusief ISO-certificaat.',            accent: '#7AAFC4' },
  { naam: 'Würth',       tagline: 'Volledig revisietraject met certificaat na afloop.',                accent: '#7AAFC4' },
  { naam: 'Proto',       tagline: 'Industrieel zwaar gebruik. Slijtdelen plus hercalibratie.',         accent: '#7AAFC4' },
  { naam: 'Ander merk?', tagline: 'Niet zeker of jouw merk erbij hoort? Vraag het ons even.',          accent: '#64C48A', link: '/contact' },
];

const whyCards = [
  {
    number: '01',
    accent: '#7AAFC4',
    icon: `<svg width="28" height="28" viewBox="0 0 32 32" fill="none">
      <circle cx="14" cy="14" r="9" stroke="currentColor" stroke-width="1.5"/>
      <path d="M21 21l6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <path d="M14 11v6M11 14h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>`,
    tagline: 'Geen kosten vooraf',
    title: 'Gratis diagnose',
    body: 'Wij inspecteren jouw sleutel kosteloos en sturen daarna een heldere raming. Reparatie pas na jouw akkoord, geen verrassingen achteraf.',
  },
  {
    number: '02',
    accent: '#C4AF64',
    icon: `<svg width="28" height="28" viewBox="0 0 32 32" fill="none">
      <path d="M16 3l3.2 9.8H29l-7.9 5.8 3.0 9.6L16 22.4 7.9 28.2l3.0-9.6L3 12.8h9.8z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
    </svg>`,
    tagline: 'Geautoriseerd dealer',
    title: 'Originele Snap-On onderdelen',
    body: 'Als geautoriseerd Snap-On dealer hebben wij directe toegang tot originele onderdelen, iets wat generieke bedrijven niet kunnen bieden.',
    link: '/merken/snap-on-kalibratie',
  },
  {
    number: '03',
    accent: '#64C48A',
    icon: `<svg width="28" height="28" viewBox="0 0 32 32" fill="none">
      <circle cx="16" cy="16" r="12" stroke="currentColor" stroke-width="1.4"/>
      <circle cx="16" cy="16" r="7"  stroke="currentColor" stroke-width="1.4"/>
      <circle cx="16" cy="16" r="2"  fill="currentColor"/>
    </svg>`,
    tagline: 'Altijd ISO-conform',
    title: 'Kalibratie na elke reparatie',
    body: 'Na elke reparatie kalibreren wij de sleutel conform ISO 6789:2017 en 2003 en leveren een volledig meetprotocol met certificaat.',
    link: '/diensten/iso-6789-certificering',
  },
];

const faq = [
  {
    q: 'Hoeveel kost een reparatie?',
    a: 'Dat hangt af van de schade en het merk. Wij doen altijd eerst een gratis diagnose en sturen je een heldere raming. Reparatie vindt pas plaats na jouw akkoord.',
  },
  {
    q: 'Kan ik mijn Snap-On sleutel bij jullie laten repareren met originele onderdelen?',
    a: 'Ja, als geautoriseerd Snap-On dealer hebben wij toegang tot originele Snap-On onderdelen en reparatiemethoden conform fabrieksnorm en ISO 6789:2017 en 2003.',
  },
  {
    q: 'Hoe lang duurt een reparatie?',
    a: 'Eenvoudige reparaties + <a href="/diensten/momentsleutel-kalibratie" style="color:#7AAFC4; text-decoration:underline;">kalibratie</a>: snel klaar. Meer uitgebreide revisies: 2–5 werkdagen. We communiceren de doorlooptijd altijd vooraf.',
  },
  {
    q: 'Wordt na reparatie ook een kalibratiecertificaat afgegeven?',
    a: 'Altijd. Na elke reparatie kalibreren wij de sleutel conform <a href="/diensten/iso-6789-certificering" style="color:#7AAFC4; text-decoration:underline;">ISO 6789:2017 en 2003</a> en leveren een volledig protocol met as-found en as-left waarden.',
  },
  {
    q: 'Wat als mijn sleutel niet meer te repareren is?',
    a: 'Dan ontvang je een diagnoserapport en eerlijk advies over vervanging. Als <a href="/merken/snap-on-kalibratie" style="color:#7AAFC4; text-decoration:underline;">Snap-On dealer</a> kunnen wij ook nieuw gecertificeerd Snap-On gereedschap leveren.',
  },
];
---

<Base
  title="Momentsleutel reparatie. Alle Merken | Dutch Torque Service"
  description="Professionele Momentsleutel reparatie van alle merken. Gratis diagnose, raming vooraf, ISO 6789:2017 en 2003 gecertificeerd. Snap-On, Stahlwille. Stuur op →"
  canonicalPath="/diensten/momentsleutel-reparatie"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(howToSchema)} />

  <NavIsland currentPage="diensten" />

  <main>

    <!-- ══════════════════════════════════════
         HERO
    ══════════════════════════════════════ -->
    <PageSection class="hero-section">
        <div class="hero-inner">
          <!-- Eyebrow -->
          <div class="sec-eyebrow" data-animate>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Reparatie</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>

          <h1 class="hero-h1" data-animate data-animate-delay="0.08">
            Momentsleutel reparatie.
          </h1>

          <p class="hero-subtitle" data-animate data-animate-delay="0.16">
            Reparatie van alle gangbare merken. Gratis diagnose, raming vooraf.<br />
            Kalibratie conform ISO 6789:2017 en 2003 erna. Stuur hem gewoon op en wij kijken er even naar.
          </p>

          <div class="hero-ctas" data-animate data-animate-delay="0.22">
            <a href="/contact" class="btn btn-primary">Plan reparatie</a>
            <a href="/diensten" class="btn btn-outline">Bekijk diensten</a>
          </div>

          <!-- Stats badges -->
          <div class="hero-badges" data-animate data-animate-delay="0.30">
            <span class="badge" style="background:rgba(122,175,196,0.10); border:1px solid rgba(122,175,196,0.28); color:#7AAFC4;">Alle Merken</span>
            <span class="badge" style="background:rgba(122,175,196,0.10); border:1px solid rgba(122,175,196,0.28); color:#7AAFC4;">Gratis Diagnose</span>
            <span class="badge" style="background:rgba(122,175,196,0.10); border:1px solid rgba(122,175,196,0.28); color:#7AAFC4;">Snelle Doorlooptijd</span>
          </div>
        </div>
    </PageSection>

    <!-- WHAT IS X. CHAT UI -->
    <PageSection>
      <ChatExplainer
        question="Wat als mijn momentsleutel niet meer klopt?"
        answer="Dan repareren wij hem. We inspecteren gratis, geven je een heldere raming vóór we beginnen, vervangen de slijtdelen en kalibreren na afloop opnieuw conform <a href='/diensten/iso-6789-certificering' style='color:#7AAFC4; text-decoration:underline;'>ISO 6789:2017 en 2003</a>. Geen verrassingen."
        accent="#C48A64"
        reactions={[
          { emoji: '🔧', count: 16 },
          { emoji: '👍', count: 12 },
          { emoji: '✅', count: 19 },
        ]}
      />
    </PageSection>

    <!-- ══════════════════════════════════════
         PROCESS
    ══════════════════════════════════════ -->
    <PageSection class="[background:rgba(14,17,24,0.5)]">
        <div class="sec-head" data-animate>
          <div class="sec-eyebrow">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Ons proces</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="sec-title">Hoe verloopt een Momentsleutel reparatie?</h2>
        </div>

        <div class="steps-grid">
          {steps.map((step, i) => (
            <div class="step-card" data-animate data-animate-delay={String(i * 0.08)}>
              <div class="step-number" style={`color:${accent};`}>{step.n}</div>
              <h3 class="step-title">{step.title}</h3>
              <p class="step-body" set:html={step.body} />
            </div>
          ))}
        </div>
    </PageSection>

    <!-- ══════════════════════════════════════
         REPAIR OR REPLACE TABLE
    ══════════════════════════════════════ -->
    <PageSection>
        <div class="sec-head" data-animate>
          <div class="sec-eyebrow">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Advies</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="sec-title">Repareren of vervangen?</h2>
        </div>

        <div class="table-wrap" data-animate data-animate-delay="0.08">
          <table class="incl-table">
            <thead>
              <tr>
                <th>Situatie</th>
                <th>Advies</th>
              </tr>
            </thead>
            <tbody>
              {repairTable.map(row => (
                <tr>
                  <td>{row.situatie}</td>
                  <td class="incl-detail" set:html={row.advies} />
                </tr>
              ))}
            </tbody>
          </table>
        </div>
    </PageSection>

    <!-- ══════════════════════════════════════
         MERKEN
    ══════════════════════════════════════ -->
    <PageSection class="[background:rgba(14,17,24,0.5)]">
        <div class="sec-head" data-animate>
          <div class="sec-eyebrow">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Merken</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="sec-title">Merken die wij repareren.</h2>
        </div>

        <div class="merken-grid">
          {merken.map((m, i) => {
            const Tag = m.link ? 'a' : 'div';
            const props = m.link ? { href: m.link } : {};
            return (
              <Tag
                {...props}
                class="merk-card"
                data-animate
                data-animate-delay={String(i * 0.05)}
                style={`--accent: ${m.accent};`}
              >
                <span class="merk-name">{m.naam}</span>
                <p class="merk-tagline">{m.tagline}</p>
                <div class="merk-corner" aria-hidden="true"></div>
              </Tag>
            );
          })}
        </div>
    </PageSection>

    <!-- ══════════════════════════════════════
         WHY DTS
    ══════════════════════════════════════ -->
    <PageSection>
        <div class="sec-head" data-animate>
          <div class="sec-eyebrow">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Waarom DTS?</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="sec-title">Waarom monteurs voor DTS kiezen.</h2>
        </div>

        <div class="value-grid">
          {whyCards.map((card, i) => {
            const Tag = card.link ? 'a' : 'div';
            const props = card.link ? { href: card.link } : {};
            return (
              <Tag
                {...props}
                class="value-card"
                data-animate
                data-animate-delay={String(i * 0.12)}
                style={`--accent: ${card.accent};`}
              >
                <div class="vc-top">
                  <span class="vc-num" aria-hidden="true">{card.number}</span>
                  <div class="vc-icon" aria-hidden="true">
                    <Fragment set:html={card.icon} />
                  </div>
                </div>
                <div class="vc-rule"></div>
                <p class="vc-tagline">{card.tagline}</p>
                <h3 class="vc-title">{card.title}</h3>
                <p class="vc-body">{card.body}</p>
                <div class="vc-corner" aria-hidden="true"></div>
              </Tag>
            );
          })}
        </div>
    </PageSection>

    <!-- ══════════════════════════════════════
         FAQ
    ══════════════════════════════════════ -->
    <PageSection class="[background:rgba(14,17,24,0.5)]">
        <div class="sec-head" data-animate>
          <div class="sec-eyebrow">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">FAQ</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="sec-title">Veelgestelde vragen.</h2>
        </div>

        <div class="faq-list" data-animate data-animate-delay="0.08">
          {faq.map(item => (
            <details>
              <summary>{item.q}</summary>
              <div class="faq-body" set:html={item.a} />
            </details>
          ))}
        </div>
    </PageSection>

    <!-- ══════════════════════════════════════
         CTA
    ══════════════════════════════════════ -->
    <PageSection>
        <div class="sec-head sec-head--flush" data-animate>
          <div class="sec-eyebrow">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Direct starten</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="sec-title">Sleutel kapot? Stuur hem op.</h2>
          <p class="sec-sub">
            Stuur ons jouw sleutel op of bel direct voor een afspraak. Bij grotere revisies hoor je vooraf de doorlooptijd. Wij zijn gevestigd in Riethoven (Noord-Brabant), opsturen kan landelijk.
          </p>
          <div class="sec-ctas">
            <a href="tel:+31613172774" class="btn btn-primary">Bel +31(0)6-131 72 774</a>
            <a href="mailto:info@dutchtorqueservice.nl" class="btn btn-outline">Stuur een e-mail</a>
          </div>
        </div>
    </PageSection>

  </main>

  <FooterDTS />

</Base>

<style>
  /* ── Hero ── */
  .hero-section {
    padding-top: clamp(7rem, 14vw, 11rem);
  }
  .hero-inner {
    max-width: 780px;
    margin-inline: auto;
    text-align: center;
  }
  .hero-h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: #fff;
    margin-bottom: 1.75rem;
  }
  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.7;
    color: #8EAAB8;
    margin-bottom: 2.5rem;
    max-width: 60ch;
    margin-inline: auto;
    text-align: center;
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    margin-bottom: 3rem;
    justify-content: center;
  }
  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    justify-content: center;
  }
  .body-text {
    font-size: 0.975rem;
    line-height: 1.8;
    color: #8EAAB8;
  }

  /* ── What is it ── */
  .def-card {
    background: #0E1118;
    border: 1px solid rgba(122,175,196,0.14);
    border-radius: 1.5rem;
    padding: clamp(1.5rem, 3vw, 2.5rem);
    max-width: 820px;
  }

  /* ── Steps ── */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.25rem;
  }
  .step-card {
    background: #0E1118;
    border: 1px solid rgba(122,175,196,0.14);
    border-radius: 1.5rem;
    padding: 1.75rem;
    position: relative;
    isolation: isolate;
    overflow: hidden;
    transition: border-color 0.35s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
                box-shadow 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .step-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 110%, rgba(122,175,196,0.10) 0%, transparent 65%);
    opacity: 0;
    transition: opacity 0.45s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
    z-index: 0;
    border-radius: inherit;
  }
  .step-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: -60%;
    width: 40%;
    height: 100%;
    background: linear-gradient(
      115deg,
      transparent 0%,
      rgba(255,255,255,0.05) 45%,
      rgba(255,255,255,0.09) 50%,
      rgba(255,255,255,0.05) 55%,
      transparent 100%
    );
    transform: skewX(-18deg);
    transition: left 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
    z-index: 0;
  }
  .step-card > * { position: relative; z-index: 1; }
  .step-card:hover,
  .step-card:focus-visible {
    border-color: rgba(122,175,196,0.32);
    transform: translateY(-4px);
    box-shadow: 0 12px 36px rgba(0,0,0,0.45), 0 0 0 1px rgba(122,175,196,0.14);
  }
  .step-card:hover::before,
