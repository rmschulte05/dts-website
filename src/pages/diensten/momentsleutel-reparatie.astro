---
import Base from '../../layouts/Base.astro';
import NavIsland from '../../components/modules/NavIsland.astro';
import FooterDTS from '../../components/modules/FooterDTS.astro';
import PageSection from '../../components/ui/PageSection.astro';
import ChatExplainer from '../../components/modules/ChatExplainer.astro';

const accent = '#7AAFC4';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Momentsleutel Reparatie",
  "name": "Momentsleutel Reparatie",
  "provider": { "@id": "https://www.dutchtorqueservice.nl/#business" },
  "description": "Professionele momentsleutel reparatie van alle merken. Gratis diagnose, raming vooraf, ISO 6789:2017 gecertificeerd resultaat.",
  "areaServed": { "@type": "Country", "name": "Netherlands" },
  "url": "https://www.dutchtorqueservice.nl/diensten/momentsleutel-reparatie"
};

const steps = [
  {
    n: '01',
    title: 'Ontvangst & registratie',
    body: 'We registreren jouw sleutel met merk, type en serienummer, en bevestigen ontvangst per e-mail.',
  },
  {
    n: '02',
    title: 'Gratis diagnose',
    body: 'Visuele en mechanische inspectie. We brengen de schade in kaart: klik-mechanisme, veer, ratel of kalibratie-drift.',
  },
  {
    n: '03',
    title: 'Kostenraming & akkoord',
    body: 'Je ontvangt een heldere raming. Wij repareren pas na jouw akkoord. Geen verborgen kosten.',
  },
  {
    n: '04',
    title: 'Reparatie & vervanging slijtdelen',
    body: 'Demontage, reiniging, vervanging van defecte onderdelen, hersmering en hersamenstelling.',
  },
  {
    n: '05',
    title: 'Kalibratie & certificaat',
    body: 'Na elke reparatie kalibreren wij de sleutel conform ISO 6789:2017 en leveren een volledig <a href="/diensten/iso-6789-certificering" style="color:#7AAFC4; text-decoration:underline;">ISO 6789:2017 protocol</a>.',
  },
];

const repairTable = [
  { situatie: 'Afwijking < 6%, geen mechanische schade', advies: '<a href="/diensten/momentsleutel-justeren" style="color:#7AAFC4; text-decoration:underline;">Justeren</a> + <a href="/diensten/momentsleutel-kalibratie" style="color:#7AAFC4; text-decoration:underline;">kalibreren</a> — goedkoopst' },
  { situatie: 'Afwijking > 6% of klik voelt anders', advies: 'Reparatie: vervanging slijtdelen' },
  { situatie: 'Reparatiekosten > 70% van de nieuwprijs', advies: 'Vervangingsadvies (wij leveren als <a href="/merken/snap-on-kalibratie" style="color:#7AAFC4; text-decoration:underline;">Snap-On dealer</a> ook nieuw)' },
  { situatie: 'Premium merk (Snap-On, Stahlwille)', advies: 'Reparatie loont vrijwel altijd — kwaliteitsbasis is degelijk' },
];

const whyCards = [
  {
    accent: '#7AAFC4',
    icon: '✓',
    title: 'Gratis diagnose',
    body: 'Geen kosten voor de inspectie. Raming altijd vooraf — geen verrassingen achteraf.',
  },
  {
    accent: '#C4AF64',
    icon: '✦',
    title: 'Originele Snap-On onderdelen',
    body: 'Als geautoriseerd dealer zijn originele Snap-On onderdelen direct beschikbaar — iets wat de meeste generieke bedrijven niet kunnen bieden.',
  },
  {
    accent: '#64C48A',
    icon: '◎',
    title: 'Kalibratie na elke reparatie',
    body: 'Na elke reparatie krijg je altijd een ISO 6789:2017 conform certificaat met volledig meetprotocol.',
  },
];

const faq = [
  {
    q: 'Hoeveel kost een reparatie?',
    a: 'Dat hangt af van de schade en het merk. Wij doen altijd eerst een gratis diagnose en sturen je een heldere raming. Reparatie vindt pas plaats na jouw akkoord.',
  },
  {
    q: 'Kan ik mijn Snap-On sleutel bij jullie laten repareren met originele onderdelen?',
    a: 'Ja — als geautoriseerd Snap-On dealer hebben wij toegang tot originele Snap-On onderdelen en reparatiemethoden conform fabrieksnorm en ISO 6789:2017.',
  },
  {
    q: 'Hoe lang duurt een reparatie?',
    a: 'Eenvoudige reparaties + <a href="/diensten/momentsleutel-kalibratie" style="color:#7AAFC4; text-decoration:underline;">kalibratie</a>: snel klaar. Meer uitgebreide revisies: 2–5 werkdagen. We communiceren de doorlooptijd altijd vooraf.',
  },
  {
    q: 'Wordt na reparatie ook een kalibratiecertificaat afgegeven?',
    a: 'Altijd. Na elke reparatie kalibreren wij de sleutel conform <a href="/diensten/iso-6789-certificering" style="color:#7AAFC4; text-decoration:underline;">ISO 6789:2017</a> en leveren een volledig protocol met as-found en as-left waarden.',
  },
  {
    q: 'Wat als mijn sleutel niet meer te repareren is?',
    a: 'Dan ontvang je een diagnoserapport en eerlijk advies over vervanging. Als <a href="/merken/snap-on-kalibratie" style="color:#7AAFC4; text-decoration:underline;">Snap-On dealer</a> kunnen wij ook nieuw gecertificeerd Snap-On gereedschap leveren.',
  },
];
---

<Base
  title="Momentsleutel Reparatie — Alle Merken | Dutch Torque Service"
  description="Professionele momentsleutel reparatie van alle merken. Gratis diagnose, raming vooraf, ISO 6789:2017 gecertificeerd. Snap-On, Stahlwille. Stuur op →"
  canonicalPath="/diensten/momentsleutel-reparatie"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(schema)} />

  <NavIsland currentPage="diensten" />

  <main>

    <!-- ══════════════════════════════════════
         HERO
    ══════════════════════════════════════ -->
    <PageSection class="hero-section">
        <div class="hero-inner">
          <!-- Eyebrow -->
          <div class="sec-eyebrow" data-animate>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Reparatie</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>

          <h1 class="hero-h1" data-animate data-animate-delay="0.08">
            Momentsleutel Reparatie.
          </h1>

          <p class="hero-subtitle" data-animate data-animate-delay="0.16">
            Reparatie van alle gangbare merken. Gratis diagnose, raming vooraf.<br />
            Kalibratie conform ISO 6789:2017 erna. Stuur hem gewoon op — wij kijken er even naar.
          </p>

          <div class="hero-ctas" data-animate data-animate-delay="0.22">
            <a href="/contact" class="btn btn-primary">Plan reparatie</a>
            <a href="/werk" class="btn btn-outline">Bekijk cases</a>
          </div>

          <!-- Stats badges -->
          <div class="hero-badges" data-animate data-animate-delay="0.30">
            <span class="badge" style="background:rgba(122,175,196,0.10); border:1px solid rgba(122,175,196,0.28); color:#7AAFC4;">Alle Merken</span>
            <span class="badge" style="background:rgba(122,175,196,0.10); border:1px solid rgba(122,175,196,0.28); color:#7AAFC4;">Gratis Diagnose</span>
            <span class="badge" style="background:rgba(122,175,196,0.10); border:1px solid rgba(122,175,196,0.28); color:#7AAFC4;">Snelle Doorlooptijd</span>
          </div>
        </div>
    </PageSection>

    <!-- WHAT IS X — CHAT UI -->
    <PageSection>
      <ChatExplainer
        question="Wat als mijn momentsleutel niet meer klopt?"
        answer="Dan repareren wij hem. We inspecteren gratis, geven je een heldere raming vóór we beginnen, vervangen de slijtdelen en kalibreren na afloop opnieuw conform <a href='/diensten/iso-6789-certificering' style='color:#7AAFC4; text-decoration:underline;'>ISO 6789:2017</a>. Geen verrassingen."
        accent="#C48A64"
        reactions={[
          { emoji: '🔧', count: 16 },
          { emoji: '👍', count: 12 },
          { emoji: '✅', count: 19 },
        ]}
      />
    </PageSection>

    <!-- ══════════════════════════════════════
         PROCESS
    ══════════════════════════════════════ -->
    <PageSection class="[background:rgba(14,17,24,0.5)]">
        <div class="sec-head" data-animate>
          <div class="sec-eyebrow">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Ons proces</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="sec-title">Hoe verloopt een momentsleutel reparatie?</h2>
        </div>

        <div class="steps-grid">
          {steps.map((step, i) => (
            <div class="step-card" data-animate data-animate-delay={String(i * 0.08)}>
              <div class="step-number" style={`color:${accent};`}>{step.n}</div>
              <h3 class="step-title">{step.title}</h3>
              <p class="step-body" set:html={step.body} />
            </div>
          ))}
        </div>
    </PageSection>

    <!-- ══════════════════════════════════════
         REPAIR OR REPLACE TABLE
    ══════════════════════════════════════ -->
    <PageSection>
        <div class="sec-head" data-animate>
          <div class="sec-eyebrow">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Advies</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="sec-title">Repareren of vervangen?</h2>
        </div>

        <div class="table-wrap" data-animate data-animate-delay="0.08">
          <table class="incl-table">
            <thead>
              <tr>
                <th>Situatie</th>
                <th>Advies</th>
              </tr>
            </thead>
            <tbody>
              {repairTable.map(row => (
                <tr>
                  <td>{row.situatie}</td>
                  <td class="incl-detail" set:html={row.advies} />
                </tr>
              ))}
            </tbody>
          </table>
        </div>
    </PageSection>

    <!-- ══════════════════════════════════════
         MERKEN
    ══════════════════════════════════════ -->
    <PageSection class="[background:rgba(14,17,24,0.5)]">
        <div class="sec-head" data-animate>
          <div class="sec-eyebrow">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Merken</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="sec-title">Merken die wij repareren.</h2>
        </div>

        <div class="def-card" data-animate data-animate-delay="0.08">
          <p class="body-text">
            Wij repareren alle gangbare kwaliteitsmerken: <strong style="color:#C8D8E0;">Snap-On</strong> (originele onderdelen beschikbaar als geautoriseerd dealer), <strong style="color:#C8D8E0;">Stahlwille</strong>, <strong style="color:#C8D8E0;">Gedore</strong>, <strong style="color:#C8D8E0;">Facom</strong>, <strong style="color:#C8D8E0;">Hazet</strong>, <strong style="color:#C8D8E0;">Würth</strong>, <strong style="color:#C8D8E0;">Proto</strong>, en andere kwaliteitsmerken. Niet zeker of wij jouw merk repareren? <a href="/contact" style="color:#7AAFC4; text-decoration:underline;">Vraag het even — wij vertellen je of het kan</a>.
          </p>
          <p class="body-text" style="margin-top:1.25rem;">
            <a href="/merken/snap-on-kalibratie" style="color:#7AAFC4; text-decoration:underline;">Snap-On kalibratie Noord-Brabant</a>
          </p>
        </div>
    </PageSection>

    <!-- ══════════════════════════════════════
         WHY DTS
    ══════════════════════════════════════ -->
    <PageSection>
        <div class="sec-head" data-animate>
          <div class="sec-eyebrow">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Waarom DTS?</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="sec-title">Waarom monteurs voor DTS kiezen.</h2>
        </div>

        <div class="why-grid">
          {whyCards.map((card, i) => (
            <div class="why-card" data-animate data-animate-delay={String(i * 0.10)} style={`border-color:rgba(${card.accent === '#7AAFC4' ? '122,175,196' : card.accent === '#C4AF64' ? '196,175,100' : '100,196,138'},0.14);`}>
              <div class="why-icon" style={`color:${card.accent};`}>{card.icon}</div>
              <h3 class="why-title" style={`color:${card.accent};`}>{card.title}</h3>
              <p class="why-body">{card.body}</p>
            </div>
          ))}
        </div>
    </PageSection>

    <!-- ══════════════════════════════════════
         FAQ
    ══════════════════════════════════════ -->
    <PageSection class="[background:rgba(14,17,24,0.5)]">
        <div class="sec-head" data-animate>
          <div class="sec-eyebrow">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">FAQ</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="sec-title">Veelgestelde vragen.</h2>
        </div>

        <div class="faq-list" data-animate data-animate-delay="0.08">
          {faq.map(item => (
            <details>
              <summary>{item.q}</summary>
              <div class="faq-body" set:html={item.a} />
            </details>
          ))}
        </div>
    </PageSection>

    <!-- ══════════════════════════════════════
         CTA
    ══════════════════════════════════════ -->
    <PageSection>
        <div class="sec-head sec-head--flush" data-animate>
          <div class="sec-eyebrow">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Direct starten</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="sec-title">Sleutel kapot? Stuur hem op.</h2>
          <p class="sec-sub">
            Stuur ons jouw sleutel op of bel direct voor een afspraak. Bij grotere revisies hoor je vooraf de doorlooptijd. Wij zijn gevestigd in Riethoven (Noord-Brabant) — opsturen kan landelijk.
          </p>
          <div class="sec-ctas">
            <a href="tel:+31613172774" class="btn btn-primary">Bel +31(0)6-131 72 774</a>
            <a href="mailto:info@dutchtorqueservice.nl" class="btn btn-outline">Stuur een e-mail</a>
          </div>
        </div>
    </PageSection>

  </main>

  <FooterDTS />

</Base>

<style>
  /* ── Hero ── */
  .hero-section {
    padding-top: clamp(7rem, 14vw, 11rem);
  }
  .hero-inner {
    max-width: 780px;
    margin-inline: auto;
    text-align: center;
  }
  .hero-h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: #fff;
    margin-bottom: 1.75rem;
  }
  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.7;
    color: #8EAAB8;
    margin-bottom: 2.5rem;
    max-width: 60ch;
    margin-inline: auto;
    text-align: center;
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    margin-bottom: 3rem;
    justify-content: center;
  }
  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    justify-content: center;
  }
  .body-text {
    font-size: 0.975rem;
    line-height: 1.8;
    color: #8EAAB8;
  }

  /* ── What is it ── */
  .def-card {
    background: #0E1118;
    border: 1px solid rgba(122,175,196,0.14);
    border-radius: 1.5rem;
    padding: clamp(1.5rem, 3vw, 2.5rem);
    max-width: 820px;
  }

  /* ── Steps ── */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.25rem;
  }
  .step-card {
    background: #0E1118;
    border: 1px solid rgba(122,175,196,0.14);
    border-radius: 1.5rem;
    padding: 1.75rem;
  }
  .step-number {
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  .step-title {
    font-size: 1rem;
    font-weight: 700;
    color: #E8F0F4;
    margin-bottom: 0.625rem;
  }
  .step-body {
    font-size: 0.875rem;
    line-height: 1.75;
    color: #8EAAB8;
  }
  .step-body a { color: #7AAFC4; text-decoration: underline; }

  /* ── Table ── */
  .table-wrap {
    overflow-x: auto;
  }
  .incl-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }
  .incl-table thead th {
    text-align: left;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    padding: 0 1rem 1rem 1rem;
    border-bottom: 1px solid rgba(122,175,196,0.12);
  }
  .incl-table tbody tr {
    border-bottom: 1px solid rgba(122,175,196,0.07);
    transition: background 0.15s;
  }
  .incl-table tbody tr:hover {
    background: rgba(122,175,196,0.04);
  }
  .incl-table tbody td {
    padding: 1rem;
    color: #C8D8E0;
    font-weight: 500;
    vertical-align: middle;
  }
  .incl-detail {
    color: #6A8A98 !important;
    font-weight: 400 !important;
    font-size: 0.85rem;
  }
  .incl-detail a { color: #7AAFC4; text-decoration: underline; }

  /* ── Why DTS ── */
  .why-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
  }
  .why-card {
    background: #0E1118;
    border: 1px solid rgba(122,175,196,0.14);
    border-radius: 1.5rem;
    padding: 2rem;
    transition: border-color 0.2s;
  }
  .why-card:hover {
    border-color: rgba(122,175,196,0.30);
  }
  .why-icon {
    font-size: 1.5rem;
    font-weight: 900;
    margin-bottom: 1rem;
  }
  .why-title {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.625rem;
  }
  .why-body {
    font-size: 0.875rem;
    line-height: 1.75;
    color: #8EAAB8;
  }

  /* ── FAQ ── */
  .faq-list {
    max-width: 820px;
    margin-inline: auto;
  }
  details {
    border: 1px solid rgba(122,175,196,0.12);
    border-radius: 1rem;
    background: #0E1118;
    margin-bottom: 0.75rem;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  details[open] {
    border-color: rgba(122,175,196,0.30);
  }
  summary {
    padding: 1.25rem 1.5rem;
    cursor: pointer;
    font-weight: 700;
    color: #E8F0F4;
    font-size: 0.975rem;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }
  summary::-webkit-details-marker { display: none; }
  summary::after {
    content: '+';
    color: #7AAFC4;
    font-size: 1.25rem;
    font-weight: 300;
    flex-shrink: 0;
    transition: transform 0.25s;
  }
  details[open] summary::after { transform: rotate(45deg); }
  .faq-body {
    padding: 0 1.5rem 1.5rem;
    font-size: 0.9rem;
    line-height: 1.8;
    color: #8EAAB8;
  }
  .faq-body a { color: #7AAFC4; text-decoration: underline; }</style>
