---
import Base from '../../layouts/Base.astro';
import NavIsland from '../../components/modules/NavIsland.astro';
import FooterDTS from '../../components/modules/FooterDTS.astro';
import PageSection from '../../components/ui/PageSection.astro';
import ChatExplainer from '../../components/modules/ChatExplainer.astro';

const accent = '#7AAFC4';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Kalibratie momentsleutel",
  "name": "Momentsleutel Kalibratie",
  "provider": { "@id": "https://www.dutchtorqueservice.nl/#business" },
  "description": "Momentsleutel kalibratie op 5 meetpunten conform ISO 6789:2017 en 2003. ±2% servicegarantie, ruim binnen de ±4% ISO-tolerantie. Volledig protocol inbegrepen. Geautoriseerd Snap-On dealer.",
  "areaServed": [
    { "@type": "Country", "name": "Netherlands" },
    { "@type": "Country", "name": "Belgium" },
    { "@type": "Country", "name": "Germany" },
    { "@type": "AdministrativeArea", "name": "Noord-Brabant" }
  ],
  "inLanguage": "nl-NL",
  "url": "https://www.dutchtorqueservice.nl/diensten/momentsleutel-kalibratie"
};

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "Hoe wij een momentsleutel kalibreren, stap voor stap",
  "description": "Ons kalibratieprotocol conform ISO 6789:2017 en 2003 in 5 stappen: ontvangst, visuele inspectie, as-found meting op 5 meetpunten, eventuele justering, protocol en certificaat.",
  "inLanguage": "nl-NL",
  "totalTime": "PT1H",
  "supply": [
    { "@type": "HowToSupply", "name": "De te kalibreren momentsleutel" }
  ],
  "tool": [
    { "@type": "HowToTool", "name": "Traceerbare referentie-koppelmeter (kalibratiestatus vermeld op certificaat)" },
    { "@type": "HowToTool", "name": "ISO 6789:2017 en 2003 kalibratieprotocol (as-found / as-left)" }
  ],
  "step": [
    { "@type": "HowToStep", "position": 1, "name": "Ontvangst & registratie", "text": "We registreren de sleutel met merk, type, serienummer en het te kalibreren bereik." },
    { "@type": "HowToStep", "position": 2, "name": "Visuele inspectie", "text": "Controle op mechanische schade, slijtage of corrosie vóór de meting. Ernstige schade wordt doorverwezen naar Momentsleutel reparatie." },
    { "@type": "HowToStep", "position": 3, "name": "As-found meting", "text": "Kalibratie op 5 meetpunten (20%, 40%, 60%, 80% en 100% van het bereik) voor de ingreep, met minimaal 3 herhalingen per punt." },
    { "@type": "HowToStep", "position": 4, "name": "Justering indien nodig", "text": "Als de afwijking buiten tolerantie valt, wordt de sleutel gejusteerd voordat de as-left meting plaatsvindt." },
    { "@type": "HowToStep", "position": 5, "name": "Protocol & certificaat", "text": "Volledig kalibratieprotocol met as-found, as-left, gebruikte referentieapparatuur en aanbevolen interval voor de volgende kalibratie." }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Hoeveel meetpunten gebruiken jullie bij kalibratie?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "5 punten: 20%, 40%, 60%, 80% en 100% van het nominale bereik, met minimaal 3 herhalingen per punt."
      }
    },
    {
      "@type": "Question",
      "name": "Welke typen momentsleutels kalibreren jullie?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Alle Type I (indicerend) en Type II (instellend) instrumenten conform ISO 6789:2017 en 2003. Van balksleutels tot digitale kliksleutels en alles daartussenin."
      }
    },
    {
      "@type": "Question",
      "name": "Moet ik mijn sleutel opsturen of kunnen jullie op locatie kalibreren?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Opsturen is de standaard. Heb je een grotere batch? Neem even contact op, dan kijken we wat we voor je kunnen regelen."
      }
    },
    {
      "@type": "Question",
      "name": "Hoe snel ontvang ik mijn certificaat?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Snel na ontvangst van je sleutel sturen we je het certificaat per e-mail."
      }
    },
    {
      "@type": "Question",
      "name": "Mijn kwaliteitshandboek vereist ISO-kalibratie, voldoen jullie hieraan?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ja. Wij kalibreren conform ISO 6789:2017 en 2003 Type I en II, met traceerbare referentieapparatuur en een geldig certificaat."
      }
    }
  ]
};

const steps = [
  {
    n: '01',
    title: 'Ontvangst & registratie',
    body: 'We registreren jouw sleutel met merk, type, serienummer en het te kalibreren bereik.',
    html: false,
  },
  {
    n: '02',
    title: 'Visuele inspectie',
    body: 'Controle op mechanische schade, slijtage of corrosie vóór de meting. Ernstige schade? Dan verwijzen we door naar <a href="/diensten/momentsleutel-reparatie">Momentsleutel reparatie</a>.',
    html: true,
  },
  {
    n: '03',
    title: 'As-found meting',
    body: 'Kalibratie op 5 meetpunten (≥20%, 40%, 60%, 80%, 100% van het bereik) voor de ingreep. Drie herhalingen per punt.',
    html: false,
  },
  {
    n: '04',
    title: 'Justering indien nodig',
    body: 'Als de afwijking buiten tolerantie valt, <a href="/diensten/momentsleutel-justeren">laten we de sleutel justeren</a> voordat de as-left meting plaatsvindt.',
    html: true,
  },
  {
    n: '05',
    title: 'Protocol & certificaat',
    body: 'Volledig kalibratieprotocol met as-found, as-left, gebruikte referentieapparatuur en aanbevolen interval voor de volgende kalibratie.',
    html: false,
  },
];

const included = [
  { item: 'As-found meting',        detail: 'Meetwaarden vóór ingreep, 5 punten × 3 herhalingen', html: false },
  { item: 'As-left meting',         detail: 'Meetwaarden na ingreep', html: false },
  { item: 'Referentieapparatuur',   detail: 'Traceerbaar, eigen kalibratiestatus vermeld', html: false },
  { item: '<a href="/diensten/iso-6789-certificering">Kalibratiecertificaat</a>', detail: 'Conform ISO 6789:2017 en 2003', html: true },
  { item: 'Volgende kalibratietermijn', detail: 'Aanbeveling op basis van gebruik en belasting', html: false },
  { item: 'E-mailbevestiging',      detail: 'Direct na afronding', html: false },
];

const whyCards = [
  {
    number: '01',
    accent: '#7AAFC4',
    icon: `<svg width="28" height="28" viewBox="0 0 32 32" fill="none">
      <circle cx="16" cy="16" r="12" stroke="currentColor" stroke-width="1.4"/>
      <circle cx="16" cy="16" r="6"  stroke="currentColor" stroke-width="1.4"/>
      <circle cx="16" cy="16" r="2"  fill="currentColor"/>
      <line x1="16" y1="4"  x2="16" y2="8"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="4"  y1="16" x2="8"  y2="16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="24" y1="16" x2="28" y2="16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>`,
    tagline: 'ISO 6789:2017 en 2003',
    title: '±2% Gegarandeerd',
    body: 'Elk instrument wordt gekalibreerd binnen de ±2% tolerantie conform ISO 6789:2017 en 2003. Onze referentieapparatuur is traceerbaar naar nationale ijknormen.',
  },
  {
    number: '02',
    accent: '#C4AF64',
    icon: `<svg width="28" height="28" viewBox="0 0 32 32" fill="none">
      <path d="M16 3l3.2 9.8H29l-7.9 5.8 3.0 9.6L16 22.4 7.9 28.2l3.0-9.6L3 12.8h9.8z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
    </svg>`,
    tagline: 'Geautoriseerd dealer',
    title: 'Snap-On Dealer',
    body: 'Als geautoriseerde Snap-On dealer kalibreren we Snap-On momentsleutels met de juiste merkspecifieke referentieapparatuur, direct, zonder tussenschakel.',
    link: '/merken/snap-on-kalibratie',
  },
  {
    number: '03',
    accent: '#64C48A',
    icon: `<svg width="28" height="28" viewBox="0 0 32 32" fill="none">
      <circle cx="16" cy="18" r="11" stroke="currentColor" stroke-width="1.4"/>
      <path d="M16 10v8l5 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M10 4h12"   stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <path d="M16 4v4"    stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>`,
    tagline: 'Snel terug',
    title: 'Snelle doorlooptijd',
    body: 'Snel na ontvangst terug, gekalibreerd, gecertificeerd en klaar voor gebruik in jouw werkplaats.',
  },
];

const faq = [
  {
    q: 'Hoeveel meetpunten gebruiken jullie bij kalibratie?',
    a: '5 punten: 20%, 40%, 60%, 80% en 100% van het nominale bereik, met minimaal 3 herhalingen per punt.',
    html: false,
  },
  {
    q: 'Welke typen momentsleutels kalibreren jullie?',
    a: 'Alle Type I (indicerend) en Type II (instellend) instrumenten conform ISO 6789:2017 en 2003. Van balksleutels tot digitale kliksleutels en alles daartussenin.',
    html: false,
  },
  {
    q: 'Moet ik mijn sleutel opsturen of kunnen jullie op locatie kalibreren?',
    a: 'Opsturen is de standaard. Heb je een grotere batch? Neem even contact op, dan kijken we wat we voor je kunnen regelen.',
    html: false,
  },
  {
    q: 'Hoe snel ontvang ik mijn certificaat?',
    a: 'Snel na ontvangst van je sleutel sturen we je het certificaat per e-mail.',
    html: false,
  },
  {
    q: 'Mijn kwaliteitshandboek vereist ISO-kalibratie, voldoen jullie hieraan?',
    a: 'Ja. Wij kalibreren conform <a href="/diensten/iso-6789-certificering">ISO 6789:2017 en 2003</a> Type I en II, met traceerbare referentieapparatuur en een geldig certificaat.',
    html: true,
  },
];
---

<Base
  title="Momentsleutel laten kalibreren | Dutch Torque Service"
  description="Laat je momentsleutel kalibreren op 5 meetpunten conform ISO 6789:2017 en 2003. Protocol + certificaat inbegrepen. Bel +31(0)6-131 72 774."
  canonicalPath="/diensten/momentsleutel-kalibratie"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <NavIsland currentPage="diensten" />

  <main>

    <!-- ══════════════════════════════════════
         HERO
    ══════════════════════════════════════ -->
    <PageSection class="hero-section">
        <div class="hero-inner">
          <!-- Eyebrow -->
          <div class="sec-eyebrow" data-animate>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Diensten</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>

          <h1 class="hero-h1" data-animate data-animate-delay="0.08">
            Momentsleutel laten kalibreren.
          </h1>

          <p class="hero-subtitle" data-animate data-animate-delay="0.16">
            Kalibratie op 5 meetpunten conform ISO 6789:2017 en 2003.<br />
            Stuur je sleutel op, snel terug met volledig protocol.
          </p>

          <div class="hero-ctas" data-animate data-animate-delay="0.22">
            <a href="#proces" class="btn btn-primary">Plan kalibratie</a>
            <a href="/diensten" class="btn btn-outline">Bekijk diensten</a>
          </div>

          <!-- Stats badges -->
          <div class="hero-badges" data-animate data-animate-delay="0.30">
            <span class="badge" style="background:rgba(122,175,196,0.10); border:1px solid rgba(122,175,196,0.28); color:#7AAFC4;">±2% Gegarandeerd</span>
            <span class="badge" style="background:rgba(122,175,196,0.10); border:1px solid rgba(122,175,196,0.28); color:#7AAFC4;">Snelle Doorlooptijd</span>
            <span class="badge" style="background:rgba(122,175,196,0.10); border:1px solid rgba(122,175,196,0.28); color:#7AAFC4;">ISO 6789:2017 en 2003</span>
          </div>
        </div>
    </PageSection>

    <!-- WHAT IS X. CHAT UI -->
    <PageSection>
      <ChatExplainer
        question="Wat is momentsleutel kalibratie eigenlijk?"
        answer="Momentsleutel kalibratie is het meten van de werkelijke koppelwaarden van jouw sleutel versus de ingestelde waarden. We leggen elk meetpunt vast in een protocol conform ISO 6789:2017 en 2003, zodat je exact weet of jouw sleutel binnen onze ±2% servicegarantie valt (ruim binnen de ±4% ISO-tolerantie). Het resultaat is een <a href='/diensten/iso-6789-certificering'>ISO 6789:2017 en 2003 certificaat</a> dat je gewoon in je kwaliteitssysteem legt."
        accent="#7AAFC4"
        reactions={[
          { emoji: '🎯', count: 18 },
          { emoji: '📐', count: 11 },
          { emoji: '✅', count: 24 },
        ]}
      />
    </PageSection>

    <!-- ══════════════════════════════════════
         PROCESS
    ══════════════════════════════════════ -->
    <PageSection class="[background:rgba(14,17,24,0.5)]">
        <div class="sec-head" data-animate>
          <div class="sec-eyebrow">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Ons proces</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 id="proces" class="sec-title">Hoe wij een momentsleutel kalibreren, stap voor stap.</h2>
        </div>

        <div class="steps-grid">
          {steps.map((step, i) => (
            <div class="step-card" data-animate data-animate-delay={String(i * 0.08)}>
              <div class="step-number" style={`color:${accent};`}>{step.n}</div>
              <h3 class="step-title">{step.title}</h3>
              {step.html
                ? <p class="step-body" set:html={step.body} />
                : <p class="step-body">{step.body}</p>
              }
            </div>
          ))}
        </div>
    </PageSection>

    <!-- ══════════════════════════════════════
         WHAT'S INCLUDED
    ══════════════════════════════════════ -->
    <PageSection>
        <div class="sec-head" data-animate>
          <div class="sec-eyebrow">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Inbegrepen</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="sec-title">Wat zit er standaard bij?</h2>
        </div>

        <div class="table-wrap" data-animate data-animate-delay="0.08">
          <table class="incl-table">
            <thead>
              <tr>
                <th>Inbegrepen</th>
                <th>Details</th>
              </tr>
            </thead>
            <tbody>
              {included.map(row => (
                <tr>
                  <td>
                    <span class="incl-check" style={`color:${accent};`}>✓</span>
                    {row.html
                      ? <span set:html={row.item} />
                      : row.item
                    }
                  </td>
                  <td class="incl-detail">{row.detail}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
    </PageSection>

    <!-- ══════════════════════════════════════
         WHY DTS
    ══════════════════════════════════════ -->
    <PageSection class="[background:rgba(14,17,24,0.5)]">
        <div class="sec-head" data-animate>
          <div class="sec-eyebrow">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Waarom DTS?</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="sec-title">Waarom monteurs DTS vertrouwen.</h2>
        </div>

        <div class="value-grid">
          {whyCards.map((card, i) => {
            const Tag = card.link ? 'a' : 'div';
            const props = card.link ? { href: card.link } : {};
            return (
              <Tag
                {...props}
                class="value-card"
                data-animate
                data-animate-delay={String(i * 0.12)}
                style={`--accent: ${card.accent};`}
              >
                <div class="vc-top">
                  <span class="vc-num" aria-hidden="true">{card.number}</span>
                  <div class="vc-icon" aria-hidden="true">
                    <Fragment set:html={card.icon} />
                  </div>
                </div>
                <div class="vc-rule"></div>
                <p class="vc-tagline">{card.tagline}</p>
                <h3 class="vc-title">{card.title}</h3>
                <p class="vc-body">{card.body}</p>
                <div class="vc-corner" aria-hidden="true"></div>
              </Tag>
            );
          })}
        </div>
    </PageSection>

    <!-- ══════════════════════════════════════
         FAQ
    ══════════════════════════════════════ -->
    <PageSection>
        <div class="sec-head" data-animate>
          <div class="sec-eyebrow">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">FAQ</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="sec-title">Veelgestelde vragen over momentsleutel kalibreren.</h2>
        </div>

        <div class="faq-list" data-animate data-animate-delay="0.08">
          {faq.map(item => (
            <details>
              <summary>{item.q}</summary>
              {item.html
                ? <div class="faq-body" set:html={item.a} />
                : <div class="faq-body">{item.a}</div>
              }
            </details>
          ))}
        </div>
    </PageSection>

    <!-- ══════════════════════════════════════
         CTA
    ══════════════════════════════════════ -->
    <PageSection>
        <div class="sec-head sec-head--flush" data-animate>
          <div class="sec-eyebrow">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Direct starten</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="sec-title">Momentsleutel laten kalibreren? Stuur hem op.</h2>
          <p class="sec-sub">
            Bel of mail. Stuur je sleutel op naar ons lab in Riethoven (Noord-Brabant), landelijk op te sturen, snel na ontvangst gekalibreerd en onderweg terug.
          </p>
          <div class="sec-ctas">
            <a href="tel:+31613172774" class="btn btn-primary">Bel +31(0)6-131 72 774</a>
            <a href="mailto:info@dutchtorqueservice.nl" class="btn btn-outline">Stuur een e-mail</a>
          </div>
        </div>
    </PageSection>

  </main>

  <FooterDTS />

</Base>

<style>
  /* ── Hero ── */
  .hero-section {
    padding-top: clamp(7rem, 14vw, 11rem);
  }
  .hero-inner {
    max-width: 780px;
    margin-inline: auto;
    text-align: center;
  }
  .hero-h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: #fff;
    margin-bottom: 1.75rem;
  }
  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.7;
    color: #8EAAB8;
    margin-bottom: 2.5rem;
    max-width: 60ch;
    margin-inline: auto;
    text-align: center;
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    margin-bottom: 3rem;
    justify-content: center;
  }
  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    justify-content: center;
  }

  .body-text {
    font-size: 0.975rem;
    line-height: 1.8;
    color: #8EAAB8;
  }

  /* ── What is it ── */
  .def-card {
    background: #0E1118;
    border: 1px solid rgba(122,175,196,0.14);
    border-radius: 1.5rem;
    padding: clamp(1.5rem, 3vw, 2.5rem);
    max-width: 820px;
  }

  /* ── Steps ── */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.25rem;
  }
  .step-card {
    background: #0E1118;
    border: 1px solid rgba(122,175,196,0.14);
    border-radius: 1.5rem;
    padding: 1.75rem;
    position: relative;
    isolation: isolate;
    overflow: hidden;
    transition: border-color 0.35s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
                box-shadow 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .step-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 110%, rgba(122,175,196,0.10) 0%, transparent 65%);
    opacity: 0;
    transition: opacity 0.45s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
    z-index: 0;
    border-radius: inherit;
  }
  .step-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: -60%;
    width: 40%;
    height: 100%;
    background: linear-gradient(
      115deg,
      transparent 0%,
      rgba(255,255,255,0.05) 45%,
      rgba(255,255,255,0.09) 50%,
      rgba(255,255,255,0.05) 55%,
      transparent 100%
    );
    transform: skewX(-18deg);
