---
import Base from '../../layouts/Base.astro';
import NavIsland from '../../components/modules/NavIsland.astro';
import FooterDTS from '../../components/modules/FooterDTS.astro';
import PageSection from '../../components/ui/PageSection.astro';
import ChatExplainer from '../../components/modules/ChatExplainer.astro';

const accent = '#7AAFC4';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Kalibratie momentsleutel",
  "name": "Momentsleutel Kalibratie",
  "provider": { "@id": "https://www.dutchtorqueservice.nl/#business" },
  "description": "Momentsleutel kalibratie op 5 meetpunten conform ISO 6789:2017. Volledig protocol inbegrepen, binnen 48 uur terug. Snap-On dealer.",
  "areaServed": "NL",
  "url": "https://www.dutchtorqueservice.nl/diensten/momentsleutel-kalibratie"
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Hoeveel meetpunten gebruiken jullie bij kalibratie?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "5 punten: 20%, 40%, 60%, 80% en 100% van het nominale bereik, met minimaal 3 herhalingen per punt."
      }
    },
    {
      "@type": "Question",
      "name": "Welke typen momentsleutels kalibreren jullie?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Alle Type I (indicerend) en Type II (instellend) instrumenten conform ISO 6789:2017. Van balksleutels tot digitale kliksleutels en alles daartussenin."
      }
    },
    {
      "@type": "Question",
      "name": "Moet ik mijn sleutel opsturen of kunnen jullie op locatie kalibreren?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Opsturen is de standaard. Heb je een grotere batch? Neem even contact op — dan kijken we wat we voor je kunnen regelen."
      }
    },
    {
      "@type": "Question",
      "name": "Hoe snel ontvang ik mijn certificaat?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Binnen 48 uur na ontvangst van je sleutel sturen we je het certificaat per e-mail."
      }
    },
    {
      "@type": "Question",
      "name": "Mijn kwaliteitshandboek vereist ISO-kalibratie — voldoen jullie hieraan?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ja. Wij kalibreren conform ISO 6789:2017 Type I en II, met traceerbare referentieapparatuur en een geldig certificaat."
      }
    }
  ]
};

const steps = [
  {
    n: '01',
    title: 'Ontvangst & registratie',
    body: 'We registreren jouw sleutel met merk, type, serienummer en het te kalibreren bereik.',
    html: false,
  },
  {
    n: '02',
    title: 'Visuele inspectie',
    body: 'Controle op mechanische schade, slijtage of corrosie vóór de meting. Ernstige schade? Dan verwijzen we door naar <a href="/diensten/momentsleutel-reparatie">momentsleutel reparatie</a>.',
    html: true,
  },
  {
    n: '03',
    title: 'As-found meting',
    body: 'Kalibratie op 5 meetpunten (≥20%, 40%, 60%, 80%, 100% van het bereik) voor de ingreep. Drie herhalingen per punt.',
    html: false,
  },
  {
    n: '04',
    title: 'Justering indien nodig',
    body: 'Als de afwijking buiten tolerantie valt, <a href="/diensten/momentsleutel-justeren">laten we de sleutel justeren</a> voordat de as-left meting plaatsvindt.',
    html: true,
  },
  {
    n: '05',
    title: 'Protocol & certificaat',
    body: 'Volledig kalibratieprotocol met as-found, as-left, gebruikte referentieapparatuur en aanbevolen interval voor de volgende kalibratie.',
    html: false,
  },
];

const included = [
  { item: 'As-found meting',        detail: 'Meetwaarden vóór ingreep, 5 punten × 3 herhalingen', html: false },
  { item: 'As-left meting',         detail: 'Meetwaarden na ingreep', html: false },
  { item: 'Referentieapparatuur',   detail: 'Traceerbaar, eigen kalibratiestatus vermeld', html: false },
  { item: '<a href="/diensten/iso-6789-certificering">Kalibratiecertificaat</a>', detail: 'Conform ISO 6789:2017', html: true },
  { item: 'Volgende kalibratietermijn', detail: 'Aanbeveling op basis van gebruik en belasting', html: false },
  { item: 'E-mailbevestiging',      detail: 'Direct na afronding', html: false },
];

const whyCards = [
  {
    accent: '#7AAFC4',
    icon: '±2%',
    iconHtml: false,
    title: '±2% Gegarandeerd',
    body: 'Elk instrument wordt gekalibreerd binnen de ±2% tolerantie conform ISO 6789:2017. Onze referentieapparatuur is traceerbaar naar nationale ijknormen.',
    html: false,
  },
  {
    accent: '#C4AF64',
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>',
    iconHtml: true,
    title: 'Snap-On Dealer',
    body: 'Als geautoriseerde <a href="/merken/snap-on-kalibratie">Snap-On kalibratie Noord-Brabant</a> dealer kalibreren we Snap-On momentsleutels met de juiste merkspecifieke referentieapparatuur — direct, zonder tussenschakel.',
    html: true,
  },
  {
    accent: '#64C48A',
    icon: '48u',
    iconHtml: false,
    title: '48-uurs doorlooptijd',
    body: 'Standaard binnen 48 uur na ontvangst terug — gekalibreerd, gecertificeerd en klaar voor gebruik.',
    html: false,
  },
];

const faq = [
  {
    q: 'Hoeveel meetpunten gebruiken jullie bij kalibratie?',
    a: '5 punten: 20%, 40%, 60%, 80% en 100% van het nominale bereik, met minimaal 3 herhalingen per punt.',
    html: false,
  },
  {
    q: 'Welke typen momentsleutels kalibreren jullie?',
    a: 'Alle Type I (indicerend) en Type II (instellend) instrumenten conform ISO 6789:2017. Van balksleutels tot digitale kliksleutels en alles daartussenin.',
    html: false,
  },
  {
    q: 'Moet ik mijn sleutel opsturen of kunnen jullie op locatie kalibreren?',
    a: 'Opsturen is de standaard. Heb je een grotere batch? Neem even contact op — dan kijken we wat we voor je kunnen regelen.',
    html: false,
  },
  {
    q: 'Hoe snel ontvang ik mijn certificaat?',
    a: 'Binnen 48 uur na ontvangst van je sleutel sturen we je het certificaat per e-mail.',
    html: false,
  },
  {
    q: 'Mijn kwaliteitshandboek vereist ISO-kalibratie — voldoen jullie hieraan?',
    a: 'Ja. Wij kalibreren conform <a href="/diensten/iso-6789-certificering">ISO 6789:2017</a> Type I en II, met traceerbare referentieapparatuur en een geldig certificaat.',
    html: true,
  },
];
---

<Base
  title="Momentsleutel Laten Kalibreren | Dutch Torque Service"
  description="Laat je momentsleutel kalibreren op 5 meetpunten conform ISO 6789:2017. Protocol + certificaat inbegrepen, binnen 48 uur terug. Bel +31(0)6-131 72 774."
  canonicalPath="/diensten/momentsleutel-kalibratie"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <NavIsland currentPage="diensten" />

  <main>

    <!-- ══════════════════════════════════════
         HERO
    ══════════════════════════════════════ -->
    <PageSection class="hero-section">
        <div class="hero-inner">
          <!-- Eyebrow -->
          <div class="eyebrow-row" data-animate>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Diensten</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>

          <h1 class="hero-h1" data-animate data-animate-delay="0.08">
            Momentsleutel Laten Kalibreren.
          </h1>

          <p class="hero-subtitle" data-animate data-animate-delay="0.16">
            Kalibratie op 5 meetpunten conform ISO 6789:2017.<br />
            Stuur je sleutel op — binnen 48 uur terug met volledig protocol.
          </p>

          <div class="hero-ctas" data-animate data-animate-delay="0.22">
            <a href="#proces" class="btn btn-primary">Plan kalibratie</a>
            <a href="/werk" class="btn btn-outline">Bekijk werk</a>
          </div>

          <!-- Stats badges -->
          <div class="hero-badges" data-animate data-animate-delay="0.30">
            <span class="badge" style="background:rgba(122,175,196,0.10); border:1px solid rgba(122,175,196,0.28); color:#7AAFC4;">±2% Gegarandeerd</span>
            <span class="badge" style="background:rgba(122,175,196,0.10); border:1px solid rgba(122,175,196,0.28); color:#7AAFC4;">48u Doorlooptijd</span>
            <span class="badge" style="background:rgba(122,175,196,0.10); border:1px solid rgba(122,175,196,0.28); color:#7AAFC4;">ISO 6789:2017</span>
          </div>
        </div>
    </PageSection>

    <!-- WHAT IS X — CHAT UI -->
    <PageSection>
      <ChatExplainer
        question="Wat is momentsleutel kalibratie eigenlijk?"
        answer="Momentsleutel kalibratie is het meten van de werkelijke koppelwaarden van jouw sleutel versus de ingestelde waarden. We leggen elk meetpunt vast in een protocol conform ISO 6789:2017 — zodat je exact weet of jouw sleutel binnen de ±2% tolerantie zit. Het resultaat is een <a href='/diensten/iso-6789-certificering'>ISO 6789:2017 certificaat</a> dat je gewoon in je kwaliteitssysteem legt."
        accent="#7AAFC4"
        reactions={[
          { emoji: '🎯', count: 18 },
          { emoji: '📐', count: 11 },
          { emoji: '✅', count: 24 },
        ]}
      />
    </PageSection>

    <!-- ══════════════════════════════════════
         PROCESS
    ══════════════════════════════════════ -->
    <PageSection class="[background:rgba(14,17,24,0.5)]">
        <div class="section-header" data-animate>
          <div class="eyebrow-row">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Ons proces</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 id="proces" class="section-h2">Hoe wij een momentsleutel kalibreren — stap voor stap.</h2>
        </div>

        <div class="steps-grid">
          {steps.map((step, i) => (
            <div class="step-card" data-animate data-animate-delay={String(i * 0.08)}>
              <div class="step-number" style={`color:${accent};`}>{step.n}</div>
              <h3 class="step-title">{step.title}</h3>
              {step.html
                ? <p class="step-body" set:html={step.body} />
                : <p class="step-body">{step.body}</p>
              }
            </div>
          ))}
        </div>
    </PageSection>

    <!-- ══════════════════════════════════════
         WHAT'S INCLUDED
    ══════════════════════════════════════ -->
    <PageSection>
        <div class="section-header" data-animate>
          <div class="eyebrow-row">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Inbegrepen</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="section-h2">Wat zit er standaard bij?</h2>
        </div>

        <div class="table-wrap" data-animate data-animate-delay="0.08">
          <table class="incl-table">
            <thead>
              <tr>
                <th>Inbegrepen</th>
                <th>Details</th>
              </tr>
            </thead>
            <tbody>
              {included.map(row => (
                <tr>
                  <td>
                    <span class="incl-check" style={`color:${accent};`}>✓</span>
                    {row.html
                      ? <span set:html={row.item} />
                      : row.item
                    }
                  </td>
                  <td class="incl-detail">{row.detail}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
    </PageSection>

    <!-- ══════════════════════════════════════
         WHY DTS
    ══════════════════════════════════════ -->
    <PageSection class="[background:rgba(14,17,24,0.5)]">
        <div class="section-header" data-animate>
          <div class="eyebrow-row">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Waarom DTS?</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="section-h2">Waarom monteurs DTS vertrouwen.</h2>
        </div>

        <div class="why-grid">
          {whyCards.map((card, i) => (
            <div class="why-card" data-animate data-animate-delay={String(i * 0.10)} style={`border-color:rgba(${card.accent === '#7AAFC4' ? '122,175,196' : card.accent === '#C4AF64' ? '196,175,100' : '100,196,138'},0.14);`}>
              {card.iconHtml
                ? <div class="why-icon" style={`color:${card.accent};`} set:html={card.icon} />
                : <div class="why-icon" style={`color:${card.accent};`}>{card.icon}</div>
              }
              <h3 class="why-title" style={`color:${card.accent};`}>{card.title}</h3>
              {card.html
                ? <p class="why-body" set:html={card.body} />
                : <p class="why-body">{card.body}</p>
              }
            </div>
          ))}
        </div>
    </PageSection>

    <!-- ══════════════════════════════════════
         FAQ
    ══════════════════════════════════════ -->
    <PageSection>
        <div class="section-header" data-animate>
          <div class="eyebrow-row">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">FAQ</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="section-h2">Veelgestelde vragen over momentsleutel kalibreren.</h2>
        </div>

        <div class="faq-list" data-animate data-animate-delay="0.08">
          {faq.map(item => (
            <details>
              <summary>{item.q}</summary>
              {item.html
                ? <div class="faq-body" set:html={item.a} />
                : <div class="faq-body">{item.a}</div>
              }
            </details>
          ))}
        </div>
    </PageSection>

    <!-- ══════════════════════════════════════
         CTA
    ══════════════════════════════════════ -->
    <PageSection class="cta-section">
        <div class="cta-inner" data-animate>
          <div class="eyebrow-row">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Direct starten</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4; display:inline-block;"></span>
          </div>
          <h2 class="section-h2">Momentsleutel laten kalibreren? Stuur hem op.</h2>
          <p class="body-text cta-body">
            Bel of mail. Stuur je sleutel op naar ons lab in Riethoven (Noord-Brabant) — landelijk op te sturen, binnen 48 uur na ontvangst gekalibreerd en onderweg terug.
          </p>
          <div class="cta-btns">
            <a href="tel:+31613172774" class="btn btn-primary">Bel +31(0)6-131 72 774</a>
            <a href="mailto:info@dutchtorqueservice.nl" class="btn btn-outline">Stuur een e-mail</a>
          </div>
        </div>
    </PageSection>

  </main>

  <FooterDTS />

</Base>

<style>
  /* ── Hero ── */
  .hero-section {
    padding-top: clamp(7rem, 14vw, 11rem);
  }
  .hero-inner {
    max-width: 780px;
  }
  .eyebrow-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .hero-h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: #fff;
    margin-bottom: 1.75rem;
  }
  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.7;
    color: #8EAAB8;
    margin-bottom: 2.5rem;
    max-width: 60ch;
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    margin-bottom: 3rem;
  }
  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }

  /* ── Section common ── */
  .section-header {
    margin-bottom: 3.5rem;
  }
  .section-h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: #E8F0F4;
    margin-top: 1rem;
  }
  .body-text {
    font-size: 0.975rem;
    line-height: 1.8;
    color: #8EAAB8;
  }

  /* ── What is it ── */
  .def-card {
    background: #0E1118;
    border: 1px solid rgba(122,175,196,0.14);
    border-radius: 1.5rem;
    padding: clamp(1.5rem, 3vw, 2.5rem);
    max-width: 820px;
  }

  /* ── Steps ── */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.25rem;
  }
  .step-card {
    background: #0E1118;
    border: 1px solid rgba(122,175,196,0.14);
    border-radius: 1.5rem;
    padding: 1.75rem;
  }
  .step-number {
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  .step-title {
    font-size: 1rem;
    font-weight: 700;
    color: #E8F0F4;
    margin-bottom: 0.625rem;
  }
  .step-body {
    font-size: 0.875rem;
    line-height: 1.75;
    color: #8EAAB8;
  }
  .step-body a { color: #7AAFC4; text-decoration: underline; }

  /* ── Included table ── */
  .table-wrap {
    overflow-x: auto;
  }
  .incl-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }
  .incl-table thead th {
    text-align: left;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    padding: 0 1rem 1rem 1rem;
    border-bottom: 1px solid rgba(122,175,196,0.12);
  }
  .incl-table tbody tr {
    border-bottom: 1px solid rgba(122,175,196,0.07);
    transition: background 0.15s;
  }
  .incl-table tbody tr:hover {
    background: rgba(122,175,196,0.04);
  }
  .incl-table tbody td {
    padding: 1rem;
    color: #C8D8E0;
    font-weight: 500;
    vertical-align: middle;
  }
  .incl-check {
    margin-right: 0.625rem;
    font-weight: 700;
  }
  .incl-detail {
    color: #6A8A98 !important;
    font-weight: 400 !important;
    font-size: 0.85rem;
  }
  .incl-table a { color: #7AAFC4; text-decoration: underline; }

  /* ── Why DTS ── */
  .why-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
  }
  .why-card {
    background: #0E1118;
    border: 1px solid rgba(122,175,196,0.14);
    border-radius: 1.5rem;
    padding: 2rem;
    transition: border-color 0.2s;
  }
  .why-card:hover {
    border-color: rgba(122,175,196,0.30);
  }
  .why-icon {
    font-size: 1.5rem;
    font-weight: 900;
    margin-bottom: 1rem;
  }
  .why-title {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.625rem;
  }
  .why-body {
    font-size: 0.875rem;
    line-height: 1.75;
    color: #8EAAB8;
  }
  .why-body a { color: #7AAFC4; text-decoration: underline; }

  /* ── FAQ ── */
  .faq-list {
    max-width: 820px;
  }
  details {
    border: 1px solid rgba(122,175,196,0.12);
    border-radius: 1rem;
    background: #0E1118;
    margin-bottom: 0.75rem;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  details[open] {
    border-color: rgba(122,175,196,0.30);
  }
  summary {
    padding: 1.25rem 1.5rem;
    cursor: pointer;
    font-weight: 700;
    color: #E8F0F4;
    font-size: 0.975rem;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }
  summary::-webkit-details-marker { display: none; }
  summary::after {
    content: '+';
    color: #7AAFC4;
    font-size: 1.25rem;
    font-weight: 300;
    flex-shrink: 0;
    transition: transform 0.25s;
  }
  details[open] summary::after { transform: rotate(45deg); }
  .faq-body {
    padding: 0 1.5rem 1.5rem;
    font-size: 0.9rem;
    line-height: 1.8;
    color: #8EAAB8;
  }
  .faq-body a { color: #7AAFC4; text-decoration: underline; }

  /* ── CTA ── */
  .cta-section {
    border-top: 1px solid rgba(122,175,196,0.08);
  }
  .cta-inner {
    max-width: 680px;
