---
import Base from '../layouts/Base.astro';
import NavIsland from '../components/modules/NavIsland.astro';
import FooterDTS from '../components/modules/FooterDTS.astro';
import PageSection from '../components/ui/PageSection.astro';

const contactSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact Dutch Torque Service",
  "url": "https://www.dutchtorqueservice.nl/contact",
  "mainEntity": {
    "@type": "LocalBusiness",
    "@id": "https://www.dutchtorqueservice.nl/#business",
    "name": "Dutch Torque Service",
    "description": "Momentsleutel kalibratie, reparatie en ISO 6789:2017 en 2003 certificering in Riethoven, Noord-Brabant.",
    "url": "https://www.dutchtorqueservice.nl",
    "telephone": "+31613172774",
    "email": "info@dutchtorqueservice.nl",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Tonterstraat 42",
      "addressLocality": "Riethoven",
      "addressRegion": "Noord-Brabant",
      "postalCode": "5561 AN",
      "addressCountry": "NL"
    },
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
        "opens": "08:00",
        "closes": "17:00"
      }
    ]
  }
};
---

<Base
  title="Momentsleutel Kalibratie Riethoven | Dutch Torque Service"
  description="Vragen over momentsleutel kalibratie, reparatie of certificering in Riethoven? Bel +31(0)6-131 72 774. Ma–Vr 08:00–17:00. Snel geholpen."
  canonicalPath="/contact"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(contactSchema)} />

  <NavIsland currentPage="contact" />

  <main>
    <!-- HERO -->
    <PageSection hero center animate>
        <div class="sec-eyebrow">
          <span class="w-8 h-px opacity-75" style="background:#7AAFC4;"></span>
          <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Contact</span>
          <span class="w-8 h-px opacity-75" style="background:#7AAFC4;"></span>
        </div>
        <h1 class="font-black tracking-tight text-white" style="font-size: clamp(2.5rem, 6vw, 4.5rem); line-height: 1.05;">
          Kalibratie of reparatie? Bel ons.
        </h1>
        <p class="sec-sub">
          Vragen over <a href="/diensten/momentsleutel-kalibratie" style="color:#7AAFC4; text-decoration:underline;">kalibratie</a>, <a href="/diensten/momentsleutel-reparatie" style="color:#7AAFC4; text-decoration:underline;">reparatie</a> of <a href="/diensten/iso-6789-certificering" style="color:#7AAFC4; text-decoration:underline;">certificering</a>? Bel ons direct, bereikbaar Ma–Vr 08:00–17:00. Je weet binnen één gesprek waar je aan toe bent.
        </p>
    </PageSection>

    <!-- CONTACT CONTENT -->
    <PageSection>
        <div class="page-grid gap-y-12">

          <!-- Left: contact details -->
          <div class="col-span-12 lg:col-span-5" data-animate data-animate-from="left">

            <!-- Section label -->
            <div class="sec-head" style="align-items: flex-start; text-align: left; margin-bottom: clamp(1.5rem, 2.5vw, 2.25rem);">
              <div class="sec-eyebrow">
                <span class="w-6 h-px" style="background:#7AAFC4; opacity:0.8;"></span>
                <span class="text-[10px] font-semibold tracking-[0.3em] uppercase" style="color:#7AAFC4;">Contactgegevens</span>
              </div>
            </div>

            {[
              {
                icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M3 5a2 2 0 012-2h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V5z" stroke="#7AAFC4" stroke-width="1.5"/><path d="M3 9h18" stroke="#7AAFC4" stroke-width="1.5"/><path d="M9 21V9" stroke="#7AAFC4" stroke-width="1.5"/></svg>`,
                label: 'Adres',
                value: 'Tonterstraat 42\n5561 AN Riethoven\nNoord-Brabant, Nederland',
              },
              {
                icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z" stroke="#7AAFC4" stroke-width="1.5"/></svg>`,
                label: 'Telefoon',
                value: '+31(0)6-131 72 774',
                href: 'tel:+31613172774',
              },
              {
                icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="#7AAFC4" stroke-width="1.5"/><path d="M22 6l-10 7L2 6" stroke="#7AAFC4" stroke-width="1.5"/></svg>`,
                label: 'E-mail',
                value: 'info@dutchtorqueservice.nl',
                href: 'mailto:info@dutchtorqueservice.nl',
              },
              {
                icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="#7AAFC4" stroke-width="1.5"/><path d="M12 6v6l4 2" stroke="#7AAFC4" stroke-width="1.5" stroke-linecap="round"/></svg>`,
                label: 'Openingstijden',
                value: 'Ma\u2013Vr: 08:00 \u2013 17:00\nZa\u2013Zo: Gesloten',
              },
              {
                icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="2" stroke="#7AAFC4" stroke-width="1.5"/><path d="M3 9h18M9 21V9" stroke="#7AAFC4" stroke-width="1.5"/></svg>`,
                label: 'KvK-nummer',
                value: '67183360',
              },
            ].map(item => (
              <div class="contact-item">
                <div class="contact-icon-wrap">
                  <Fragment set:html={item.icon} />
                </div>
                <div class="contact-item-body">
                  <p class="contact-label">{item.label}</p>
                  {item.href ? (
                    <a href={item.href} class="contact-value contact-link">{item.value}</a>
                  ) : (
                    <p class="contact-value">{item.value}</p>
                  )}
                </div>
              </div>
            ))}

            <p class="mt-4 text-xs" style="color: rgba(148,168,178,0.85); line-height: 1.6;">
              Erkend opvolger van Van Rootselaar Technic bv. per 1 januari 2026.
            </p>
          </div>

          <!-- Right: CTA card + map placeholder -->
          <div class="col-span-12 lg:col-span-6 lg:col-start-7 flex flex-col gap-6" data-animate data-animate-from="right">

            <!-- Call CTA card -->
            <div class="relative overflow-hidden" style="padding: 1.75rem 2rem; border-radius: 1.5rem; background: linear-gradient(140deg, rgba(122,175,196,0.08) 0%, transparent 55%), #0E1118; border: 1px solid rgba(122,175,196,0.18); box-shadow: 0 4px 32px rgba(0,0,0,0.35);">
              <div class="absolute top-0 right-0 w-48 h-48 rounded-full" style="background: radial-gradient(circle, rgba(122,175,196,0.06) 0%, transparent 70%); transform: translate(30%, -30%);"></div>
              <div class="sec-eyebrow" style="margin-bottom: 0.75rem;">
                <span class="w-6 h-px" style="background:#7AAFC4; opacity:0.8;"></span>
                <span class="text-[10px] font-semibold tracking-[0.3em] uppercase" style="color: rgba(122,175,196,0.65);">Snelste weg</span>
              </div>
              <h3 class="text-2xl font-black text-white" style="margin-bottom: 0.75rem;">Bel direct.</h3>
              <p class="text-sm leading-relaxed" style="color: #8EAAB8; margin-bottom: clamp(1rem, 2vw, 1.5rem);">Geen wachttijden, geen formulieren. Bel ons en plan jouw kalibratie of reparatie direct in.</p>
              <a href="tel:+31613172774" class="btn btn-primary w-full justify-center">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="1.5"/></svg>
                Bel ons: +31(0)6-131 72 774
              </a>
              <a href="mailto:info@dutchtorqueservice.nl" class="btn btn-outline w-full justify-center" style="margin-top: 0.625rem;">
                Stuur een e-mail
              </a>
            </div>

            <!-- Live Google Map embed (no API key, ?output=embed endpoint) -->
            <div class="contact-map">
              <iframe
                title="Locatie Dutch Torque Service, Tonterstraat 42, Riethoven"
                src="https://maps.google.com/maps?q=Tonterstraat+42+5561+AN+Riethoven&z=15&output=embed"
                width="100%"
                height="100%"
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                allowfullscreen
                style="border:0; display:block; filter: grayscale(0.25) contrast(1.05);"
              ></iframe>
              <a
                href="https://www.google.com/maps/dir/?api=1&destination=Tonterstraat+42+5561+AN+Riethoven"
                target="_blank"
                rel="noopener noreferrer"
                class="contact-map-cta"
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M3 11l18-8-8 18-2-8-8-2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
                </svg>
                Route plannen
              </a>
            </div>
          </div>

        </div>
    </PageSection>
  </main>

  <FooterDTS />
</Base>

<style>
  /* ── Contact detail cards ── */
  .contact-item {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.75rem 1rem;
    background: rgba(122,175,196,0.03);
    border: 1px solid rgba(122,175,196,0.09);
    border-radius: 0.875rem;
    margin-bottom: 0.375rem;
    isolation: isolate;
    transition: border-color 0.3s cubic-bezier(0.22, 1, 0.36, 1),
                background 0.3s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
                box-shadow 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  /* Slide right + glow halo on hover */
  .contact-item:hover {
    border-color: rgba(122,175,196,0.28);
    background: rgba(122,175,196,0.07);
    transform: translateX(3px);
    box-shadow: 0 4px 20px rgba(122,175,196,0.08);
  }

  .contact-icon-wrap {
    flex-shrink: 0;
    width:  36px;
    height: 36px;
    border-radius: 9px;
    background: rgba(122,175,196,0.1);
    border: 1px solid rgba(122,175,196,0.18);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s cubic-bezier(0.22, 1, 0.36, 1),
                box-shadow 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .contact-item:hover .contact-icon-wrap {
    background: rgba(122,175,196,0.18);
    box-shadow: 0 0 12px rgba(122,175,196,0.22);
  }

  .contact-item-body {
    flex: 1;
    min-width: 0;
  }

  .contact-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(122,175,196,0.55);
    margin-bottom: 0.4rem;
  }

  .contact-value {
    font-size: 0.975rem;
    line-height: 1.6;
    color: #C4D0D8;
    white-space: pre-line;
    display: block;
  }

  /* Embedded Google Map */
  .contact-map {
    position: relative;
    overflow: hidden;
    border-radius: 1.5rem;
    aspect-ratio: 16 / 9;
    background: #0E1118;
    border: 1px solid rgba(122,175,196,0.18);
    box-shadow: 0 4px 32px rgba(0,0,0,0.35);
  }
  .contact-map iframe { width: 100%; height: 100%; }
  .contact-map-cta {
    position: absolute;
    bottom: 0.875rem;
    right: 0.875rem;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.875rem;
    background: rgba(8,9,11,0.9);
    border: 1px solid rgba(122,175,196,0.35);
    border-radius: 0.6rem;
    color: #B8D4E0;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: background 0.25s, border-color 0.25s, color 0.25s, transform 0.2s;
  }
  .contact-map-cta:hover,
  .contact-map-cta:focus-visible {
    background: rgba(122,175,196,0.18);
    border-color: rgba(122,175,196,0.65);
    color: #fff;
    transform: translateY(-2px);
  }
  .contact-map-cta:focus-visible {
    outline: 2px solid rgba(122,175,196,0.7);
    outline-offset: 2px;
  }

  /* Clickable contact links, animated underline grows L→R */
  .contact-link {
    text-decoration: none;
    background-image: linear-gradient(#7AAFC4, #9BC8D9);
    background-repeat: no-repeat;
    background-size: 0% 1px;
    background-position: left bottom;
    transition: color 0.25s cubic-bezier(0.22, 1, 0.36, 1),
                background-size 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .contact-link:hover,
  .contact-link:focus-visible {
    color: #fff;
    background-size: 100% 1px;
  }
  .contact-link:focus-visible {
    outline: 2px solid rgba(122,175,196,0.55);
    outline-offset: 3px;
    border-radius: 2px;
  }
</style>
