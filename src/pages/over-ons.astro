---
import Base from '../layouts/Base.astro';
import NavIsland from '../components/modules/NavIsland.astro';
import FooterDTS from '../components/modules/FooterDTS.astro';
---

<Base
  title="Over Ons | Dutch Torque Service — Riethoven, Noord-Brabant"
  description="Dutch Torque Service is opgericht door Jan-Piet Schulte en zonen als opvolger van Van Rootselaar Technic bv. Geautoriseerd Snap-On dealer, ISO 6789 gecertificeerd, gevestigd in Riethoven."
  canonicalPath="/over-ons"
>
  <NavIsland currentPage="over-ons" />

  <main>
    <!-- PAGE HERO -->
    <section class="relative overflow-hidden" style="padding-top: clamp(8rem, 14vw, 11rem); padding-bottom: clamp(4rem, 6vw, 6rem); padding-inline: var(--page-px); background: transparent;">
      <div class="absolute top-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, rgba(122,175,196,0.18), transparent);"></div>

      <div class="page-container text-center" data-animate>
        <div class="flex items-center justify-center gap-3 mb-6">
          <span class="w-8 h-px opacity-75" style="background:#7AAFC4;"></span>
          <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Over Ons</span>
          <span class="w-8 h-px opacity-75" style="background:#7AAFC4;"></span>
        </div>
        <h1 class="font-black tracking-tight text-white mb-6" style="font-size: clamp(2.5rem, 6vw, 4.5rem); line-height: 1.05;">
          Vakmanschap<br/>dat telt.
        </h1>
        <p class="mx-auto" style="font-size: clamp(1rem, 1.6vw, 1.15rem); line-height: 1.75; color: #9AAEB8; max-width: 52ch;">
          Dutch Torque Service is opgericht vanuit een passie voor precisie en een erfenis van vertrouwen.
          Wij zijn de erkende voortzetter van Van Rootselaar Technic bv. — een naam die tientallen jaren synoniem stond voor betrouwbare momentsleutel service in Nederland.
        </p>
      </div>
    </section>

    <!-- STORY SECTION -->
    <section class="relative page-wrap overflow-hidden">
      <div class="absolute top-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, rgba(122,175,196,0.18), transparent);"></div>
      <div class="page-container">
        <div class="page-grid items-center gap-y-16">

          <!-- Image placeholder left -->
          <div class="col-span-12 lg:col-span-5" data-animate data-animate-from="left">
            <div class="relative" style="border-radius: 1.5rem; overflow: hidden; aspect-ratio: 4/3; background: #0E1118; border: 1px solid rgba(122,175,196,0.14);">
              <div class="absolute inset-0" style="background-image: linear-gradient(rgba(122,175,196,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(122,175,196,0.04) 1px, transparent 1px); background-size: 28px 28px;"></div>
              <div class="absolute inset-0 flex flex-col items-center justify-center gap-4">
                <svg width="72" height="72" viewBox="0 0 80 80" fill="none" style="opacity:0.35;">
                  <circle cx="20" cy="40" r="14" stroke="#7AAFC4" stroke-width="1.5"/>
                  <circle cx="20" cy="40" r="7" stroke="#7AAFC4" stroke-width="1"/>
                  <rect x="34" y="34" width="32" height="12" rx="3" stroke="#7AAFC4" stroke-width="1.5"/>
                  <rect x="66" y="31" width="10" height="18" rx="4" stroke="#7AAFC4" stroke-width="1.5"/>
                </svg>
                <p class="text-xs tracking-[0.25em] uppercase font-medium" style="color:rgba(122,175,196,0.45);">Teamfoto volgt binnenkort</p>
              </div>
              <!-- Corner brackets -->
              <div class="absolute -top-2 -left-2 w-5 h-5" style="border-top: 2px solid rgba(122,175,196,0.5); border-left: 2px solid rgba(122,175,196,0.5); border-radius: 4px 0 0 0;"></div>
              <div class="absolute -top-2 -right-2 w-5 h-5" style="border-top: 2px solid rgba(122,175,196,0.5); border-right: 2px solid rgba(122,175,196,0.5); border-radius: 0 4px 0 0;"></div>
              <div class="absolute -bottom-2 -left-2 w-5 h-5" style="border-bottom: 2px solid rgba(122,175,196,0.5); border-left: 2px solid rgba(122,175,196,0.5); border-radius: 0 0 0 4px;"></div>
              <div class="absolute -bottom-2 -right-2 w-5 h-5" style="border-bottom: 2px solid rgba(122,175,196,0.5); border-right: 2px solid rgba(122,175,196,0.5); border-radius: 0 0 4px 0;"></div>
            </div>
          </div>

          <!-- Text right -->
          <div class="col-span-12 lg:col-span-6 lg:col-start-7" data-animate data-animate-from="right">
            <div class="flex items-center gap-3 mb-5">
              <span class="w-6 h-px" style="background:#7AAFC4; opacity:0.8;"></span>
              <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Ons Verhaal</span>
            </div>
            <h2 class="text-3xl md:text-4xl font-black tracking-tight text-white mb-6" style="line-height:1.1;">
              Voortzetter van een bewezen naam.
            </h2>
            <p class="mb-5" style="font-size: 1.05rem; line-height: 1.8; color: #C4D0D8;">
              Per 1 januari 2026 heeft Dutch Torque Service via een warme overdracht de momentsleutelwerkzaamheden overgenomen van <strong style="color:#fff;">Van Rootselaar Technic bv.</strong> te Stiens — een bedrijf dat jarenlang het vertrouwen van werkplaatsen in binnen- en buitenland verdiende.
            </p>
            <p class="mb-5" style="font-size: 0.975rem; line-height: 1.8; color: #A8B8C4;">
              Ger van Rootselaar heeft ons persoonlijk het vertrouwen gegeven om zijn erfenis voort te zetten. Dat nemen wij serieus: dezelfde zorgvuldige werkwijze, dezelfde moderne test- en controleapparatuur, dezelfde nauwkeurigheidseisen — maar nu vanuit Riethoven, Noord-Brabant.
            </p>
            <p style="font-size: 0.975rem; line-height: 1.8; color: #A8B8C4;">
              Naast onze kalibratie- en reparatiediensten runnen wij een officieel <strong style="color:#C4D0D8;">Snap-On dealerbedrijf</strong> voor de regio Zuid-Noord-Brabant. Zo combineren wij de beste gereedschapskennis met gecertificeerde precisiediensten.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- TEAM / VALUES -->
    <section class="relative page-wrap overflow-hidden">
      <div class="absolute top-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, rgba(122,175,196,0.18), transparent);"></div>
      <div class="page-container">

        <div class="text-center mb-16" data-animate>
          <div class="flex items-center justify-center gap-3 mb-5">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Het Team</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4;"></span>
          </div>
          <h2 class="text-4xl md:text-5xl font-black tracking-tight text-white">
            Schulte &amp; Zonen.
          </h2>
        </div>

        <!-- 3 value cards -->
        <div class="grid gap-5" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));">
          {[
            {
              num: '01',
              title: 'Familiebedrijf',
              body: 'Jan-Piet Schulte en zijn zonen vormen de kern van DTS. Persoonlijk contact, directe communicatie en verantwoordelijkheidsgevoel staan centraal in alles wat wij doen.',
              accent: '#7AAFC4',
            },
            {
              num: '02',
              title: 'Snap-On Dealer',
              body: 'Als geautoriseerd Snap-On dealer voor Zuid-Noord-Brabant hebben wij toegang tot originele onderdelen en de nieuwste kalibratiemethoden van de marktleider in professioneel gereedschap.',
              accent: '#C4AF64',
            },
            {
              num: '03',
              title: 'ISO Gecertificeerd',
              body: 'Al onze kalibratiewerkzaamheden worden uitgevoerd conform ISO 6789:2017. Je ontvangt een volledig protocol met meetwaarden voor en na — audit-proof en transparant.',
              accent: '#64C48A',
            },
          ].map((v, i) => (
            <div
              class="team-card relative"
              data-animate
              data-animate-delay={String(i * 0.1)}
              style={`--accent: ${v.accent}; padding: 2.5rem; border-radius: 1.5rem; background: linear-gradient(140deg, color-mix(in srgb, ${v.accent} 8%, transparent) 0%, transparent 55%), #0E1118; border: 1px solid color-mix(in srgb, ${v.accent} 18%, transparent); box-shadow: 0 2px 16px rgba(0,0,0,0.28); transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s;`}
            >
              <span style={`font-size: 3rem; font-weight: 900; line-height: 1; letter-spacing: -0.04em; color: ${v.accent}; opacity: 0.55; display: block; margin-bottom: 1.5rem;`}>{v.num}</span>
              <h3 class="text-xl font-black text-white mb-3" style="letter-spacing: -0.01em;">{v.title}</h3>
              <p style="font-size: 0.9rem; line-height: 1.75; color: #8EAAB8;">{v.body}</p>
              <div class="absolute bottom-5 right-5 w-4 h-4" style={`border-right: 1.5px solid ${v.accent}; border-bottom: 1.5px solid ${v.accent}; border-radius: 0 0 4px 0; opacity: 0.3;`}></div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CREDENTIALS / STATS BAR -->
    <section class="relative page-wrap overflow-hidden">
      <div class="absolute top-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, rgba(122,175,196,0.18), transparent);"></div>
      <div class="page-container">
        <div class="grid gap-8" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));">
          {[
            { value: '±2%',   label: 'Nauwkeurigheidsgarantie', color: '#7AAFC4' },
            { value: '48u',   label: 'Max. doorlooptijd',         color: '#C4AF64' },
            { value: 'ISO',   label: '6789:2017 Gecertificeerd',  color: '#64C48A' },
            { value: '100%',  label: 'Gedocumenteerd protocol',   color: '#C48A64' },
          ].map((s, i) => (
            <div class="text-center" data-animate data-animate-delay={String(i * 0.08)}>
              <div style={`font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; line-height: 1; letter-spacing: -0.03em; color: ${s.color}; margin-bottom: 0.5rem;`}>{s.value}</div>
              <div style="font-size: 0.65rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(184,196,204,0.5);">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="relative page-wrap overflow-hidden">
      <div class="absolute top-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, rgba(122,175,196,0.18), transparent);"></div>
      <div class="page-container text-center" data-animate>
        <h2 class="text-3xl md:text-4xl font-black tracking-tight text-white mb-4">Klaar om samen te werken?</h2>
        <p class="mb-8 mx-auto" style="color: #9AAEB8; max-width: 44ch; font-size: 1.05rem; line-height: 1.75;">
          Stuur ons een bericht of bel direct. We reageren snel en geven altijd een eerlijk advies.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/contact" class="btn btn-primary">
            Neem contact op
            <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="tel:+31613172774" class="btn btn-outline">+31(0)6-131 72 774</a>
        </div>
      </div>
    </section>
  </main>

  <FooterDTS />
</Base>
