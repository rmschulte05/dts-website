---
import Base from '../layouts/Base.astro';
import { Image } from 'astro:assets';
import NavIsland from '../components/modules/NavIsland.astro';
import FooterDTS from '../components/modules/FooterDTS.astro';
import PageSection from '../components/ui/PageSection.astro';
import jpPortrait from '../img/jp/JP.png';

// ProfilePage + AboutPage schema referencing the Person already declared in Base.astro.
// Helps AI engines anchor "Jan-Piet Schulte" + "Dutch Torque Service" as a single entity graph.
const aboutPageSchema = {
  "@context": "https://schema.org",
  "@type": ["AboutPage", "ProfilePage"],
  "url": "https://www.dutchtorqueservice.nl/over-ons",
  "name": "Over Dutch Torque Service",
  "inLanguage": "nl-NL",
  "about": { "@id": "https://www.dutchtorqueservice.nl/#business" },
  "mainEntity": { "@id": "https://www.dutchtorqueservice.nl/#jan-piet-schulte" },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.dutchtorqueservice.nl/" },
      { "@type": "ListItem", "position": 2, "name": "Over Ons", "item": "https://www.dutchtorqueservice.nl/over-ons" }
    ]
  }
};
---

<Base
  title="Over Ons | Dutch Torque Service. Riethoven, Noord-Brabant"
  description="Dutch Torque Service is opgericht door Jan-Piet Schulte en zonen als opvolger van Van Rootselaar Technic bv. Snap-On dealer en ISO 6789 specialist."
  canonicalPath="/over-ons"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(aboutPageSchema)} />

  <NavIsland currentPage="over-ons" />

  <main>
    <!-- PAGE HERO -->
    <PageSection hero center animate>
        <div class="sec-eyebrow">
          <span class="w-8 h-px opacity-75" style="background:#7AAFC4;"></span>
          <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Over Ons</span>
          <span class="w-8 h-px opacity-75" style="background:#7AAFC4;"></span>
        </div>
        <h1 class="font-black tracking-tight text-white" style="font-size: clamp(2.5rem, 6vw, 4.5rem); line-height: 1.1;">
          Vakmanschap<br/>
          <span style="background: linear-gradient(90deg, #7AAFC4 0%, #9BC5D8 50%, #7AAFC4 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">dat telt.</span>
        </h1>
        <p class="sec-sub">
          Dutch Torque Service is opgericht vanuit een passie voor precisie en een erfenis van vertrouwen.
          Wij zijn de erkende voortzetter van Van Rootselaar Technic bv., een naam die tientallen jaren synoniem stond voor betrouwbare momentsleutel service in de Benelux.
        </p>
    </PageSection>

    <!-- STORY SECTION -->
    <PageSection>
        <div class="page-grid items-center gap-y-16">

          <!-- Founder portrait left -->
          <div class="col-span-12 lg:col-span-5" data-animate data-animate-from="left">
            <div class="founder-frame relative" style="border-radius: 1.5rem; overflow: hidden; aspect-ratio: 4/3; background: #0E1118; border: 1px solid rgba(122,175,196,0.18);">
              <Image
                src={jpPortrait}
                alt="Jan-Piet Schulte, oprichter van Dutch Torque Service"
                widths={[480, 720, 960]}
                sizes="(min-width: 1024px) 40vw, 100vw"
                format="webp"
                quality={84}
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover"
              />
              <!-- Bottom gradient for caption legibility -->
              <div class="absolute inset-x-0 bottom-0 h-2/5 pointer-events-none" style="background: linear-gradient(to top, rgba(8,9,11,0.85) 0%, rgba(8,9,11,0.45) 50%, transparent 100%);"></div>
              <!-- Founder caption -->
              <div class="founder-meta">
                <span class="founder-meta-eyebrow">
                  Oprichter
                </span>
                <p class="founder-meta-name">Jan-Piet Schulte</p>
              </div>
              <!-- Corner brackets -->
              <div class="absolute -top-2 -left-2 w-5 h-5" style="border-top: 2px solid rgba(122,175,196,0.5); border-left: 2px solid rgba(122,175,196,0.5); border-radius: 4px 0 0 0;"></div>
              <div class="absolute -top-2 -right-2 w-5 h-5" style="border-top: 2px solid rgba(122,175,196,0.5); border-right: 2px solid rgba(122,175,196,0.5); border-radius: 0 4px 0 0;"></div>
              <div class="absolute -bottom-2 -left-2 w-5 h-5" style="border-bottom: 2px solid rgba(122,175,196,0.5); border-left: 2px solid rgba(122,175,196,0.5); border-radius: 0 0 0 4px;"></div>
              <div class="absolute -bottom-2 -right-2 w-5 h-5" style="border-bottom: 2px solid rgba(122,175,196,0.5); border-right: 2px solid rgba(122,175,196,0.5); border-radius: 0 0 4px 0;"></div>
            </div>
          </div>

          <!-- Text right -->
          <div class="col-span-12 lg:col-span-6 lg:col-start-7" data-animate data-animate-from="right">
            <div class="flex items-center gap-3 mb-5">
              <span class="w-6 h-px" style="background:#7AAFC4; opacity:0.8;"></span>
              <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Ons Verhaal</span>
            </div>
            <h2 class="text-3xl md:text-4xl font-black tracking-tight text-white mb-6" style="line-height:1.1;">
              Voortzetter van een bewezen naam.
            </h2>
            <p class="mb-5" style="font-size: 1.05rem; line-height: 1.8; color: #C4D0D8;">
              Per 1 januari 2026 heeft Dutch Torque Service via een warme overdracht de momentsleutelwerkzaamheden overgenomen van <strong style="color:#fff;">Van Rootselaar Technic bv.</strong> te Stiens, een bedrijf dat jarenlang het vertrouwen van werkplaatsen in binnen- en buitenland verdiende.
            </p>
            <p class="mb-5" style="font-size: 0.975rem; line-height: 1.8; color: #A8B8C4;">
              Ger van Rootselaar heeft ons persoonlijk het vertrouwen gegeven om zijn erfenis voort te zetten. Dat nemen wij serieus: dezelfde zorgvuldige werkwijze, dezelfde moderne test- en controleapparatuur, dezelfde nauwkeurigheidseisen, maar nu vanuit Riethoven, Noord-Brabant.
            </p>
            <p style="font-size: 0.975rem; line-height: 1.8; color: #A8B8C4;">
              Naast onze kalibratie- en reparatiediensten runnen wij een officieel <strong style="color:#C4D0D8;">Snap-On dealerbedrijf</strong> voor de regio Zuid-Noord-Brabant. Zo combineren wij de beste gereedschapskennis met gecertificeerde precisiediensten.
            </p>
          </div>
        </div>
    </PageSection>

    <!-- TEAM / VALUES -->
    <PageSection>
        <div class="text-center" data-animate style="margin-bottom: clamp(4rem, 8vw, 7rem);">
          <div class="flex items-center justify-center gap-3 mb-5">
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4;"></span>
            <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Het Team</span>
            <span class="w-8 h-px opacity-75" style="background:#7AAFC4;"></span>
          </div>
          <h2 class="text-4xl md:text-5xl font-black tracking-tight text-white" style="margin-bottom: 2rem;">
            Schulte &amp; Zonen.
          </h2>
          <div class="flex items-center justify-center gap-2" aria-hidden="true" style="opacity: 0.55;">
            <span style="width: 48px; height: 1px; background: linear-gradient(90deg, transparent, #7AAFC4);"></span>
            <span style="width: 5px; height: 5px; border-radius: 50%; background: #7AAFC4; box-shadow: 0 0 12px rgba(122,175,196,0.6);"></span>
            <span style="width: 48px; height: 1px; background: linear-gradient(90deg, #7AAFC4, transparent);"></span>
          </div>
        </div>

        <!-- 3 value cards -->
        <div class="grid gap-5" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));">
          {[
            {
              num: '01',
              title: 'Familiebedrijf',
              body: 'Jan-Piet Schulte en zijn zonen vormen de kern van DTS. Persoonlijk contact, directe communicatie en verantwoordelijkheidsgevoel staan centraal in alles wat wij doen.',
              accent: '#7AAFC4',
            },
            {
              num: '02',
              title: 'Snap-On Dealer',
              body: 'Als geautoriseerd Snap-On dealer voor Zuid-Noord-Brabant hebben wij toegang tot originele onderdelen en de nieuwste kalibratiemethoden van de marktleider in professioneel gereedschap.',
              accent: '#C4AF64',
            },
            {
              num: '03',
              title: 'ISO Gecertificeerd',
              body: 'Al onze kalibratiewerkzaamheden worden uitgevoerd conform ISO 6789:2017 en 2003. Je ontvangt een volledig protocol met meetwaarden voor en na, audit-proof en transparant.',
              accent: '#64C48A',
            },
          ].map((v, i) => (
            <div
              class="team-card relative"
              data-animate
              data-animate-delay={String(i * 0.1)}
              style={`--accent: ${v.accent}; padding: 2.5rem; border-radius: 1.5rem; background: linear-gradient(140deg, color-mix(in srgb, ${v.accent} 8%, transparent) 0%, transparent 55%), #0E1118; border: 1px solid color-mix(in srgb, ${v.accent} 18%, transparent); box-shadow: 0 2px 16px rgba(0,0,0,0.28); transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s;`}
            >
              <span style={`font-size: 3rem; font-weight: 900; line-height: 1; letter-spacing: -0.04em; color: ${v.accent}; opacity: 0.55; display: block; margin-bottom: 1.5rem;`}>{v.num}</span>
              <h3 class="text-xl font-black text-white mb-3" style="letter-spacing: -0.01em;">{v.title}</h3>
              <p style="font-size: 0.9rem; line-height: 1.75; color: #8EAAB8;">{v.body}</p>
              <div class="absolute bottom-5 right-5 w-4 h-4" style={`border-right: 1.5px solid ${v.accent}; border-bottom: 1.5px solid ${v.accent}; border-radius: 0 0 4px 0; opacity: 0.3;`}></div>
            </div>
          ))}
        </div>
    </PageSection>

    <!-- CREDENTIALS / STATS BAR -->
    <PageSection>
        <div class="grid gap-8" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));">
          {[
            { value: '±2%',   label: 'Servicegarantie (ISO-norm: ±4%)', color: '#7AAFC4' },
            { value: 'Snelle',  label: 'Doorlooptijd',               color: '#C4AF64' },
            { value: 'ISO',   label: '6789:2017 en 2003 Gecertificeerd',  color: '#64C48A' },
            { value: '100%',  label: 'Gedocumenteerd protocol',   color: '#C48A64' },
          ].map((s, i) => (
            <div class="text-center" data-animate data-animate-delay={String(i * 0.08)}>
              <div style={`font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; line-height: 1; letter-spacing: -0.03em; color: ${s.color}; margin-bottom: 0.5rem;`}>{s.value}</div>
              <div style="font-size: 0.65rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(184,196,204,0.5);">{s.label}</div>
            </div>
          ))}
        </div>
    </PageSection>

    <!-- CTA -->
    <PageSection center animate>
        <h2 class="text-3xl md:text-4xl font-black tracking-tight text-white mb-4">Klaar om samen te werken?</h2>
        <p class="mb-8 mx-auto" style="color: #9AAEB8; max-width: 44ch; font-size: 1.05rem; line-height: 1.75;">
          Stuur ons een bericht of bel direct. We reageren snel en geven altijd een eerlijk advies.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/contact" class="btn btn-primary">
            Neem contact op
            <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="tel:+31613172774" class="btn btn-outline">+31(0)6-131 72 774</a>
        </div>
    </PageSection>
  </main>

  <FooterDTS />
</Base>

<style>
  /* ── Team / value cards, lift + accent glow halo ── */
  .team-card {
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
                box-shadow 0.35s cubic-bezier(0.22, 1, 0.36, 1),
                border-color 0.35s cubic-bezier(0.22, 1, 0.36, 1) !important;
  }
  .team-card:hover {
    transform: translateY(-5px) !important;
    box-shadow: 0 16px 48px rgba(0,0,0,0.40),
                0 0 0 1px color-mix(in srgb, var(--accent) 30%, transparent),
                0 0 32px color-mix(in srgb, var(--accent) 12%, transparent) !important;
    border-color: color-mix(in srgb, var(--accent) 32%, transparent) !important;
  }

  /* ── Founder portrait caption overlay ── */
  .founder-meta {
    position: absolute;
    left: clamp(1rem, 2.5vw, 1.5rem);
    right: clamp(1rem, 2.5vw, 1.5rem);
    bottom: clamp(1rem, 2.5vw, 1.5rem);
    color: #fff;
    z-index: 1;
  }
  .founder-meta-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(155, 200, 217, 0.95);
    margin-bottom: 0.4rem;
  }
  .founder-meta-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #64C48A;
    box-shadow: 0 0 6px rgba(100, 196, 138, 0.7);
  }
  .founder-meta-name {
    font-size: clamp(1.15rem, 2vw, 1.4rem);
    font-weight: 900;
    letter-spacing: -0.01em;
    line-height: 1.1;
    margin-bottom: 0.25rem;
  }
  .founder-meta-role {
    font-size: 0.78rem;
    color: #B8C4CC;
    line-height: 1.4;
  }

  /* ── Google Maps link, animated underline L→R ── */
  a[href*="maps.google"] {
    color: rgba(122,175,196,0.5);
    text-decoration: none;
    background-image: linear-gradient(#7AAFC4, #9BC8D9);
    background-repeat: no-repeat;
    background-size: 0% 1px;
    background-position: left bottom;
    transition: color 0.25s cubic-bezier(0.22, 1, 0.36, 1),
                background-size 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  a[href*="maps.google"]:hover,
  a[href*="maps.google"]:focus-visible {
    color: #7AAFC4;
    background-size: 100% 1px;
  }
</style>
