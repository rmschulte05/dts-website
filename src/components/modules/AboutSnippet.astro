---
import { Image } from 'astro:assets';
import jpPortrait from '../../img/jp/JP.png';

interface Props {
  imageSrc?: string;
  imageAlt?: string;
}
const {
  imageSrc,
  imageAlt = 'Jan-Piet Schulte, oprichter van Dutch Torque Service in Riethoven, Noord-Brabant',
} = Astro.props;
---

<section id="over-ons" class="about-section relative page-wrap overflow-hidden">

  <!-- Separator -->
  <div class="absolute top-0 left-0 right-0 h-px"
    style="background: linear-gradient(90deg, transparent 0%, rgba(122,175,196,0.2) 40%, rgba(122,175,196,0.2) 60%, transparent 100%);"></div>

  <div class="relative page-container">

    <!-- Section label, centred -->
    <div class="about-header type-stack flex flex-col items-center text-center" data-animate>
      <div class="flex items-center gap-3">
        <span class="w-8 h-px opacity-75" style="background:#7AAFC4;"></span>
        <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Over Ons</span>
        <span class="w-8 h-px opacity-75" style="background:#7AAFC4;"></span>
      </div>
      <h2 class="text-4xl md:text-5xl font-black leading-[1.05] tracking-tight text-white">
        Vakmanschap in elke Newton&nbsp;meter.
      </h2>
    </div>

    <!-- Visual divider between header and content -->
    <div class="about-divider" aria-hidden="true">
      <span class="about-divider-line"></span>
      <span class="about-divider-dot"></span>
      <span class="about-divider-line"></span>
    </div>

    <!-- 12-col grid: image = 5 cols, text = 6 cols, 1 col gap -->
    <div class="page-grid items-center">

      <!-- Image, 5 cols on desktop -->
      <div class="about-image-wrap col-span-12 lg:col-span-5" data-animate data-animate-from="left">
        <div class="image-frame relative">
          {imageSrc ? (
            <img
              src={imageSrc}
              alt={imageAlt}
              class="img-card w-full aspect-[4/3] object-cover"
              loading="lazy"
              decoding="async"
            />
          ) : (
            <Image
              src={jpPortrait}
              alt={imageAlt}
              widths={[480, 720, 960]}
              sizes="(min-width: 1024px) 40vw, 100vw"
              format="webp"
              quality={82}
              loading="lazy"
              decoding="async"
              class="img-card w-full aspect-[4/3] object-cover"
            />
          )}
          <!-- Bottom gradient + founder caption (matches over-ons) -->
          {!imageSrc && (
            <>
              <div class="founder-fade" aria-hidden="true"></div>
              <div class="founder-meta">
                <span class="founder-meta-eyebrow">Oprichter</span>
                <p class="founder-meta-name">Jan-Piet Schulte</p>
              </div>
            </>
          )}
          <!-- Corner brackets -->
          <div class="corner corner-tl absolute -top-3 -left-3 w-6 h-6 border-t-2 border-l-2 rounded-tl" style="border-color:rgba(122,175,196,0.55);"></div>
          <div class="corner corner-tr absolute -top-3 -right-3 w-6 h-6 border-t-2 border-r-2 rounded-tr" style="border-color:rgba(122,175,196,0.55);"></div>
          <div class="corner corner-bl absolute -bottom-3 -left-3 w-6 h-6 border-b-2 border-l-2 rounded-bl" style="border-color:rgba(122,175,196,0.55);"></div>
          <div class="corner corner-br absolute -bottom-3 -right-3 w-6 h-6 border-b-2 border-r-2 rounded-br" style="border-color:rgba(122,175,196,0.55);"></div>
        </div>
      </div>

      <!-- Text, 6 cols on desktop, starts at col 7 (1-col gap after image) -->
      <div class="about-text col-span-12 lg:col-span-6 lg:col-start-7" data-animate data-animate-from="right">
        <p class="text-base md:text-lg leading-relaxed mb-6 md:mb-8" style="color:#C4D0D8;">
          Dutch Torque Service is dé specialist voor professionele momentsleutel kalibratie, reparatie
          en officiële certificering conform ISO&nbsp;6789:2017 en 2003. Als geautoriseerd Snap-On dealer en erkende
          opvolger van Van Rootselaar Technic bv. brengen wij een reputatie van tientallen jaren
          naar werkplaatsen in Nederland.
        </p>
        <p class="text-base leading-relaxed" style="color:#A8B8C4;">
          Je ontvangt altijd een volledig kalibratieprotocol met meetresultaten voor én na de service ,
          inclusief de gebruikte referentieapparatuur en je volgende kalibratietermijn.
          Audit-proof documentatie, geen verrassingen.
        </p>

        <!-- Trust tags, 2×2 grid on mobile, wrapping row on desktop -->
        <div class="about-tags">
          {['ISO 6789:2017 en 2003', 'Type I & II', 'Snap-On Dealer', 'Gecertificeerd'].map(tag => (
            <span class="badge" style="background: rgba(122,175,196,0.1); border: 1px solid rgba(122,175,196,0.22); color:#7AAFC4;">
              {tag}
            </span>
          ))}
        </div>

        <!-- Button, wrapped in its own row for clear separation -->
        <div class="about-btn-row">
          <a href="/over-ons" class="btn btn-outline">
            Over ons
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-section {
    position: relative;
    z-index: 1;
    background: transparent;
    padding-top: clamp(4rem, 8vw, 9rem);
  }

  /* ── Title block: generous breathing room below the heading ── */
  .about-header {
    margin-bottom: clamp(2rem, 5vw, 4rem);
  }

  /* ── Visual divider: sits between the heading and the image/text grid ── */
  .about-divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: clamp(2rem, 5vw, 4rem);
  }
  .about-divider-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(122,175,196,0.18), transparent);
  }
  .about-divider-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: rgba(122,175,196,0.45);
    flex-shrink: 0;
  }

  /* ── Trust tags: 2×2 grid on mobile, flex row on desktop ── */
  .about-tags {
    display: grid;
    margin-top: 10px;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
    margin-bottom: 0;
  }
  .about-tags .badge {
    justify-content: center;
    text-align: center;
    width: 100%;
  }
  @media (min-width: 640px) {
    .about-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
    }
    .about-tags .badge {
      width: auto;
      justify-content: flex-start;
    }
  }

  /* ── Button row: sits in its own block with strong top margin ── */
  .about-btn-row {
    margin-top: clamp(1.5rem, 3vw, 2.5rem);
    padding-top: clamp(1.25rem, 2.5vw, 2rem);
    border-top: 1px solid rgba(122,175,196,0.1);
  }

  .image-placeholder {
    background: transparent;
    border: 1px solid rgba(122, 175, 196, 0.2);
  }

  /* ── Founder portrait caption overlay (matches over-ons) ── */
  .image-frame { position: relative; }
  .img-card { border-radius: 1.5rem; }
  .founder-fade {
    position: absolute;
    inset: auto 0 0 0;
    height: 40%;
    border-radius: 0 0 1.5rem 1.5rem;
    pointer-events: none;
    background: linear-gradient(to top,
      rgba(8, 9, 11, 0.85) 0%,
      rgba(8, 9, 11, 0.45) 50%,
      transparent 100%);
    z-index: 1;
  }
  .founder-meta {
    position: absolute;
    left: clamp(1rem, 2.5vw, 1.5rem);
    right: clamp(1rem, 2.5vw, 1.5rem);
    bottom: clamp(1rem, 2.5vw, 1.5rem);
    color: #fff;
    z-index: 2;
  }
  .founder-meta-eyebrow {
    display: inline-block;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(155, 200, 217, 0.95);
    margin-bottom: 0.4rem;
  }
  .founder-meta-name {
    font-size: clamp(1.15rem, 2vw, 1.4rem);
    font-weight: 900;
    letter-spacing: -0.01em;
    line-height: 1.1;
  }
  .placeholder-grid {
    background-image:
      linear-gradient(rgba(122,175,196,0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(122,175,196,0.05) 1px, transparent 1px);
    background-size: 28px 28px;
  }
</style>
