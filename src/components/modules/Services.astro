---
const services = [
  {
    id: 'justeren',
    title: 'Justeren',
    subtitle: 'Instelling & Afstelling',
    description: 'Na slijtage of een val stellen wij je momentsleutel opnieuw in op de juiste waarden.',
    icon: `<svg width="36" height="36" viewBox="0 0 28 28" fill="none">
      <circle cx="14" cy="14" r="9" stroke="currentColor" stroke-width="1.5"/>
      <circle cx="14" cy="14" r="3" stroke="currentColor" stroke-width="1.5"/>
      <line x1="14" y1="2"  x2="14" y2="6"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="14" y1="22" x2="14" y2="26" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="2"  y1="14" x2="6"  y2="14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="22" y1="14" x2="26" y2="14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>`,
  },
  {
    id: 'kalibratie',
    title: 'Kalibratie',
    subtitle: 'ISO 6789 Nauwkeurig',
    description: 'Kalibratie op 5 meetpunten over het volledige bereik, protocol inbegrepen.',
    icon: `<svg width="36" height="36" viewBox="0 0 28 28" fill="none">
      <rect x="4" y="10" width="20" height="12" rx="2" stroke="currentColor" stroke-width="1.5"/>
      <line x1="4"  y1="16" x2="24" y2="16" stroke="currentColor" stroke-width="0.75" stroke-opacity="0.5"/>
      <line x1="8"  y1="10" x2="8"  y2="7"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="14" y1="10" x2="14" y2="5"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="20" y1="10" x2="20" y2="7"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="11" y1="10" x2="11" y2="8"  stroke="currentColor" stroke-width="1"   stroke-linecap="round" stroke-opacity="0.5"/>
      <line x1="17" y1="10" x2="17" y2="8"  stroke="currentColor" stroke-width="1"   stroke-linecap="round" stroke-opacity="0.5"/>
    </svg>`,
  },
  {
    id: 'reparatie',
    title: 'Reparatie',
    subtitle: 'Herstel & Revisie',
    description: 'Volledig demontage, reiniging en vervanging van slijtdelen. Hersteld als nieuw.',
    icon: `<svg width="36" height="36" viewBox="0 0 28 28" fill="none">
      <path d="M6 22L18 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <circle cx="21" cy="7"  r="4" stroke="currentColor" stroke-width="1.5"/>
      <path d="M18 10l3-3"   stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <circle cx="7"  cy="21" r="4" stroke="currentColor" stroke-width="1.5"/>
      <path d="M6 22l3-3"    stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>`,
  },
  {
    id: 'certificering',
    title: 'Certificering',
    subtitle: 'Officieel Certificaat',
    description: 'DTS-kalibratiecertificaat met meetwaarden, apparatuur en volgende kalibratietermijn.',
    icon: `<svg width="36" height="36" viewBox="0 0 28 28" fill="none">
      <rect x="4" y="4" width="20" height="20" rx="3" stroke="currentColor" stroke-width="1.5"/>
      <path d="M9 14l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>`,
  },
];
---

<section id="diensten" class="services-section relative page-wrap">

  <!-- Separator -->
  <div class="absolute top-0 left-0 right-0 h-px"
    style="background: linear-gradient(90deg, transparent, rgba(122,175,196,0.18), transparent);"></div>

  <div class="page-container">

    <!-- Header — centred -->
    <div class="type-stack text-center mb-16 md:mb-20" data-animate>
      <div class="flex items-center justify-center gap-3">
        <span class="w-8 h-px opacity-75" style="background:#7AAFC4;"></span>
        <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Wat wij doen</span>
        <span class="w-8 h-px opacity-75" style="background:#7AAFC4;"></span>
      </div>
      <h2 class="text-4xl md:text-5xl font-black leading-tight tracking-tight text-white max-w-xl mx-auto">
        Compleet gereedschap,<br/>altijd betrouwbaar.
      </h2>
    </div>

    <!-- 4 cards — 12-col grid: full → 6/6 → 3/3/3/3 -->
    <div class="page-grid">
      {services.map((svc, i) => (
        <div
          class="service-card col-span-12 sm:col-span-6 lg:col-span-3 flex flex-col p-8 md:p-9"
          data-animate
          data-animate-delay={String(i * 0.09)}
        >
          <!-- Number (top-right, very faint) -->
          <div class="flex items-start justify-between mb-6">
            <div class="service-icon" style="color:#7AAFC4;">
              <Fragment set:html={svc.icon} />
            </div>
            <span class="service-number text-4xl font-black leading-none" style="color:rgba(122,175,196,0.1);">
              {String(i + 1).padStart(2, '0')}
            </span>
          </div>

          <!-- Spacer pushes text to bottom -->
          <div class="flex-1"></div>

          <!-- Title + description -->
          <div>
            <p class="text-[10px] font-semibold tracking-[0.24em] uppercase mb-2" style="color:rgba(122,175,196,0.65);">
              {svc.subtitle}
            </p>
            <h3 class="text-xl md:text-2xl font-black text-white mb-3 leading-tight tracking-tight">
              {svc.title}
            </h3>
            <p class="text-sm leading-relaxed" style="color:#A8BAC2;">{svc.description}</p>
          </div>

          <!-- Bottom accent line (hover) -->
          <div class="service-line mt-5 h-0.5 w-0 rounded transition-all duration-500 ease-out"
            style="background: linear-gradient(90deg, #7AAFC4, transparent);"></div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services-section {
    position: relative;
    z-index: 1;
    background: transparent;
  }

  .service-card {
    /* Force square aspect ratio */
    aspect-ratio: 1 / 1;
    background: transparent;
    border: 1px solid rgba(122, 175, 196, 0.1);
    border-radius: 1.1rem;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
    cursor: default;
  }

  /* Hover via JS (mouseenter/leave) to avoid flicker — see script */
  .service-card.hovered {
    border-color: rgba(122, 175, 196, 0.3);
    box-shadow: 0 16px 44px rgba(0,0,0,0.35), 0 0 0 1px rgba(122,175,196,0.08);
  }
  .service-card.hovered .service-line { width: 100%; }
  .service-card.hovered .service-icon { color: #9BC5D8; }
  .service-card.hovered .service-number { color: rgba(122,175,196,0.22) !important; }

  .service-icon { transition: color 0.3s; }
</style>

<script>
  import gsap from 'gsap';

  // GSAP hover — avoids CSS transform hover-flicker
  document.querySelectorAll<HTMLElement>('.service-card').forEach(card => {
    card.addEventListener('mouseenter', () => {
      card.classList.add('hovered');
      gsap.to(card, { y: -5, duration: 0.3, ease: 'power2.out' });
    });
    card.addEventListener('mouseleave', () => {
      card.classList.remove('hovered');
      gsap.to(card, { y: 0, duration: 0.3, ease: 'power2.out' });
    });
  });
</script>
