---
const services = [
  {
    id: 'justeren',
    title: 'Justeren',
    subtitle: 'Instelling & Afstelling',
    description: 'Sleutel buiten tolerantie door slijtage of een val? Wij stellen je momentsleutel opnieuw in op de juiste Newton-meterwaarden over het volledige bereik — conform ISO\u00A06789:2017.',
    link: { href: '/diensten/momentsleutel-justeren', label: 'momentsleutel laten justeren' },
    accent: '#C4AF64',
    icon: `<svg width="32" height="32" viewBox="0 0 28 28" fill="none">
      <circle cx="14" cy="14" r="9" stroke="currentColor" stroke-width="1.5"/>
      <circle cx="14" cy="14" r="3" stroke="currentColor" stroke-width="1.5"/>
      <line x1="14" y1="2"  x2="14" y2="6"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="14" y1="22" x2="14" y2="26" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="2"  y1="14" x2="6"  y2="14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="22" y1="14" x2="26" y2="14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>`,
  },
  {
    id: 'kalibratie',
    title: 'Kalibratie',
    subtitle: 'ISO 6789:2017 Conform',
    description: 'Professionele momentsleutel kalibratie op 5 meetpunten over het volledige bereik. Volledig kalibratieprotocol conform ISO\u00A06789:2017 type\u00A0I en\u00A0II inbegrepen.',
    link: { href: '/diensten/momentsleutel-kalibratie', label: 'momentsleutel kalibreren laten' },
    accent: '#7AAFC4',
    icon: `<svg width="32" height="32" viewBox="0 0 28 28" fill="none">
      <rect x="4" y="10" width="20" height="12" rx="2" stroke="currentColor" stroke-width="1.5"/>
      <line x1="4"  y1="16" x2="24" y2="16" stroke="currentColor" stroke-width="0.75" stroke-opacity="0.5"/>
      <line x1="8"  y1="10" x2="8"  y2="7"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="14" y1="10" x2="14" y2="5"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="20" y1="10" x2="20" y2="7"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="11" y1="10" x2="11" y2="8"  stroke="currentColor" stroke-width="1"   stroke-linecap="round" stroke-opacity="0.5"/>
      <line x1="17" y1="10" x2="17" y2="8"  stroke="currentColor" stroke-width="1"   stroke-linecap="round" stroke-opacity="0.5"/>
    </svg>`,
  },
  {
    id: 'reparatie',
    title: 'Reparatie',
    subtitle: 'Herstel & Revisie',
    description: 'Volledige demontage, reiniging en vervanging van slijtdelen. Van Snap-On tot Stahlwille: wij herstellen jouw momentsleutel als nieuw — zonder de aanschafprijs van vervangen.',
    link: { href: '/diensten/momentsleutel-reparatie', label: 'momentsleutel reparatie' },
    accent: '#C48A64',
    icon: `<svg width="32" height="32" viewBox="0 0 28 28" fill="none">
      <path d="M6 22L18 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <circle cx="21" cy="7"  r="4" stroke="currentColor" stroke-width="1.5"/>
      <path d="M18 10l3-3"   stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <circle cx="7"  cy="21" r="4" stroke="currentColor" stroke-width="1.5"/>
      <path d="M6 22l3-3"    stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>`,
  },
  {
    id: 'certificering',
    title: 'Certificering',
    subtitle: 'Officieel Certificaat',
    description: 'Officieel DTS-kalibratiecertificaat met meetwaarden voor en na de service, gebruikte referentieapparatuur en volgende kalibratietermijn. Audit-proof voor ISO-gecertificeerde bedrijven.',
    link: { href: '/diensten/iso-6789-certificering', label: 'ISO 6789:2017 certificaat' },
    accent: '#64C48A',
    icon: `<svg width="32" height="32" viewBox="0 0 28 28" fill="none">
      <rect x="4" y="4" width="20" height="20" rx="3" stroke="currentColor" stroke-width="1.5"/>
      <path d="M9 14l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>`,
  },
];
---

<section id="diensten" class="services-section relative page-wrap">

  <!-- Separator -->
  <div class="absolute top-0 left-0 right-0 h-px"
    style="background: linear-gradient(90deg, transparent, rgba(122,175,196,0.18), transparent);"></div>

  <div class="page-container">

    <!-- Header -->
    <div class="svc-header" data-animate>
      <div class="flex items-center justify-center gap-3">
        <span class="w-8 h-px opacity-75" style="background:#7AAFC4;"></span>
        <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Wat wij doen</span>
        <span class="w-8 h-px opacity-75" style="background:#7AAFC4;"></span>
      </div>
      <h2 class="text-4xl md:text-5xl font-black leading-tight tracking-tight text-white max-w-xl mx-auto text-center">
        Kalibratie, reparatie<br/>en certificering.
      </h2>
    </div>

    <!-- 4 cards -->
    <div class="svc-grid">
      {services.map((svc, i) => (
        <div
          class="svc-card"
          data-animate
          data-animate-delay={String(i * 0.10)}
          style={`--accent: ${svc.accent};`}
        >
          <!-- Top: icon + number -->
          <div class="svc-top">
            <div class="svc-icon-wrap" aria-hidden="true">
              <div class="svc-icon">
                <Fragment set:html={svc.icon} />
              </div>
            </div>
            <span class="svc-number" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
          </div>

          <!-- Flex spacer -->
          <div class="flex-1 min-h-[2rem]"></div>

          <!-- Rule -->
          <div class="svc-rule"></div>

          <!-- Text -->
          <p class="svc-subtitle">{svc.subtitle}</p>
          <h3 class="svc-title">{svc.title}</h3>
          <p class="svc-body">{svc.description}</p>
          {svc.link && (
            <a href={svc.link.href} class="svc-link">{svc.link.label} <span class="svc-link-arrow" aria-hidden="true">→</span></a>
          )}

          <!-- Hover bottom bar -->
          <div class="svc-bar"></div>

          <!-- Corner bracket -->
          <div class="svc-corner"></div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services-section {
    position: relative;
    z-index: 1;
    background: transparent;
  }

  .svc-header {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    align-items: center;
    text-align: center;
    margin-bottom: clamp(3rem, 5vw, 4.5rem);
  }

  .svc-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 540px)  { .svc-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .svc-grid { grid-template-columns: repeat(4, 1fr); } }

  /* ── CARD ── */
  .svc-card {
    position: relative;
    padding: 2rem;
    border-radius: 1.5rem;
    border: 1px solid color-mix(in srgb, var(--accent) 20%, transparent);
    background:
      linear-gradient(145deg, color-mix(in srgb, var(--accent) 7%, transparent) 0%, transparent 55%),
      #0E1118;
    box-shadow: 0 2px 16px rgba(0,0,0,0.28);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    isolation: isolate;
    transition:
      border-color 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow   0.45s cubic-bezier(0.22, 1, 0.36, 1),
      transform    0.45s cubic-bezier(0.22, 1, 0.36, 1);
    cursor: default;
  }

  /* Accent glow halo — radial behind card content */
  .svc-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(
      ellipse 80% 60% at 50% 0%,
      color-mix(in srgb, var(--accent) 18%, transparent) 0%,
      transparent 70%
    );
    opacity: 0;
    transition: opacity 0.45s cubic-bezier(0.22, 1, 0.36, 1);
    z-index: -1;
    pointer-events: none;
  }

  /* Diagonal shine sweep */
  .svc-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: -60%;
    width: 40%;
    height: 100%;
    background: linear-gradient(
      115deg,
      transparent 0%,
      rgba(255,255,255,0.06) 45%,
      rgba(255,255,255,0.12) 50%,
      rgba(255,255,255,0.06) 55%,
      transparent 100%
    );
    transform: skewX(-18deg);
    transition: left 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
    z-index: 0;
  }

  .svc-card:hover,
  .svc-card:focus-visible {
    border-color: color-mix(in srgb, var(--accent) 70%, transparent);
    box-shadow:
      0 24px 64px rgba(0,0,0,0.55),
      0 0 48px color-mix(in srgb, var(--accent) 18%, transparent),
      0 0 0 1px color-mix(in srgb, var(--accent) 18%, transparent);
    transform: translateY(-8px);
  }
  .svc-card:hover::before,
  .svc-card:focus-visible::before { opacity: 1; }
  .svc-card:hover::after,
  .svc-card:focus-visible::after  { left: 120%; }

  /* All direct children sit above the pseudo-elements */
  .svc-card > * {
    position: relative;
    z-index: 1;
  }
  /* svc-corner is absolutely positioned — restore that */
  .svc-corner {
    position: absolute !important;
  }

  /* Top row */
  .svc-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 0;
  }

  .svc-icon-wrap {
    display: inline-flex;
    padding: 11px;
    border-radius: 1rem;
    border: 1px solid color-mix(in srgb, var(--accent) 22%, transparent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    color: var(--accent);
    transition:
      background   0.35s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      transform    0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .svc-card:hover .svc-icon-wrap,
  .svc-card:focus-visible .svc-icon-wrap {
    background:   color-mix(in srgb, var(--accent) 22%, transparent);
    border-color: color-mix(in srgb, var(--accent) 55%, transparent);
    transform:    scale(1.08);
  }

  .svc-icon { display: flex; align-items: center; justify-content: center; }

  .svc-number {
    font-size: 3.25rem;
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.04em;
    font-variant-numeric: tabular-nums;
    color: var(--accent);
    opacity: 0.18;
    transition: opacity 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .svc-card:hover .svc-number,
  .svc-card:focus-visible .svc-number { opacity: 0.50; }

  /* Rule */
  .svc-rule {
    height: 1px;
    background: color-mix(in srgb, var(--accent) 18%, transparent);
    margin-bottom: 1.25rem;
  }

  .svc-subtitle {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--accent);
    opacity: 0.80;
    margin-bottom: 0.4rem;
  }

  .svc-title {
    font-size: 1.3rem;
    font-weight: 900;
    color: #fff;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin-bottom: 0.75rem;
  }

  .svc-body {
    font-size: 0.95rem;
    line-height: 1.7;
    color: #A8BDC7;
    margin-bottom: 0.75rem;
  }

  /* Animated underline grows L→R; arrow slides +4px */
  .svc-link {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    opacity: 0.75;
    text-decoration: none;
    letter-spacing: 0.02em;
    margin-bottom: 1.25rem;
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
    position: relative;
    transition:
      opacity 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      color   0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .svc-link::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 0%;
    height: 1px;
    background: var(--accent);
    border-radius: 1px;
    transition: width 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .svc-card:hover .svc-link,
  .svc-card:focus-visible .svc-link {
    opacity: 1;
    color: color-mix(in srgb, var(--accent) 90%, #fff);
  }
  .svc-card:hover .svc-link::after,
  .svc-card:focus-visible .svc-link::after { width: 100%; }

  /* Arrow character inside the link text slides right */
  .svc-link-arrow {
    display: inline-block;
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .svc-card:hover .svc-link-arrow,
  .svc-card:focus-visible .svc-link-arrow { transform: translateX(4px); }

  /* Bottom accent bar (expands on hover) */
  .svc-bar {
    height: 2px;
    width: 0;
    border-radius: 2px;
    background: linear-gradient(90deg, var(--accent), transparent);
    transition: width 0.55s cubic-bezier(0.22, 1, 0.36, 1);
    margin-top: auto;
  }
  .svc-card:hover .svc-bar,
  .svc-card:focus-visible .svc-bar { width: 100%; }

  /* Corner bracket */
  .svc-corner {
    bottom: 1.25rem;
    right: 1.25rem;
    width: 16px;
    height: 16px;
    border-right: 1.5px solid var(--accent);
    border-bottom: 1.5px solid var(--accent);
    border-radius: 0 0 4px 0;
    opacity: 0.25;
    transition: opacity 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .svc-card:hover .svc-corner,
  .svc-card:focus-visible .svc-corner { opacity: 0.70; }
</style>
