---
const values = [
  {
    number: '01',
    title: 'Precisie',
    tagline: '±2% op elk meetpunt',
    description:
      'Elke momentsleutel wordt gekalibreerd op 5 meetpunten over het volledige bereik. Pas als de afwijking binnen ISO 6789:2017 valt — en niet eerder — verlaat hij jouw werkplaats.',
    accent: '#7AAFC4',
    icon: `<svg width="28" height="28" viewBox="0 0 32 32" fill="none">
      <circle cx="16" cy="16" r="12" stroke="currentColor" stroke-width="1.4"/>
      <circle cx="16" cy="16" r="6"  stroke="currentColor" stroke-width="1.4"/>
      <circle cx="16" cy="16" r="2"  fill="currentColor"/>
      <line x1="16" y1="4"  x2="16" y2="8"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="4"  y1="16" x2="8"  y2="16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="24" y1="16" x2="28" y2="16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>`,
  },
  {
    number: '02',
    title: 'Snelle doorlooptijd',
    tagline: 'Binnen 48 uur gecertificeerd',
    description:
      'Werkplaatsen kunnen gewoon niet wachten. Wij garanderen een doorlooptijd van maximaal 48 uur, van inleveren tot gecertificeerd gereedschap — zodat jij niet stilstaat.',
    accent: '#C4AF64',
    icon: `<svg width="28" height="28" viewBox="0 0 32 32" fill="none">
      <circle cx="16" cy="18" r="11" stroke="currentColor" stroke-width="1.4"/>
      <path d="M16 10v8l5 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M10 4h12"   stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <path d="M16 4v4"    stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>`,
  },
  {
    number: '03',
    title: 'Transparantie',
    tagline: 'Volledig protocol, geen verrassingen',
    description:
      'Je ontvangt een gedetailleerd kalibratieprotocol met meetresultaten voor én na de service — inclusief afwijkingsgrafieken en volgende kalibratietermijn. Geen black box, alles gedocumenteerd.',
    accent: '#64C48A',
    icon: `<svg width="28" height="28" viewBox="0 0 32 32" fill="none">
      <rect x="6" y="4" width="20" height="24" rx="3" stroke="currentColor" stroke-width="1.4"/>
      <line x1="10" y1="11" x2="22" y2="11" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
      <line x1="10" y1="16" x2="22" y2="16" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
      <line x1="10" y1="21" x2="16" y2="21" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
    </svg>`,
  },
];
---

<section class="values-section relative page-wrap">

  <!-- Separator -->
  <div class="absolute top-0 left-0 right-0 h-px"
    style="background: linear-gradient(90deg, transparent 0%, rgba(122,175,196,0.18) 30%, rgba(122,175,196,0.18) 70%, transparent 100%);"></div>

  <div class="relative page-container">

    <!-- Header — centred -->
    <div class="values-header" data-animate>
      <div class="flex items-center justify-center gap-3">
        <span class="w-8 h-px opacity-75" style="background:#7AAFC4;"></span>
        <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Onze Kernwaarden</span>
        <span class="w-8 h-px opacity-75" style="background:#7AAFC4;"></span>
      </div>
      <h2 class="text-4xl md:text-5xl font-black leading-tight tracking-tight text-white">
        Waarom werkplaatsen ons vertrouwen.
      </h2>
    </div>

    <!-- 3 cards -->
    <div class="values-grid">
      {values.map((v, i) => (
        <div
          class="value-card"
          data-animate
          data-animate-delay={String(i * 0.12)}
          style={`--accent: ${v.accent};`}
        >
          <!-- Top: number + icon -->
          <div class="vc-top">
            <span class="vc-num">{v.number}</span>
            <div class="vc-icon">
              <Fragment set:html={v.icon} />
            </div>
          </div>

          <!-- Rule -->
          <div class="vc-rule"></div>

          <!-- Tagline -->
          <p class="vc-tagline">{v.tagline}</p>

          <!-- Title -->
          <h3 class="vc-title">{v.title}</h3>

          <!-- Description -->
          <p class="vc-body">{v.description}</p>

          <!-- Corner bracket -->
          <div class="vc-corner"></div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .values-section {
    position: relative;
    z-index: 1;
    background: transparent;
  }

  .values-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.25rem;
    margin-bottom: clamp(3rem, 5vw, 4.5rem);
  }

  .values-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 640px)  { .values-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .values-grid { grid-template-columns: repeat(3, 1fr); } }

  /* ── CARD ── */
  .value-card {
    position: relative;
    padding: 2.5rem;
    border-radius: 1.5rem;
    border: 1px solid rgba(122,175,196,0.13);
    overflow: hidden;
    background: linear-gradient(140deg, color-mix(in srgb, var(--accent) 8%, transparent) 0%, transparent 55%),
                #0E1118;
    transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
    box-shadow: 0 2px 16px rgba(0,0,0,0.28);
  }
  .value-card:hover {
    border-color: color-mix(in srgb, var(--accent) 40%, transparent);
    box-shadow: 0 16px 48px rgba(0,0,0,0.45);
    transform: translateY(-3px);
  }

  /* Top row */
  .vc-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 1.75rem;
  }

  .vc-num {
    font-size: 3.5rem;
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.04em;
    font-variant-numeric: tabular-nums;
    color: var(--accent);
    opacity: 0.65;
  }

  .vc-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: 1rem;
    border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    color: var(--accent);
    flex-shrink: 0;
    transition: background 0.3s, border-color 0.3s;
  }
  .value-card:hover .vc-icon {
    background: color-mix(in srgb, var(--accent) 18%, transparent);
    border-color: color-mix(in srgb, var(--accent) 45%, transparent);
  }

  /* Rule */
  .vc-rule {
    height: 1px;
    background: color-mix(in srgb, var(--accent) 20%, transparent);
    margin-bottom: 1.5rem;
  }

  .vc-tagline {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--accent);
    opacity: 0.75;
    margin-bottom: 0.5rem;
  }

  .vc-title {
    font-size: 1.3rem;
    font-weight: 900;
    color: #fff;
    letter-spacing: -0.01em;
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }

  .vc-body {
    font-size: 0.875rem;
    line-height: 1.7;
    color: #8EAAB8;
  }

  /* Corner bracket */
  .vc-corner {
    position: absolute;
    bottom: 1.5rem;
    right: 1.5rem;
    width: 18px;
    height: 18px;
    border-right: 1.5px solid var(--accent);
    border-bottom: 1.5px solid var(--accent);
    border-radius: 0 0 5px 0;
    opacity: 0.30;
  }
</style>
