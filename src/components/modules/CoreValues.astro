---
const values = [
  {
    number: '01',
    title: 'Precisie',
    tagline: '±2% op elk meetpunt',
    description:
      'Elk gereedschap wordt gekalibreerd op 5 meetpunten. Pas als de afwijking binnen de ISO 6789-norm valt, verlaat het je werkplaats.',
    icon: `<svg width="48" height="48" viewBox="0 0 32 32" fill="none">
      <circle cx="16" cy="16" r="12" stroke="currentColor" stroke-width="1.4"/>
      <circle cx="16" cy="16" r="6"  stroke="currentColor" stroke-width="1.4"/>
      <circle cx="16" cy="16" r="2"  fill="currentColor"/>
      <line x1="16" y1="4"  x2="16" y2="8"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="4"  y1="16" x2="8"  y2="16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="24" y1="16" x2="28" y2="16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>`,
  },
  {
    number: '02',
    title: 'Snelle doorlooptijd',
    tagline: 'Binnen 48 uur terug',
    description:
      'Werkplaatsen kunnen niet wachten. Wij streven naar een doorlooptijd van maximaal 48 uur, van inleveren tot gecalibreerd gereedschap.',
    icon: `<svg width="48" height="48" viewBox="0 0 32 32" fill="none">
      <circle cx="16" cy="18" r="11" stroke="currentColor" stroke-width="1.4"/>
      <path d="M16 10v8l5 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M10 4h12"   stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <path d="M16 4v4"    stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>`,
  },
  {
    number: '03',
    title: 'Transparantie',
    tagline: 'Volledig inzicht altijd',
    description:
      'Je ontvangt een gedetailleerd kalibratieprotocol met meetresultaten voor én na de service. Niets verborgen, alles gedocumenteerd.',
    icon: `<svg width="48" height="48" viewBox="0 0 32 32" fill="none">
      <rect x="6" y="4" width="20" height="24" rx="3" stroke="currentColor" stroke-width="1.4"/>
      <line x1="10" y1="11" x2="22" y2="11" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
      <line x1="10" y1="16" x2="22" y2="16" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
      <line x1="10" y1="21" x2="16" y2="21" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
    </svg>`,
  },
];
---

<section class="values-section relative page-wrap">

  <!-- Separator -->
  <div class="absolute top-0 left-0 right-0 h-px"
    style="background: linear-gradient(90deg, transparent 0%, rgba(122,175,196,0.18) 30%, rgba(122,175,196,0.18) 70%, transparent 100%);"></div>

  <div class="relative page-container">

    <!-- Header — centred -->
    <div class="text-center mb-16 md:mb-20" data-animate>
      <div class="flex items-center justify-center gap-3 mb-5">
        <span class="w-8 h-px opacity-75" style="background:#7AAFC4;"></span>
        <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Onze Kernwaarden</span>
        <span class="w-8 h-px opacity-75" style="background:#7AAFC4;"></span>
      </div>
      <h2 class="text-4xl md:text-5xl font-black leading-tight tracking-tight text-white">
        Waar wij elke dag voor staan.
      </h2>
    </div>

    <!-- 3 cards — 12-col grid: full → 4/4/4 -->
    <div class="page-grid">
      {values.map((v, i) => (
        <div
          class="value-card col-span-12 md:col-span-4 group flex flex-col p-10 md:p-12"
          data-animate
          data-animate-delay={String(i * 0.12)}
        >
          <!-- Number — large, top-left -->
          <div class="value-number text-7xl md:text-8xl font-black leading-none tracking-tighter mb-6">
            {v.number}
          </div>

          <!-- Visual area: icon centred in flexible space -->
          <div class="value-icon-area flex-1 flex items-center justify-center py-6">
            <div class="value-icon-wrap" style="color:#7AAFC4;">
              <Fragment set:html={v.icon} />
            </div>
          </div>

          <!-- Divider -->
          <div class="h-px mb-8" style="background: rgba(122,175,196,0.12);"></div>

          <!-- Title + tagline + description — bottom -->
          <div>
            <p class="text-[10px] font-semibold tracking-[0.26em] uppercase mb-2" style="color:rgba(122,175,196,0.65);">
              {v.tagline}
            </p>
            <h3 class="text-2xl md:text-3xl font-black text-white leading-tight tracking-tight mb-4">
              {v.title}
            </h3>
            <p class="text-sm md:text-base leading-relaxed" style="color:#A8BAC2;">
              {v.description}
            </p>
          </div>

          <!-- Bottom accent (hover) -->
          <div class="value-bar absolute bottom-0 left-0 h-0.5 w-0 group-hover:w-full transition-all duration-500 rounded"
            style="background: linear-gradient(90deg, #7AAFC4, transparent);"></div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .values-section {
    position: relative;
    z-index: 1;
    background: transparent;
  }

  .value-card {
    position: relative;
    background: transparent;
    border: 1px solid rgba(122, 175, 196, 0.1);
    border-radius: 1.1rem;
    min-height: 480px;
    transition: border-color 0.35s ease, box-shadow 0.35s ease;
    overflow: hidden;
  }
  .value-card:hover {
    border-color: rgba(122, 175, 196, 0.28);
    box-shadow: 0 20px 56px rgba(0,0,0,0.35), 0 0 0 1px rgba(122,175,196,0.06);
  }

  .value-number {
    /* Prominent but not overpowering — matches reference screenshot */
    color: rgba(255, 255, 255, 0.12);
    transition: color 0.35s;
    font-variant-numeric: tabular-nums;
  }
  .value-card:hover .value-number { color: rgba(122,175,196,0.22); }

  .value-icon-wrap {
    padding: 20px;
    background: rgba(122,175,196,0.07);
    border: 1px solid rgba(122,175,196,0.15);
    border-radius: 1rem;
    transition: background 0.3s, border-color 0.3s;
  }
  .value-card:hover .value-icon-wrap {
    background: rgba(122,175,196,0.13);
    border-color: rgba(122,175,196,0.28);
  }
</style>
