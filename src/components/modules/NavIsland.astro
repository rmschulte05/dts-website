---
interface Props {
  currentPage?: string;
}
const { currentPage = 'home' } = Astro.props;

const links = [
  { label: 'Home',      href: '/',          key: 'home' },
  { label: 'Diensten',  href: '/diensten',  key: 'diensten' },
  { label: 'Werk',      href: '/werk',      key: 'werk' },
  { label: 'Blog',      href: '/blog',      key: 'blog' },
  { label: 'Over Ons',  href: '/over-ons',  key: 'over-ons' },
  { label: 'Contact',   href: '/contact',   key: 'contact' },
];
---

<header id="nav-header" class="fixed top-5 left-0 right-0 z-50 flex justify-center" style="padding-inline: var(--page-px);">
  <nav
    class="nav-island flex items-center gap-6 md:gap-8 px-5 md:px-8 py-3.5 rounded-2xl w-full max-w-[1200px]"
    aria-label="Hoofdnavigatie"
  >
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 shrink-0 group">
      <span class="dts-logo-text font-black text-base tracking-[0.06em]">DTS</span>
    </a>

    <!-- Divider -->
    <div class="nav-divider hidden md:block w-px h-4"></div>

    <!-- Links -->
    <div class="hidden md:flex items-center gap-6">
      {links.map(link => (
        <a
          href={link.href}
          class={['nav-link text-xs font-medium tracking-[0.14em] uppercase', currentPage === link.key ? 'nav-link--active' : ''].join(' ')}
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Spacer -->
    <div class="flex-1"></div>

    <!-- CTA -->
    <a href="/contact" class="btn btn-primary nav-cta-btn hidden md:inline-flex">
      Offerte
    </a>

    <!-- Mobile hamburger -->
    <button
      id="nav-toggle"
      class="md:hidden flex flex-col gap-1.5 p-1"
      aria-label="Menu openen"
      aria-expanded="false"
    >
      <span class="ham-line block w-5 h-0.5 rounded transition-all duration-300"></span>
      <span class="ham-line block w-5 h-0.5 rounded transition-all duration-300"></span>
      <span class="ham-line block w-3 h-0.5 rounded transition-all duration-300"></span>
    </button>
  </nav>

  <!-- Mobile dropdown -->
  <div
    id="nav-mobile"
    class="mobile-menu absolute top-full left-4 right-4 mt-2 rounded-2xl overflow-hidden"
    aria-hidden="true"
  >
    <div class="flex flex-col p-5 gap-4">
      {links.map(link => (
        <a
          href={link.href}
          class="text-sm font-medium tracking-wide transition-colors py-1 border-b border-white/5 last:border-0 nav-mobile-link"
        >
          {link.label}
        </a>
      ))}
      <a href="/contact" class="btn btn-primary w-full justify-center mt-1">
        Offerte Aanvragen
      </a>
    </div>
  </div>
</header>

<style>
  /* ── Base: transparent — integrated into hero ── */
  .nav-island {
    background:             transparent;
    backdrop-filter:        none;
    -webkit-backdrop-filter: none;
    border:                 1px solid transparent;
    box-shadow:             none;
    transition:
      background      0.45s ease,
      border-color    0.45s ease,
      box-shadow      0.45s ease,
      backdrop-filter 0.45s ease;
  }

  /* Nav links — white on dark hero */
  .nav-link {
    color:      rgba(255, 255, 255, 0.72);
    transition: color 0.3s ease;
  }
  .nav-link:hover,
  .nav-link--active { color: rgba(255, 255, 255, 1); }

  /* Divider */
  .nav-divider { background: rgba(255, 255, 255, 0.12); }

  /* Hamburger lines */
  .ham-line { background: rgba(255, 255, 255, 0.65); }

  /* Nav CTA — smaller than global .btn so it sits inside the nav with breathing room */
  .nav-cta-btn {
    height:    36px;
    padding:   0 18px;
    font-size: 0.6875rem; /* 11px */
    margin:    4px 0;     /* 4px vertical gap from nav border */
  }

  /* Logo */
  .dts-logo-text {
    background: linear-gradient(135deg, #9BC5D8 0%, #7AAFC4 40%, #B8C4CC 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    transition: filter 0.45s ease;
  }

  /* ── Scrolled: white frosted glass ── */
  .nav-island.scrolled {
    background:              rgba(255, 255, 255, 0.75);
    backdrop-filter:         blur(20px) saturate(1.8);
    -webkit-backdrop-filter: blur(20px) saturate(1.8);
    border-color:            rgba(0, 0, 0, 0.07);
    box-shadow:
      0 4px 24px rgba(0, 0, 0, 0.08),
      0 1px 0   rgba(255, 255, 255, 0.9) inset;
  }

  /* Links — dark on light background */
  .nav-island.scrolled .nav-link          { color: rgba(8, 9, 11, 0.60); }
  .nav-island.scrolled .nav-link:hover,
  .nav-island.scrolled .nav-link--active  { color: rgba(8, 9, 11, 0.95); }

  /* Divider */
  .nav-island.scrolled .nav-divider { background: rgba(8, 9, 11, 0.10); }

  /* Hamburger */
  .nav-island.scrolled .ham-line { background: rgba(8, 9, 11, 0.55); }

  /* ── Mobile menu ── */
  .mobile-menu {
    background:              rgba(8, 9, 11, 0.92);
    backdrop-filter:         blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border:                  1px solid rgba(122, 175, 196, 0.15);
    max-height:              0;
    opacity:                 0;
    pointer-events:          none;
    transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.25s ease;
  }
  .mobile-menu.open {
    max-height:     500px;
    opacity:        1;
    pointer-events: auto;
  }

  .nav-mobile-link { color: rgba(255,255,255,0.60); }
  .nav-mobile-link:hover { color: #fff; }

  /* Hamburger open state */
  #nav-toggle[aria-expanded="true"] .ham-line:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }
  #nav-toggle[aria-expanded="true"] .ham-line:nth-child(2) { opacity: 0; }
  #nav-toggle[aria-expanded="true"] .ham-line:nth-child(3) {
    width: 20px;
    transform: translateY(-8px) rotate(-45deg);
  }
</style>

<script>
  import gsap from 'gsap';

  const nav = document.querySelector<HTMLElement>('.nav-island')!;

  // ── Scroll-driven style switch ──
  function updateNav() {
    if (window.scrollY > 60) {
      nav.classList.add('scrolled');
    } else {
      nav.classList.remove('scrolled');
    }
  }

  // Apply immediately on load (handles page refresh mid-scroll)
  updateNav();
  window.addEventListener('scroll', updateNav, { passive: true });

  // ── Entrance animation ──
  gsap.from('#nav-header', {
    y: -20,
    opacity: 0,
    duration: 0.8,
    ease: 'power3.out',
    delay: 0.2,
  });

  // ── Mobile menu toggle ──
  const toggle     = document.getElementById('nav-toggle');
  const mobileMenu = document.getElementById('nav-mobile');

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isOpen));
    mobileMenu?.setAttribute('aria-hidden', String(isOpen));
    mobileMenu?.classList.toggle('open');
  });

  document.addEventListener('click', (e) => {
    const header = document.getElementById('nav-header');
    if (!header?.contains(e.target as Node)) {
      toggle?.setAttribute('aria-expanded', 'false');
      mobileMenu?.setAttribute('aria-hidden', 'true');
      mobileMenu?.classList.remove('open');
    }
  });
</script>
