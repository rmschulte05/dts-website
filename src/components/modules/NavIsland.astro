---
interface Props {
  currentPage?: string;
}
const { currentPage = 'home' } = Astro.props;

const links = [
  { label: 'Home',      href: '/',          key: 'home' },
  { label: 'Diensten',  href: '/diensten',  key: 'diensten' },
  { label: 'Werk',      href: '/werk',      key: 'werk' },
  { label: 'Blog',      href: '/blog',      key: 'blog' },
  { label: 'Over Ons',  href: '/over-ons',  key: 'over-ons' },
  { label: 'Contact',   href: '/contact',   key: 'contact' },
];
---

<header id="nav-header" class="fixed top-0 left-0 right-0 z-50 flex justify-center" style="padding-inline: var(--page-px); padding-top: 1.25rem;">
  <nav
    class="nav-island relative flex items-center gap-4 md:gap-6 px-7 md:px-12 rounded-2xl w-full max-w-[1200px]"
    aria-label="Hoofdnavigatie"
    style="height: 56px;"
  >

    <!-- ── Scroll progress bar (teal, bottom edge of nav) ── -->
    <div class="nav-progress" id="nav-progress" aria-hidden="true"></div>

    <!-- ── Sliding active-link indicator ── -->
    <div class="nav-indicator" id="nav-indicator" aria-hidden="true"></div>

    <!-- Logo -->
    <a href="/" class="nav-logo flex items-center gap-2 shrink-0" aria-label="Dutch Torque Service — home">
      <!-- Mini precision-gauge icon -->
      <svg width="20" height="20" viewBox="0 0 28 28" fill="none" class="nav-logo-icon" aria-hidden="true">
        <circle cx="14" cy="14" r="12" stroke="currentColor" stroke-width="1.4"/>
        <circle cx="14" cy="14" r="6"  stroke="currentColor" stroke-width="1"/>
        <line x1="14" y1="14" x2="14" y2="5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        <circle cx="14" cy="14" r="1.5" fill="currentColor"/>
        <!-- Tick marks -->
        <line x1="14" y1="3"  x2="14" y2="5.5"  stroke="currentColor" stroke-width="1" opacity="0.6"/>
        <line x1="25" y1="14" x2="22.5" y2="14" stroke="currentColor" stroke-width="1" opacity="0.6"/>
        <line x1="3"  y1="14" x2="5.5"  y2="14" stroke="currentColor" stroke-width="1" opacity="0.6"/>
        <line x1="14" y1="25" x2="14"  y2="22.5" stroke="currentColor" stroke-width="1" opacity="0.6"/>
      </svg>
      <span class="dts-logo-text font-black tracking-[0.05em]" style="font-size:0.9rem;">DTS</span>
    </a>

    <!-- Divider -->
    <div class="nav-divider hidden md:block w-px" style="height:1rem; flex-shrink:0;"></div>

    <!-- Links -->
    <div class="hidden md:flex items-center gap-2" id="nav-links">
      {links.map(link => (
        <a
          href={link.href}
          class={['nav-link relative px-4 py-2 text-[0.68rem] font-semibold tracking-[0.16em] uppercase rounded-lg transition-colors', currentPage === link.key ? 'nav-link--active' : ''].join(' ')}
          data-key={link.key}
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Spacer -->
    <div class="flex-1"></div>

    <!-- Status chip (shows when scrolled) -->
    <div class="nav-status hidden md:flex items-center gap-1.5" id="nav-status" aria-hidden="true">
      <span class="nav-status-dot"></span>
      <span class="nav-status-label" id="nav-status-label">LIVE</span>
    </div>

    <!-- CTA -->
    <a href="tel:+31613172774" class="btn btn-primary nav-cta-btn hidden md:inline-flex">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="1.5"/>
      </svg>
      Bel Ons
    </a>

    <!-- Mobile hamburger -->
    <button
      id="nav-toggle"
      class="md:hidden flex flex-col gap-1.5 p-1.5 rounded-lg"
      aria-label="Menu openen"
      aria-expanded="false"
    >
      <span class="ham-line block w-5 h-0.5 rounded transition-all duration-300"></span>
      <span class="ham-line block w-5 h-0.5 rounded transition-all duration-300"></span>
      <span class="ham-line block w-3 h-0.5 rounded transition-all duration-300"></span>
    </button>
  </nav>

  <!-- Mobile fullscreen overlay -->
  <div
    id="nav-mobile"
    class="mobile-overlay"
    aria-hidden="true"
    role="dialog"
    aria-modal="true"
    aria-label="Navigatiemenu"
  >
    <!-- Close button -->
    <button id="nav-close" class="mobile-close" aria-label="Menu sluiten">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      </svg>
    </button>

    <!-- Nav links -->
    <nav class="mobile-nav-list">
      {links.map((link, i) => (
        <a
          href={link.href}
          class={['mobile-nav-link', currentPage === link.key ? 'mobile-nav-link--active' : ''].join(' ')}
          tabindex="-1"
        >
          <span class="mobile-link-num" aria-hidden="true">0{i + 1}</span>
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Phone CTA -->
    <a href="tel:+31613172774" class="mobile-phone-cta" tabindex="-1">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="1.5"/>
      </svg>
      +31(0)6-131 72 774
    </a>
  </div>
</header>

<style>
  /* ═══════════════════════════════════════
     BASE — transparent, blends into hero
  ═══════════════════════════════════════ */
  .nav-island {
    background:              transparent;
    backdrop-filter:         none;
    -webkit-backdrop-filter: none;
    border:                  1px solid transparent;
    box-shadow:              none;
    transition:
      background       0.5s cubic-bezier(0.4,0,0.2,1),
      border-color     0.5s cubic-bezier(0.4,0,0.2,1),
      box-shadow       0.5s cubic-bezier(0.4,0,0.2,1);
  }

  /* ── Scroll progress bar ── */
  .nav-progress {
    position:   absolute;
    bottom:     0;
    left:       1.5rem;
    right:      1.5rem;
    height:     1.5px;
    width:      0%;          /* JS sets this on scroll */
    background: linear-gradient(to right, transparent, #7AAFC4 20%, #9BC5D8 80%, transparent);
    border-radius: 1px;
    opacity:    0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  /* ── Sliding indicator under active link ── */
  .nav-indicator {
    position:     absolute;
    bottom:       6px;
    height:       2px;
    width:        0;
    background:   linear-gradient(to right, transparent, #7AAFC4, transparent);
    border-radius: 1px;
    pointer-events: none;
    transition:   left 0.35s cubic-bezier(0.4,0,0.2,1),
                  width 0.35s cubic-bezier(0.4,0,0.2,1),
                  opacity 0.3s ease;
    opacity: 0;
  }

  /* ── Logo ── */
  .nav-logo-icon {
    color: rgba(122,175,196,0.65);
    transition: color 0.35s ease;
  }
  .nav-logo:hover .nav-logo-icon { color: #7AAFC4; }

  .dts-logo-text {
    background: linear-gradient(135deg, #9BC5D8 0%, #7AAFC4 45%, #B8C4CC 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    transition: filter 0.4s ease;
  }

  /* ── Divider ── */
  .nav-divider { background: rgba(255,255,255,0.10); }

  /* ── Links ── */
  .nav-link {
    color:      rgba(255,255,255,0.55);
    position:   relative;
    transition: color 0.25s ease, background 0.25s ease;
  }
  .nav-link:hover    { color: rgba(255,255,255,0.90); background: rgba(255,255,255,0.05); }
  .nav-link--active  { color: #ffffff; }

  /* ── Status chip ── */
  .nav-status {
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .nav-status-dot {
    width:  6px;
    height: 6px;
    border-radius: 50%;
    background: #7AAFC4;
    box-shadow: 0 0 6px rgba(122,175,196,0.8);
    animation: statusPulse 2.5s ease-in-out infinite;
  }
  .nav-status-label {
    font-size:      0.55rem;
    font-weight:    700;
    letter-spacing: 0.22em;
    color:          rgba(122,175,196,0.65);
    text-transform: uppercase;
  }
  @keyframes statusPulse {
    0%,100% { opacity: 1; box-shadow: 0 0 4px rgba(122,175,196,0.6); }
    50%      { opacity: 0.5; box-shadow: 0 0 10px rgba(122,175,196,0.9); }
  }

  /* ── CTA button in nav ── */
  .nav-cta-btn {
    height:    34px;
    padding:   0 16px;
    font-size: 0.65rem;
    gap:       0.4rem;
  }

  /* ── Hamburger ── */
  .ham-line { background: rgba(255,255,255,0.60); }

  /* ═══════════════════════════════════════
     SCROLLED — dark precision glass
  ═══════════════════════════════════════ */
  .nav-island.scrolled {
    background:              rgba(8, 9, 11, 0.88);
    backdrop-filter:         blur(24px) saturate(1.6);
    -webkit-backdrop-filter: blur(24px) saturate(1.6);
    border-color:            rgba(122,175,196,0.18);
    box-shadow:
      0 1px 0   rgba(122,175,196,0.12) inset,   /* top inner glow */
      0 0  0 1px rgba(122,175,196,0.06),          /* outer ring */
      0 8px 32px rgba(0,0,0,0.55),
      0 2px 8px  rgba(0,0,0,0.35);
  }

  .nav-island.scrolled .nav-progress { opacity: 1; }
  .nav-island.scrolled .nav-indicator { opacity: 1; }
  .nav-island.scrolled .nav-status   { opacity: 1; }

  /* Links stay white/teal on dark background */
  .nav-island.scrolled .nav-link         { color: rgba(184,196,204,0.55); }
  .nav-island.scrolled .nav-link:hover   { color: rgba(255,255,255,0.85); background: rgba(122,175,196,0.08); }
  .nav-island.scrolled .nav-link--active { color: #7AAFC4; }

  /* Logo gets brighter teal */
  .nav-island.scrolled .dts-logo-text {
    filter: drop-shadow(0 0 8px rgba(122,175,196,0.35));
  }
  .nav-island.scrolled .nav-logo-icon { color: rgba(122,175,196,0.80); }

  /* Divider */
  .nav-island.scrolled .nav-divider { background: rgba(122,175,196,0.14); }

  /* Hamburger */
  .nav-island.scrolled .ham-line { background: rgba(184,196,204,0.70); }

  /* ═══════════════════════════════════════
     MOBILE FULLSCREEN OVERLAY
  ═══════════════════════════════════════ */
  .mobile-overlay {
    position:              fixed;
    inset:                 0;
    z-index:               200;
    background:            rgba(4, 5, 7, 0.97);
    backdrop-filter:       blur(32px) saturate(1.4);
    -webkit-backdrop-filter: blur(32px) saturate(1.4);
    display:               flex;
    flex-direction:        column;
    align-items:           center;
    justify-content:       center;
    gap:                   0.25rem;
    padding:               2rem;
    opacity:               0;
    pointer-events:        none;
    transition:            opacity 0.25s ease;
  }
  .mobile-overlay.open {
    opacity:        1;
    pointer-events: auto;
  }

  /* Close × button */
  .mobile-close {
    position:   absolute;
    top:        1.5rem;
    right:      1.5rem;
    padding:    0.6rem;
    border-radius: 50%;
    background: rgba(255,255,255,0.05);
    border:     1px solid rgba(255,255,255,0.08);
    color:      rgba(255,255,255,0.5);
    cursor:     pointer;
    transition: background 0.2s, color 0.2s;
    display:    flex;
    align-items: center;
    justify-content: center;
  }
  .mobile-close:hover { background: rgba(255,255,255,0.1); color: #fff; }

  /* Nav list */
  .mobile-nav-list {
    display:        flex;
    flex-direction: column;
    align-items:    center;
    gap:            0.15rem;
  }

  .mobile-nav-link {
    display:        flex;
    align-items:    center;
    gap:            1rem;
    padding:        0.55rem 1.5rem;
    border-radius:  0.75rem;
    font-size:      clamp(2rem, 10vw, 3.25rem);
    font-weight:    900;
    letter-spacing: -0.03em;
    color:          rgba(255,255,255,0.22);
    text-decoration: none;
    transition:     color 0.2s ease, background 0.2s ease;
    width:          100%;
    justify-content: center;
  }
  .mobile-nav-link:hover          { color: rgba(255,255,255,0.75); background: rgba(255,255,255,0.04); }
  .mobile-nav-link--active        { color: #7AAFC4; }

  .mobile-link-num {
    font-size:      0.7rem;
    font-weight:    600;
    letter-spacing: 0.12em;
    color:          rgba(122,175,196,0.35);
    width:          1.5rem;
    text-align:     right;
    flex-shrink:    0;
    align-self:     center;
    padding-bottom: 2px;
  }
  .mobile-nav-link--active .mobile-link-num { color: rgba(122,175,196,0.6); }

  /* Phone CTA */
  .mobile-phone-cta {
    display:        inline-flex;
    align-items:    center;
    gap:            0.6rem;
    margin-top:     2rem;
    padding:        0.85rem 2rem;
    border-radius:  9999px;
    border:         1px solid rgba(122,175,196,0.28);
    background:     rgba(122,175,196,0.08);
    color:          #7AAFC4;
    font-size:      1.05rem;
    font-weight:    700;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition:     background 0.2s, border-color 0.2s;
  }
  .mobile-phone-cta:hover {
    background:    rgba(122,175,196,0.15);
    border-color:  rgba(122,175,196,0.45);
  }

  /* ── Hamburger open state — hides lines when overlay is open ── */
  #nav-toggle[aria-expanded="true"] .ham-line:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  #nav-toggle[aria-expanded="true"] .ham-line:nth-child(2) { opacity: 0; transform: scaleX(0); }
  #nav-toggle[aria-expanded="true"] .ham-line:nth-child(3) { width: 20px; transform: translateY(-8px) rotate(-45deg); }
</style>

<script>
  import gsap from 'gsap';

  const nav       = document.querySelector<HTMLElement>('.nav-island')!;
  const progress  = document.getElementById('nav-progress') as HTMLElement;
  const indicator = document.getElementById('nav-indicator') as HTMLElement;
  const statusLbl = document.getElementById('nav-status-label') as HTMLElement;
  const navLinks  = document.querySelectorAll<HTMLAnchorElement>('#nav-links .nav-link');

  // ─────────────────────────────────────
  //  1. Scroll state + progress bar
  // ─────────────────────────────────────
  function updateNav() {
    const scrolled = window.scrollY > 60;
    nav.classList.toggle('scrolled', scrolled);

    // Progress bar width
    const docH   = document.body.scrollHeight - window.innerHeight;
    const pct    = docH > 0 ? (window.scrollY / docH) * 100 : 0;
    progress.style.width = `${pct}%`;
  }

  updateNav();
  window.addEventListener('scroll', updateNav, { passive: true });

  // ─────────────────────────────────────
  //  2. Sliding indicator under active link
  // ─────────────────────────────────────
  function moveIndicator(el: HTMLElement) {
    const navRect = nav.getBoundingClientRect();
    const elRect  = el.getBoundingClientRect();
    const left    = elRect.left - navRect.left + (elRect.width * 0.2);
    const width   = elRect.width * 0.6;
    indicator.style.left  = `${left}px`;
    indicator.style.width = `${width}px`;
  }

  // Set indicator on the active link immediately
  const activeLink = document.querySelector<HTMLElement>('#nav-links .nav-link--active');
  if (activeLink) moveIndicator(activeLink);

  // Hover: move indicator to hovered link
  navLinks.forEach(link => {
    link.addEventListener('mouseenter', () => moveIndicator(link));
    link.addEventListener('mouseleave', () => {
      if (activeLink) moveIndicator(activeLink);
    });
  });

  // ─────────────────────────────────────
  //  3. Section scanner — status chip
  //     shows the section heading name
  // ─────────────────────────────────────
  const sectionMap: Record<string, string> = {
    'hero-section':  'HOME',
    'over-ons':      'OVER ONS',
    'diensten':      'DIENSTEN',
    'cases':         'WERK',
    'werk':          'WERK',
    'blog':          'BLOG',
    'contact':       'CONTACT',
  };

  if (typeof IntersectionObserver !== 'undefined') {
    const io = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          const id = (entry.target as HTMLElement).id || (entry.target as HTMLElement).className.split(' ')[0];
          const match = Object.entries(sectionMap).find(([key]) => id.includes(key));
          if (match && statusLbl) statusLbl.textContent = match[1];
        }
      }
    }, { threshold: 0.3 });

    document.querySelectorAll('section[id], section.hero-section').forEach(s => io.observe(s));
  }

  // ─────────────────────────────────────
  //  4. Entrance animation
  // ─────────────────────────────────────
  gsap.from('#nav-header', {
    y: -28,
    opacity: 0,
    duration: 0.9,
    ease: 'power3.out',
    delay: 0.15,
  });

  // Logo icon draws in
  gsap.from('.nav-logo-icon', {
    rotation: -90,
    opacity: 0,
    duration: 0.7,
    ease: 'back.out(1.5)',
    delay: 0.55,
  });

  // Links stagger in
  gsap.from('#nav-links .nav-link', {
    y: -8,
    opacity: 0,
    duration: 0.45,
    stagger: 0.06,
    ease: 'power2.out',
    delay: 0.5,
  });

  // ─────────────────────────────────────
  //  5. Mobile fullscreen menu
  // ─────────────────────────────────────
  const toggle      = document.getElementById('nav-toggle');
  const closeBtn    = document.getElementById('nav-close');
  const mobileMenu  = document.getElementById('nav-mobile');
  const mobileLinks = document.querySelectorAll<HTMLElement>('.mobile-nav-link');
  const mobileCta   = document.querySelector<HTMLElement>('.mobile-phone-cta');

  function openMenu() {
    toggle?.setAttribute('aria-expanded', 'true');
    mobileMenu?.setAttribute('aria-hidden', 'false');
    mobileMenu?.classList.add('open');
    // Make links focusable
    mobileLinks.forEach(l => l.setAttribute('tabindex', '0'));
    mobileCta?.setAttribute('tabindex', '0');
    // GSAP stagger
    gsap.fromTo(mobileLinks,
      { opacity: 0, y: 28 },
      { opacity: 1, y: 0, duration: 0.42, stagger: 0.07, ease: 'power3.out', delay: 0.05 }
    );
    gsap.fromTo(mobileCta ?? [],
      { opacity: 0, y: 16 },
      { opacity: 1, y: 0, duration: 0.38, ease: 'power2.out', delay: 0.42 }
    );
  }

  function closeMenu() {
    toggle?.setAttribute('aria-expanded', 'false');
    mobileMenu?.setAttribute('aria-hidden', 'true');
    mobileMenu?.classList.remove('open');
    mobileLinks.forEach(l => l.setAttribute('tabindex', '-1'));
    mobileCta?.setAttribute('tabindex', '-1');
  }

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    isOpen ? closeMenu() : openMenu();
  });
  closeBtn?.addEventListener('click', closeMenu);

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
</script>
