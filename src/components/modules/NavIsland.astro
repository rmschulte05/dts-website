---
interface Props {
  currentPage?: string;
}
const { currentPage = 'home' } = Astro.props;

const links = [
  { label: 'Home',      href: '/',          key: 'home' },
  { label: 'Diensten',  href: '/diensten',  key: 'diensten' },
  { label: 'Werk',      href: '/werk',      key: 'werk' },
  { label: 'Blog',      href: '/blog',      key: 'blog' },
  { label: 'Over Ons',  href: '/over-ons',  key: 'over-ons' },
  { label: 'Contact',   href: '/contact',   key: 'contact' },
];
---

<header id="nav-header" class="fixed top-0 left-0 right-0 z-50 flex justify-center" style="padding-inline: var(--page-px); padding-top: 1.25rem;">
  <nav
    class="nav-island relative flex items-center gap-4 md:gap-6 px-7 md:px-12 rounded-2xl w-full max-w-[1200px]"
    aria-label="Hoofdnavigatie"
    style="height: 56px;"
  >

    <!-- ── Scroll progress bar (teal, bottom edge of nav) ── -->
    <div class="nav-progress" id="nav-progress" aria-hidden="true"></div>

    <!-- ── Sliding active-link indicator ── -->
    <div class="nav-indicator" id="nav-indicator" aria-hidden="true"></div>

    <!-- Logo -->
    <a href="/" class="nav-logo shrink-0" aria-label="Dutch Torque Service — home">
      <img
        src="/logo/dts-logo-1x.webp"
        srcset="/logo/dts-logo-1x.webp 1x, /logo/dts-logo-2x.webp 2x"
        alt="Dutch Torque Service"
        width="79"
        height="44"
        class="nav-logo-img"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
    </a>

    <!-- Divider -->
    <div class="nav-divider hidden md:block w-px" style="height:1rem; flex-shrink:0;"></div>

    <!-- Links -->
    <div class="hidden md:flex items-center gap-5" id="nav-links">
      {links.map(link => (
        <a
          href={link.href}
          class={['nav-link relative px-4 py-2 text-[0.68rem] font-semibold tracking-[0.16em] uppercase rounded-lg transition-colors', currentPage === link.key ? 'nav-link--active' : ''].join(' ')}
          data-key={link.key}
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Spacer -->
    <div class="flex-1"></div>

    <!-- Status chip (shows when scrolled) -->
    <div class="nav-status hidden md:flex items-center gap-1.5" id="nav-status" aria-hidden="true">
      <span class="nav-status-dot"></span>
      <span class="nav-status-label" id="nav-status-label">LIVE</span>
    </div>

    <!-- CTA -->
    <a href="tel:+31613172774" class="btn btn-primary nav-cta-btn hidden md:inline-flex">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="1.5"/>
      </svg>
      Bel Ons
    </a>

    <!-- Mobile phone CTA — primary conversion path, always visible -->
    <a
      href="tel:+31613172774"
      class="nav-mobile-phone md:hidden"
      aria-label="Bel Dutch Torque Service"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
        <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>

    <!-- Mobile hamburger -->
    <button
      id="nav-toggle"
      class="md:hidden flex flex-col gap-1.5 p-1.5 rounded-lg"
      aria-label="Menu openen"
      aria-expanded="false"
    >
      <span class="ham-line block w-5 h-0.5 rounded transition-all duration-300"></span>
      <span class="ham-line block w-5 h-0.5 rounded transition-all duration-300"></span>
      <span class="ham-line block w-3 h-0.5 rounded transition-all duration-300"></span>
    </button>
  </nav>

  <!-- Mobile fullscreen overlay -->
  <div
    id="nav-mobile"
    class="mobile-overlay"
    aria-hidden="true"
    role="dialog"
    aria-modal="true"
    aria-label="Navigatiemenu"
  >
    <!-- Close button — absolutely positioned, always top-right -->
    <button id="nav-close" class="mobile-close" aria-label="Menu sluiten">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
        <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      </svg>
    </button>

    <!-- Centred content wrapper — auto margins push it to centre when space allows -->
    <div class="mobile-overlay-inner">
      <!-- Nav links -->
      <nav class="mobile-nav-list">
        {links.map((link, i) => (
          <a
            href={link.href}
            class={['mobile-nav-link', currentPage === link.key ? 'mobile-nav-link--active' : ''].join(' ')}
            tabindex="-1"
          >
            <span class="mobile-link-num" aria-hidden="true">0{i + 1}</span>
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Phone CTA -->
      <a href="tel:+31613172774" class="mobile-phone-cta" tabindex="-1">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="1.5"/>
        </svg>
        +31(0)6-131 72 774
      </a>
    </div>
  </div>
</header>

<style>
  /* ═══════════════════════════════════════
     ENTRANCE — visible immediately on mobile,
     CSS-animated on desktop only.

     On mobile Safari, position:fixed elements
     with animation-fill-mode:both can get
     stuck at opacity:0 when the compositing
     layer is created before the animation
     fires. Showing the header instantly on
     mobile avoids the issue completely.
  ═══════════════════════════════════════ */
  @media (min-width: 768px) {
    #nav-header {
      animation: navHeaderIn 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
      animation-delay: 0.15s;
    }
    @keyframes navHeaderIn {
      from { opacity: 0; transform: translateY(-28px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  }

  /* ═══════════════════════════════════════
     BASE — transparent, blends into hero
  ═══════════════════════════════════════ */
  .nav-island {
    background:              transparent;
    backdrop-filter:         none;
    -webkit-backdrop-filter: none;
    border:                  1px solid transparent;
    box-shadow:              none;
    transition:
      background       0.5s cubic-bezier(0.4,0,0.2,1),
      border-color     0.5s cubic-bezier(0.4,0,0.2,1),
      box-shadow       0.5s cubic-bezier(0.4,0,0.2,1);
  }

  /* ── Scroll progress bar ── */
  .nav-progress {
    position:   absolute;
    bottom:     0;
    left:       1.5rem;
    right:      1.5rem;
    height:     1.5px;
    width:      0%;          /* JS sets this on scroll */
    background: linear-gradient(to right, transparent, #7AAFC4 20%, #9BC5D8 80%, transparent);
    border-radius: 1px;
    opacity:    0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  /* ── Sliding indicator under active link ── */
  .nav-indicator {
    position:     absolute;
    bottom:       6px;
    height:       2px;
    width:        0;
    background:   linear-gradient(to right, transparent, #7AAFC4, transparent);
    border-radius: 1px;
    pointer-events: none;
    transition:   left 0.35s cubic-bezier(0.4,0,0.2,1),
                  width 0.35s cubic-bezier(0.4,0,0.2,1),
                  opacity 0.3s ease;
    opacity: 0;
  }

  /* ── Logo ── */
  .nav-logo {
    display: flex;
    align-items: center;
  }
  .nav-logo-img {
    height: 44px;
    width: auto;
    display: block;
    object-fit: contain;
    transition: filter 0.35s ease;
    filter: drop-shadow(0 1px 4px rgba(0,0,0,0.5));
  }
  .nav-logo:hover .nav-logo-img {
    filter: drop-shadow(0 1px 4px rgba(0,0,0,0.5)) drop-shadow(0 0 10px rgba(122,175,196,0.4));
  }

  /* ── Divider ── */
  .nav-divider { background: rgba(255,255,255,0.10); }

  /* ── Links ── */
  .nav-link {
    color:      rgba(255,255,255,0.55);
    position:   relative;
    transition:
      color      0.3s cubic-bezier(0.22, 1, 0.36, 1),
      background 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  /* Underline grows outward from centre on hover */
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 50%;
    transform: translateX(-50%);
    width: 0%;
    height: 1.5px;
    background: linear-gradient(to right, transparent, rgba(122,175,196,0.70), transparent);
    border-radius: 1px;
    transition: width 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
  }
  .nav-link:hover,
  .nav-link:focus-visible         { color: rgba(255,255,255,0.90); background: rgba(255,255,255,0.05); }
  .nav-link:hover::after,
  .nav-link:focus-visible::after  { width: 60%; }
  .nav-link--active               { color: #ffffff; }
  .nav-link--active::after        { width: 60%; background: linear-gradient(to right, transparent, rgba(122,175,196,0.45), transparent); }
  .nav-link:focus-visible         { outline: 2px solid rgba(122,175,196,0.80); outline-offset: 2px; border-radius: 6px; }
  .nav-logo:focus-visible      { outline: 2px solid rgba(122,175,196,0.80); outline-offset: 4px; border-radius: 8px; }
  #nav-toggle:focus-visible    { outline: 2px solid rgba(122,175,196,0.80); outline-offset: 2px; }

  /* ── Status chip ── */
  .nav-status {
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .nav-status-dot {
    width:  6px;
    height: 6px;
    border-radius: 50%;
    background: #7AAFC4;
    box-shadow: 0 0 6px rgba(122,175,196,0.8);
    animation: statusPulse 2.5s ease-in-out infinite;
  }
  .nav-status-label {
    font-size:      0.7rem;
    font-weight:    700;
    letter-spacing: 0.22em;
    color:          rgba(184,196,204,0.85);
    text-transform: uppercase;
  }
  @keyframes statusPulse {
    0%,100% { opacity: 1; box-shadow: 0 0 4px rgba(122,175,196,0.6); }
    50%      { opacity: 0.5; box-shadow: 0 0 10px rgba(122,175,196,0.9); }
  }

  /* ── CTA button in nav ── */
  .nav-cta-btn {
    height:    34px;
    padding:   0 16px;
    font-size: 0.65rem;
    gap:       0.4rem;
  }

  /* ── Hamburger ── */
  .ham-line { background: rgba(255,255,255,0.60); transition: background 0.25s ease; }
  #nav-toggle:hover .ham-line,
  #nav-toggle:focus-visible .ham-line { background: rgba(255,255,255,0.90); }
  #nav-toggle {
    transition: background 0.25s ease, transform 0.25s cubic-bezier(0.22,1,0.36,1);
  }
  #nav-toggle:hover,
  #nav-toggle:focus-visible { background: rgba(255,255,255,0.06); }
  #nav-toggle:active { transform: scale(0.94); }

  /* ── Mobile phone CTA — always-visible tap target ── */
  .nav-mobile-phone {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width:  44px;
    height: 44px;
    margin-right: 0.25rem;
    border-radius: 50%;
    color: #7AAFC4;
    background: rgba(122,175,196,0.10);
    border: 1px solid rgba(122,175,196,0.25);
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease, transform 0.15s ease;
  }
  .nav-mobile-phone:hover,
  .nav-mobile-phone:focus-visible {
    background: rgba(122,175,196,0.20);
    border-color: rgba(122,175,196,0.55);
    color: #B8D4E0;
  }
  .nav-mobile-phone:active { transform: scale(0.95); }
  .nav-mobile-phone:focus-visible {
    outline: 2px solid rgba(122,175,196,0.8);
    outline-offset: 2px;
  }
  .nav-island.scrolled .nav-mobile-phone {
    background: rgba(122,175,196,0.14);
    border-color: rgba(122,175,196,0.35);
  }

  /* ═══════════════════════════════════════
     SCROLLED — dark precision glass
  ═══════════════════════════════════════ */
  .nav-island.scrolled {
    background:              rgba(8, 9, 11, 0.88);
    backdrop-filter:         blur(24px) saturate(1.6);
    -webkit-backdrop-filter: blur(24px) saturate(1.6);
    border-color:            rgba(122,175,196,0.18);
    box-shadow:
      0 1px 0   rgba(122,175,196,0.12) inset,   /* top inner glow */
      0 0  0 1px rgba(122,175,196,0.06),          /* outer ring */
      0 8px 32px rgba(0,0,0,0.55),
      0 2px 8px  rgba(0,0,0,0.35);
  }

  .nav-island.scrolled .nav-progress { opacity: 1; }
  .nav-island.scrolled .nav-indicator { opacity: 1; }
  .nav-island.scrolled .nav-status   { opacity: 1; }

  /* Links stay white/teal on dark background */
  .nav-island.scrolled .nav-link                  { color: rgba(184,196,204,0.55); }
  .nav-island.scrolled .nav-link:hover,
  .nav-island.scrolled .nav-link:focus-visible    { color: rgba(255,255,255,0.85); background: rgba(122,175,196,0.08); }
  .nav-island.scrolled .nav-link--active          { color: #7AAFC4; }
  /* Teal tint on the underline when scrolled */
  .nav-island.scrolled .nav-link:hover::after,
  .nav-island.scrolled .nav-link:focus-visible::after { background: linear-gradient(to right, transparent, rgba(122,175,196,0.85), transparent); }
  .nav-island.scrolled .nav-link--active::after   { background: linear-gradient(to right, transparent, rgba(122,175,196,0.65), transparent); }

  /* Logo gets a subtle glow when scrolled */
  .nav-island.scrolled .nav-logo-img {
    filter: drop-shadow(0 0 8px rgba(122,175,196,0.30));
  }

  /* Divider */
  .nav-island.scrolled .nav-divider { background: rgba(122,175,196,0.14); }

  /* Hamburger */
  .nav-island.scrolled .ham-line { background: rgba(184,196,204,0.70); }

  /* ═══════════════════════════════════════
     MOBILE FULLSCREEN OVERLAY
  ═══════════════════════════════════════ */
  .mobile-overlay {
    position:         fixed;
    inset:            0;
    /* Explicit height fallback so old Safari doesn't collapse it */
    height:           100vh;
    height:           100dvh;
    z-index:          200;
    background:       rgba(4, 5, 7, 0.98);
    backdrop-filter:  blur(32px) saturate(1.4);
    -webkit-backdrop-filter: blur(32px) saturate(1.4);
    display:          flex;
    flex-direction:   column;
    align-items:      center;
    /* Safe centering: auto top/bottom margins on children handle centering,
       overflow-y: auto catches the rare too-small screen edge case */
    justify-content:  flex-start;
    overflow-y:       auto;
    /* Top padding clears the close × button; bottom gives breathing room */
    padding:          4.5rem 1.5rem 2.5rem;
    opacity:          0;
    pointer-events:   none;
    transition:       opacity 0.28s ease;
    /* Prevent rubber-band scroll leaking to page on iOS */
    overscroll-behavior: contain;
  }
  .mobile-overlay.open {
    opacity:        1;
    pointer-events: auto;
  }

  /* Inner wrapper — flex child that centres in the overlay when there's spare height */
  .mobile-overlay-inner {
    display:        flex;
    flex-direction: column;
    align-items:    center;
    width:          100%;
    /* auto top+bottom margins push this block to the vertical centre when
       the overlay has surplus height, but let it sit at the top when not */
    margin-top:     auto;
    margin-bottom:  auto;
  }

  /* Close × button */
  .mobile-close {
    position:   absolute;
    top:        1.25rem;
    right:      1.25rem;
    min-width:  44px;
    min-height: 44px;
    padding:    0.75rem;
    border-radius: 50%;
    background: rgba(255,255,255,0.05);
    border:     1px solid rgba(255,255,255,0.08);
    color:      rgba(255,255,255,0.72);
    cursor:     pointer;
    touch-action: manipulation;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    display:    flex;
    align-items: center;
    justify-content: center;
    /* Keep above overlay-inner */
    z-index: 1;
  }
  .mobile-close:hover,
  .mobile-close:focus-visible  {
    background:   rgba(122,175,196,0.12);
    border-color: rgba(122,175,196,0.30);
    color:        #7AAFC4;
    transform:    scale(1.08) rotate(90deg);
  }
  .mobile-close                { transition: background 0.3s cubic-bezier(0.22,1,0.36,1), border-color 0.3s cubic-bezier(0.22,1,0.36,1), color 0.3s cubic-bezier(0.22,1,0.36,1), transform 0.35s cubic-bezier(0.22,1,0.36,1); }
  .mobile-close:focus-visible  { outline: 2px solid rgba(122,175,196,0.80); outline-offset: 2px; }

  /* Nav list */
  .mobile-nav-list {
    display:        flex;
    flex-direction: column;
    align-items:    center;
    gap:            0;
    width:          100%;
  }

  .mobile-nav-link {
    display:         flex;
    align-items:     center;
    gap:             0.875rem;
    /* dvh-based font size: scales with screen HEIGHT so all 6 items always fit.
       Fallback to vh for browsers that don't support dvh. */
    font-size:       clamp(1.6rem, 6vh, 2.75rem);
    font-size:       clamp(1.6rem, 6dvh, 2.75rem);
    font-weight:     900;
    letter-spacing:  -0.03em;
    color:           rgba(255,255,255,0.55);
    text-decoration: none;
    padding:         clamp(0.3rem, 1dvh, 0.55rem) 1.5rem;
    border-radius:   0.75rem;
    transition:      color 0.2s ease, background 0.2s ease;
    width:           100%;
    justify-content: center;
  }
  .mobile-nav-link:hover,
  .mobile-nav-link:focus-visible  { color: rgba(255,255,255,0.88); background: rgba(122,175,196,0.06); }
  .mobile-nav-link--active        { color: #7AAFC4; }
  .mobile-nav-link:focus-visible  { outline: 2px solid rgba(122,175,196,0.70); outline-offset: 2px; border-radius: 0.75rem; }

  .mobile-link-num {
    font-size:      0.7rem;
    font-weight:    600;
    letter-spacing: 0.12em;
    color:          rgba(122,175,196,0.35);
    width:          1.5rem;
    text-align:     right;
    flex-shrink:    0;
    align-self:     center;
    padding-bottom: 2px;
  }
  .mobile-nav-link--active .mobile-link-num { color: rgba(122,175,196,0.6); }

  /* Phone CTA */
  .mobile-phone-cta {
    display:        inline-flex;
    align-items:    center;
    gap:            0.6rem;
    margin-top:     clamp(1.25rem, 3dvh, 2rem);
    padding:        0.85rem 2rem;
    border-radius:  9999px;
    border:         1px solid rgba(122,175,196,0.28);
    background:     rgba(122,175,196,0.08);
    color:          #7AAFC4;
    font-size:      1.05rem;
    font-weight:    700;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition:     background 0.2s, border-color 0.2s;
  }
  .mobile-phone-cta:hover {
    background:    rgba(122,175,196,0.15);
    border-color:  rgba(122,175,196,0.45);
  }

  /* ── Hamburger open state — hides lines when overlay is open ── */
  #nav-toggle[aria-expanded="true"] .ham-line:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  #nav-toggle[aria-expanded="true"] .ham-line:nth-child(2) { opacity: 0; transform: scaleX(0); }
  #nav-toggle[aria-expanded="true"] .ham-line:nth-child(3) { width: 20px; transform: translateY(-8px) rotate(-45deg); }
</style>

<script>
  import gsap from 'gsap';

  const nav       = document.querySelector<HTMLElement>('.nav-island')!;
  const progress  = document.getElementById('nav-progress') as HTMLElement;
  const indicator = document.getElementById('nav-indicator') as HTMLElement;
  const statusLbl = document.getElementById('nav-status-label') as HTMLElement;
  const navLinks  = document.querySelectorAll<HTMLAnchorElement>('#nav-links .nav-link');

  // ─────────────────────────────────────
  //  1. Scroll state + progress bar — RAF-throttled
  // ─────────────────────────────────────
  function updateNav() {
    const scrolled = window.scrollY > 60;
    nav.classList.toggle('scrolled', scrolled);

    // Progress bar width
    const docH   = document.body.scrollHeight - window.innerHeight;
    const pct    = docH > 0 ? (window.scrollY / docH) * 100 : 0;
    progress.style.width = `${pct}%`;
  }

  let navRaf = 0;
  function onScroll() {
    if (navRaf) return;
    navRaf = requestAnimationFrame(() => {
      navRaf = 0;
      updateNav();
    });
  }

  updateNav();
  window.addEventListener('scroll', onScroll, { passive: true });

  // ─────────────────────────────────────
  //  2. Sliding indicator under active link
  // ─────────────────────────────────────
  function moveIndicator(el: HTMLElement) {
    const navRect = nav.getBoundingClientRect();
    const elRect  = el.getBoundingClientRect();
    const left    = elRect.left - navRect.left + (elRect.width * 0.2);
    const width   = elRect.width * 0.6;
    indicator.style.left  = `${left}px`;
    indicator.style.width = `${width}px`;
  }

  // Set indicator on the active link immediately
  const activeLink = document.querySelector<HTMLElement>('#nav-links .nav-link--active');
  if (activeLink) moveIndicator(activeLink);

  // Hover: move indicator to hovered link
  navLinks.forEach(link => {
    link.addEventListener('mouseenter', () => moveIndicator(link));
    link.addEventListener('mouseleave', () => {
      if (activeLink) moveIndicator(activeLink);
    });
  });

  // Reposition the indicator when the viewport resizes — otherwise it
  // stays frozen at the pre-resize offset until the user hovers a link.
  let resizeRaf = 0;
  window.addEventListener('resize', () => {
    if (resizeRaf) return;
    resizeRaf = requestAnimationFrame(() => {
      resizeRaf = 0;
      if (activeLink) moveIndicator(activeLink);
    });
  }, { passive: true });

  // ─────────────────────────────────────
  //  3. Section scanner — status chip
  //     shows the section heading name
  // ─────────────────────────────────────
  const sectionMap: Record<string, string> = {
    'hero-section':  'HOME',
    'over-ons':      'OVER ONS',
    'diensten':      'DIENSTEN',
    'cases':         'WERK',
    'werk':          'WERK',
    'blog':          'BLOG',
    'contact':       'CONTACT',
  };

  if (typeof IntersectionObserver !== 'undefined') {
    const io = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          const id = (entry.target as HTMLElement).id || (entry.target as HTMLElement).className.split(' ')[0];
          const match = Object.entries(sectionMap).find(([key]) => id.includes(key));
          if (match && statusLbl) statusLbl.textContent = match[1];
        }
      }
    }, { threshold: 0.3 });

    document.querySelectorAll('section[id], section.hero-section').forEach(s => io.observe(s));
  }

  // ─────────────────────────────────────
  //  4. Entrance animation
  //  Note: #nav-header entrance is handled
  //  by CSS @keyframes (navHeaderIn) for
  //  iOS Safari reliability.
  // ─────────────────────────────────────

  // Desktop-only entrance micro-animations
  // (On mobile the nav is visible instantly — no GSAP touch at all)
  if (window.innerWidth >= 768) {
    // Logo scales in subtly
    gsap.from('.nav-logo-img', {
      scale: 0.88,
      duration: 0.6,
      ease: 'back.out(1.4)',
      delay: 0.5,
    });

    // Links stagger in
    gsap.from('#nav-links .nav-link', {
      y: -8,
      opacity: 0,
      duration: 0.45,
      stagger: 0.06,
      ease: 'power2.out',
      delay: 0.5,
    });
  }

  // ─────────────────────────────────────
  //  5. Mobile fullscreen menu — with focus trap + focus restore
  // ─────────────────────────────────────
  const toggle      = document.getElementById('nav-toggle');
  const closeBtn    = document.getElementById('nav-close');
  const mobileMenu  = document.getElementById('nav-mobile');
  const mobileLinks = document.querySelectorAll<HTMLElement>('.mobile-nav-link');
  const mobileCta   = document.querySelector<HTMLElement>('.mobile-phone-cta');

  // Track which element had focus before the overlay opened so we can
  // restore it on close (WCAG: focus must return to a sensible place).
  let lastFocus: HTMLElement | null = null;
  let menuIsOpen = false;

  // Collect every keyboard-reachable element inside the overlay so Tab /
  // Shift+Tab can cycle without escaping to the hidden page behind it.
  function getFocusables(): HTMLElement[] {
    if (!mobileMenu) return [];
    return Array.from(
      mobileMenu.querySelectorAll<HTMLElement>(
        'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])'
      )
    ).filter(el => el.offsetParent !== null || el === closeBtn);
  }

  function handleKeydown(e: KeyboardEvent) {
    if (!menuIsOpen) return;
    if (e.key === 'Escape') {
      e.preventDefault();
      closeMenu();
      return;
    }
    if (e.key !== 'Tab') return;
    const focusables = getFocusables();
    if (focusables.length === 0) return;
    const first = focusables[0];
    const last  = focusables[focusables.length - 1];
    const active = document.activeElement as HTMLElement | null;
    if (e.shiftKey && (active === first || !mobileMenu?.contains(active))) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && active === last) {
      e.preventDefault();
      first.focus();
    }
  }

  function openMenu() {
    if (menuIsOpen) return;
    menuIsOpen = true;
    lastFocus = document.activeElement as HTMLElement | null;

    toggle?.setAttribute('aria-expanded', 'true');
    mobileMenu?.setAttribute('aria-hidden', 'false');
    mobileMenu?.classList.add('open');
    // Prevent background scroll while overlay is open
    document.body.style.overflow = 'hidden';
    // Make links focusable
    mobileLinks.forEach(l => l.setAttribute('tabindex', '0'));
    mobileCta?.setAttribute('tabindex', '0');

    // GSAP stagger
    gsap.fromTo(mobileLinks,
      { opacity: 0, y: 28 },
      {
        opacity: 1, y: 0, duration: 0.42, stagger: 0.07, ease: 'power3.out', delay: 0.05,
        onComplete: () => {
          // Move focus into the overlay once the entrance animation is done,
          // landing on the close button — the most predictable escape hatch.
          (closeBtn as HTMLElement | null)?.focus();
        },
      }
    );
    gsap.fromTo(mobileCta ?? [],
      { opacity: 0, y: 16 },
      { opacity: 1, y: 0, duration: 0.38, ease: 'power2.out', delay: 0.42 }
    );
  }

  function closeMenu() {
    if (!menuIsOpen) return;
    menuIsOpen = false;

    toggle?.setAttribute('aria-expanded', 'false');
    mobileMenu?.setAttribute('aria-hidden', 'true');
    mobileMenu?.classList.remove('open');
    document.body.style.overflow = '';
    mobileLinks.forEach(l => l.setAttribute('tabindex', '-1'));
    mobileCta?.setAttribute('tabindex', '-1');

    // Restore focus to the trigger (hamburger) so keyboard users land back
    // where they opened the menu from.
    (lastFocus ?? toggle)?.focus?.();
    lastFocus = null;
  }

  toggle?.addEventListener('click', () => {
    menuIsOpen ? closeMenu() : openMenu();
  });
  closeBtn?.addEventListener('click', closeMenu);

  // Close on Escape + trap Tab while the overlay is open
  document.addEventListener('keydown', handleKeydown);

  // Tapping a nav link navigates away — close the overlay first so focus
  // management unwinds cleanly before the page transition.
  mobileLinks.forEach(l => l.addEventListener('click', closeMenu));
</script>
