---
import { cases } from '../../data/cases.ts';

const serviceColors: Record<string, string> = {
  'Kalibratie':    'rgba(122, 175, 196, 0.15)',
  'Reparatie':     'rgba(196, 138, 100, 0.15)',
  'Certificering': 'rgba(100, 196, 138, 0.15)',
  'Justeren':      'rgba(196, 175, 100, 0.15)',
  'Reiniging':     'rgba(150, 150, 196, 0.15)',
};
const serviceTextColors: Record<string, string> = {
  'Kalibratie':    '#7AAFC4',
  'Reparatie':     '#C48A64',
  'Certificering': '#64C48A',
  'Justeren':      '#C4AF64',
  'Reiniging':     '#9696C4',
};
---

<section id="cases" class="cases-section page-wrap">
  <div class="page-container">

    <!-- Section header — centred -->
    <div class="cases-header type-stack flex flex-col items-center text-center" data-animate>
      <div class="flex items-center gap-3">
        <span class="w-8 h-px opacity-75" style="background:#7AAFC4;"></span>
        <span class="text-[11px] font-semibold tracking-[0.32em] uppercase" style="color:#7AAFC4;">Ons Werk</span>
        <span class="w-8 h-px opacity-75" style="background:#7AAFC4;"></span>
      </div>
      <h2 class="text-4xl md:text-5xl font-black leading-tight tracking-tight text-white">
        Elke sleutel vertelt een verhaal.
      </h2>
      <p class="text-base max-w-md leading-relaxed" style="color:#A8BAC2;">
        Elke kaart toont de volledige voor- en na-documentatie — open er een.
      </p>
    </div>

    <!-- Cases grid — 12-col: full → 6/6 → 4/4/4 -->
    <div class="cases-grid-layout">
      {cases.map((c, i) => (
        <article
          class="case-card relative"
          data-stagger-delay={String((i % 3) * 80)}
        >
          <!-- Image area -->
          <div class="case-image relative aspect-[3/2] overflow-hidden rounded-t-2xl">
            {c.before ? (
              <img
                src={c.before}
                alt={`${c.model} — voor service`}
                class="case-img w-full h-full object-cover"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <div class="case-placeholder w-full h-full flex flex-col items-center justify-center gap-3 relative overflow-hidden">
                <div class="case-grid absolute inset-0"></div>
                <!-- Mini wrench icon -->
                <svg width="48" height="48" viewBox="0 0 80 32" fill="none" class="relative z-10 opacity-25">
                  <circle cx="12" cy="16" r="10" stroke="#7AAFC4" stroke-width="1.5"/>
                  <circle cx="12" cy="16" r="5" stroke="#7AAFC4" stroke-width="1"/>
                  <rect x="22" y="12" width="38" height="8" rx="2" stroke="#7AAFC4" stroke-width="1.5"/>
                  <rect x="60" y="10" width="14" height="12" rx="3" stroke="#7AAFC4" stroke-width="1.5"/>
                </svg>
                <span class="relative z-10 text-[10px] tracking-[0.2em] uppercase font-medium" style="color: rgba(122,175,196,0.35);">
                  {c.model}
                </span>
              </div>
            )}

          </div>

          <!-- Card info -->
          <div class="case-info rounded-b-2xl" style="padding: 1.75rem 2rem 2rem;">
            <div class="flex items-start justify-between gap-3 mb-5">
              <div>
                <h3 class="text-lg font-bold text-white leading-snug" style="margin-bottom: 0.35rem;">{c.model}</h3>
                <p class="text-sm" style="color:#8A9AA8;">{c.type} · {c.range}</p>
              </div>
              <span class="text-[11px] font-semibold shrink-0 mt-0.5 tracking-wide" style="color:rgba(122,175,196,0.60);">{c.date.split(' ').slice(-2).join(' ')}</span>
            </div>

            <!-- Divider -->
            <div style="height:1px; background:rgba(122,175,196,0.08); margin-bottom:1.25rem;"></div>

            <!-- Service badges -->
            <div class="flex flex-wrap gap-2">
              {c.services.map(s => (
                <span
                  class="badge"
                  style={`background: ${serviceColors[s] ?? 'rgba(122,175,196,0.1)'}; color: ${serviceTextColors[s] ?? '#7AAFC4'};`}
                >
                  {s}
                </span>
              ))}
            </div>
          </div>

          <!-- Full-card trigger — a real <button> covers the whole card so screen
               readers announce a single labelled action per card instead of an
               article-with-role=button. Clicks anywhere on the card still open
               the modal; Enter/Space works natively. -->
          <button
            type="button"
            class="case-open-btn"
            aria-label={`Bekijk case: ${c.model}`}
            data-case-id={c.id}
          >
            <span class="case-open-label" aria-hidden="true">Bekijk details</span>
          </button>
        </article>
      ))}
    </div><!-- end cases-grid-layout -->

    <!-- View all — separated from card grid with a visual break -->
    <div class="cases-cta" data-animate>
      <div class="cases-cta-divider" aria-hidden="true">
        <span class="cases-cta-line"></span>
        <span class="cases-cta-dot"></span>
        <span class="cases-cta-line"></span>
      </div>
      <a href="/werk" class="btn btn-outline">
        Naar de werkpagina
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<!-- ─── MODAL ─── -->
<div
  id="case-modal-overlay"
  class="modal-overlay fixed inset-0 z-[200] flex items-center justify-center px-4 py-8 pointer-events-none opacity-0"
  aria-modal="true"
  role="dialog"
  aria-label="Case detail"
>
  <!-- Backdrop -->
  <div id="modal-backdrop" class="absolute inset-0" style="background: rgba(4,5,6,0.88); backdrop-filter: blur(8px);"></div>

  <!-- Modal card -->
  <div id="case-modal" class="modal-card relative w-full max-w-3xl rounded-2xl overflow-hidden flex flex-col max-h-[90vh]">

    <!-- Header -->
    <div class="modal-header flex items-start justify-between" style="padding: 2rem 2.5rem 1.75rem; border-bottom: 1px solid rgba(122,175,196,0.1);">
      <div>
        <p class="text-[10px] font-semibold tracking-[0.28em] uppercase" style="color: #7AAFC4; margin-bottom: 0.5rem;" id="modal-type"></p>
        <h3 class="text-2xl font-black text-white leading-tight" style="margin-bottom: 0.4rem;" id="modal-model"></h3>
        <p class="text-sm" style="color: #7A8A94;" id="modal-meta"></p>
      </div>
      <button
        id="modal-close"
        class="modal-close-btn shrink-0 rounded-xl transition-colors duration-200"
        style="margin-top: 0.25rem; margin-left: 1.5rem;"
        aria-label="Sluit modal"
      >
        <svg width="16" height="16" viewBox="0 0 18 18" fill="none">
          <path d="M1 1l16 16M17 1L1 17" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <!-- Body -->
    <div class="modal-body overflow-y-auto flex-1" style="padding: 2rem 2.5rem 2.5rem;">

      <!-- Before / After image tabs -->
      <div style="margin-bottom: 2.5rem;">
        <div class="flex gap-1.5" style="margin-bottom: 1rem;">
          <button class="ba-tab-btn active" data-tab="before">Voor service</button>
          <button class="ba-tab-btn" data-tab="after">Na service</button>
        </div>
        <div class="ba-image-wrap relative aspect-[16/9] rounded-2xl overflow-hidden">
          <div id="modal-before-img" class="ba-panel absolute inset-0 active">
            <div class="ba-placeholder w-full h-full flex flex-col items-center justify-center gap-3">
              <div class="ba-grid absolute inset-0"></div>
              <svg width="56" height="24" viewBox="0 0 80 32" fill="none" class="relative z-10 opacity-20">
                <circle cx="12" cy="16" r="10" stroke="#7AAFC4" stroke-width="1.5"/>
                <circle cx="12" cy="16" r="5" stroke="#7AAFC4" stroke-width="1"/>
                <rect x="22" y="12" width="38" height="8" rx="2" stroke="#7AAFC4" stroke-width="1.5"/>
                <rect x="60" y="10" width="14" height="12" rx="3" stroke="#7AAFC4" stroke-width="1.5"/>
              </svg>
              <span class="relative z-10 text-[11px] tracking-[0.2em] uppercase" style="color: rgba(122,175,196,0.3);">Voor foto</span>
            </div>
          </div>
          <div id="modal-after-img" class="ba-panel absolute inset-0">
            <div class="ba-placeholder w-full h-full flex flex-col items-center justify-center gap-3">
              <div class="ba-grid absolute inset-0"></div>
              <svg width="56" height="24" viewBox="0 0 80 32" fill="none" class="relative z-10 opacity-20">
                <circle cx="12" cy="16" r="10" stroke="#7AAFC4" stroke-width="1.5"/>
                <circle cx="12" cy="16" r="5" stroke="#7AAFC4" stroke-width="1"/>
                <rect x="22" y="12" width="38" height="8" rx="2" stroke="#7AAFC4" stroke-width="1.5"/>
                <rect x="60" y="10" width="14" height="12" rx="3" stroke="#7AAFC4" stroke-width="1.5"/>
              </svg>
              <span class="relative z-10 text-[11px] tracking-[0.2em] uppercase" style="color: rgba(122,175,196,0.3);">Na foto</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Divider -->
      <div style="height: 1px; background: rgba(122,175,196,0.08); margin-bottom: 2rem;"></div>

      <!-- Services -->
      <div style="margin-bottom: 2rem;">
        <p class="text-[10px] font-semibold tracking-[0.28em] uppercase" style="color: #7A8A94; margin-bottom: 1rem;">Uitgevoerde werkzaamheden</p>
        <div id="modal-services" class="flex flex-wrap gap-2.5"></div>
      </div>

      <!-- Divider -->
      <div style="height: 1px; background: rgba(122,175,196,0.08); margin-bottom: 2rem;"></div>

      <!-- Notes -->
      <div class="modal-notes rounded-2xl" style="padding: 1.75rem;">
        <p class="text-[10px] font-semibold tracking-[0.28em] uppercase" style="color: #7A8A94; margin-bottom: 1rem;">Technische notities</p>
        <p id="modal-notes-text" class="text-sm leading-relaxed" style="color: rgba(184,196,204,0.80);"></p>
      </div>

      <!-- Footer: DTS cert mark -->
      <div class="flex items-center justify-between" style="margin-top: 2rem; padding-top: 1.75rem; border-top: 1px solid rgba(122,175,196,0.1);">
        <span class="text-[11px]" style="color: rgba(122,175,196,0.60);">Jouw sleutel ook <a href="/diensten/momentsleutel-kalibratie" style="color:#7AAFC4; text-decoration: underline; text-underline-offset: 2px;">momentsleutel kalibreren laten</a>?</span>
        <span class="text-[11px]" style="color: rgba(122,175,196,0.50);">Dutch Torque Service — ISO 6789:2017 gecertificeerd</span>
      </div>
    </div>
  </div>
</div>

<style>
  .cases-section {
    position: relative;
    z-index: 1;
    background: transparent;
  }

  /* ── Section header: space below the subtitle before cards ── */
  .cases-header {
    margin-bottom: 5rem;
  }

  /* ── CTA block: lives in its own island below the grid ── */
  .cases-cta {
    margin-top: 5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
  }

  /* Decorative divider between grid and button */
  .cases-cta-divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    width: 100%;
    max-width: 480px;
  }
  .cases-cta-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(122,175,196,0.18), transparent);
  }
  .cases-cta-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: rgba(122,175,196,0.45);
    flex-shrink: 0;
  }

  /* Custom grid — overrides page-grid for more generous gaps */
  .cases-grid-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 640px)  { .cases-grid-layout { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .cases-grid-layout { grid-template-columns: repeat(3, 1fr); } }

  /* Case card — GSAP never touches these elements. Hover is driven by both
     :hover AND a JS-tracked .is-hover class (pointerenter/pointerleave),
     so fast cursor passes across the grid reliably show "Bekijk details"
     even when the translateY animation momentarily moves an edge pixel
     out from under the cursor. Entrance animation only controls opacity. */
  .case-card {
    background: #0D1017;
    border: 1px solid rgba(122, 175, 196, 0.14);
    border-radius: 1.5rem;
    overflow: visible;
    box-shadow: 0 4px 24px rgba(0,0,0,0.35);
    opacity: 0; /* starts hidden; JS adds .is-animated then .is-done */
    transition: transform 0.22s cubic-bezier(0.22, 1, 0.36, 1),
                border-color 0.22s ease,
                box-shadow 0.22s ease;
    isolation: isolate;
  }

  /* Teal glow halo — appears on hover via pseudo-element.
     Sits BEHIND card content, so image/info stay crisp. */
  .case-card::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    background: radial-gradient(
      120% 80% at 50% 0%,
      rgba(122,175,196,0.22) 0%,
      rgba(122,175,196,0.08) 40%,
      transparent 70%
    );
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
    z-index: 0;
  }
  .case-card:hover::before,
  .case-card.is-hover::before { opacity: 1; }

  /* Scroll-in keyframe — only animates opacity/transform, never blocks hover */
  @keyframes cardIn {
    from { opacity: 0; transform: translateY(22px) scale(0.97); }
    to   { opacity: 1; transform: none; }
  }
  .case-card.is-animated {
    animation: cardIn 0.55s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  /* After animation: keep visible */
  .case-card.is-done {
    opacity: 1;
  }

  /* Safety net — if neither .is-animated nor .is-done gets added
     (IO/animationend race, tab backgrounded during entrance, reduced-motion
     quirks), force-show after 1.2s so the page NEVER renders as empty
     or un-hoverable. Overridden the moment either class lands. */
  @keyframes caseCardFallbackShow {
    to { opacity: 1; }
  }
  .case-card:not(.is-animated):not(.is-done) {
    animation: caseCardFallbackShow 0.01s linear 1.2s forwards;
  }

  /* HOVER — works unconditionally, no class prerequisite.
     :hover AND .is-hover both trigger the state so fast cursor passes
     that miss a :hover update (edge pixel / translate flicker) still
     reveal the label via the JS pointer-event channel. */
  .case-card:hover,
  .case-card.is-hover {
    transform: translateY(-6px);
    border-color: rgba(122, 175, 196, 0.55);
    box-shadow: 0 24px 64px rgba(0,0,0,0.62),
                0 0 0 1px rgba(122,175,196,0.18),
                0 0 48px rgba(122,175,196,0.12);
  }
  .case-card:hover .case-open-label,
  .case-card.is-hover .case-open-label,
  .case-open-btn:focus-visible .case-open-label { opacity: 1; transform: scale(1); }
  .case-card:hover .case-img,
  .case-card.is-hover .case-img                 { transform: scale(1.06); }
  .case-card:hover .badge,
  .case-card.is-hover .badge                    { transform: translateY(-1px); filter: brightness(1.25) saturate(1.15); }

  /* Keep visual children above the glow ::before (z-index: 0).
     The .case-open-btn is deliberately EXCLUDED — it has its own
     position: absolute + z-index: 3 so it stays as a full-card click
     overlay. Overriding it here would collapse it into normal flow
     and kill card clicks. */
  .case-card > .case-image,
  .case-card > .case-info {
    position: relative;
    z-index: 1;
  }

  /* Clip inner content to card radius */
  .case-card > .case-image { border-radius: 1.5rem 1.5rem 0 0; overflow: hidden; }
  .case-card:focus-visible {
    outline: 2px solid rgba(122, 175, 196, 0.6);
    outline-offset: 2px;
  }

  /* Badge transition baseline — activated by .case-card:hover above */
  .badge {
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
                filter 0.35s ease;
  }

  .case-img {
    transition: transform 0.7s ease;
  }

  .case-placeholder {
    background: #090B0F;
  }
  .case-grid {
    background-image:
      linear-gradient(rgba(122,175,196,0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(122,175,196,0.05) 1px, transparent 1px);
    background-size: 24px 24px;
  }

  .case-info {
    background: transparent;
    border-top: 1px solid rgba(122, 175, 196, 0.08);
  }

  /* Transparent button layered over the whole card — invisible unless focused.
     The hover darkening is applied on the card itself (below) so pointer and
     keyboard focus both reveal the label the same way. */
  .case-open-btn {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    background: transparent;
    border: 0;
    padding: 0;
    margin: 0;
    cursor: pointer;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 1.5rem;
    touch-action: manipulation;
    transition: background 0.18s ease;
  }
  .case-open-btn:focus-visible {
    outline: 2px solid rgba(122, 175, 196, 0.7);
    outline-offset: 4px;
  }
  /* Darken overlay matches the old .case-overlay behaviour on card hover.
     Unconditional — no longer waits for .is-done. */
  .case-card:hover .case-open-btn,
  .case-card.is-hover .case-open-btn,
  .case-open-btn:focus-visible {
    background: rgba(8, 9, 11, 0.55);
  }

  .case-open-label {
    padding: 0.75rem 1.5rem;
    border-radius: 0.75rem;
    background: rgba(122, 175, 196, 0.92);
    color: #08090B;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0;
    transform: scale(0.95);
    /* Snappy reveal so even a brief hover (fast cursor sweep) shows the
       label clearly instead of catching it mid-fade-in. */
    transition: opacity 0.12s ease, transform 0.12s ease;
  }

  /* Modal */
  .modal-overlay { transition: opacity 0.3s ease; }
  .modal-overlay.open { pointer-events: auto; opacity: 1; }

  .modal-card {
    background: #0E1118;
    border: 1px solid rgba(122, 175, 196, 0.18);
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.7), 0 0 40px rgba(122, 175, 196, 0.06);
  }

  .modal-header { background: #0E1118; }

  .modal-close-btn {
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: rgba(184, 196, 204, 0.7);
    background: rgba(122, 175, 196, 0.08);
    border: 1px solid transparent;
  }
  .modal-close-btn:hover {
    background: rgba(122, 175, 196, 0.16);
    color: rgba(232, 240, 244, 0.95);
  }
  .modal-close-btn:focus-visible {
    outline: 2px solid rgba(122, 175, 196, 0.8);
    outline-offset: 2px;
  }

  /* BA tabs */
  .ba-tab-btn {
    min-height: 44px;
    padding: 0 18px;
    border-radius: 10px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(122, 175, 196, 0.7);
    background: transparent;
    border: 1px solid rgba(122, 175, 196, 0.18);
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .ba-tab-btn:focus-visible {
    outline: 2px solid rgba(122, 175, 196, 0.7);
    outline-offset: 2px;
  }
  .ba-tab-btn.active,
  .ba-tab-btn:hover {
    background: rgba(122, 175, 196, 0.12);
    color: #7AAFC4;
    border-color: rgba(122, 175, 196, 0.3);
  }

  .ba-image-wrap { background: #0A0B0E; }

  .ba-panel {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .ba-panel.active {
    opacity: 1;
    pointer-events: auto;
  }

  .ba-placeholder { position: relative; overflow: hidden; }
  .ba-grid {
    background-image:
      linear-gradient(rgba(122,175,196,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(122,175,196,0.04) 1px, transparent 1px);
    background-size: 28px 28px;
  }

  .modal-notes {
    background: rgba(122, 175, 196, 0.04);
    border: 1px solid rgba(122, 175, 196, 0.1);
  }
</style>

<script>
  import gsap from 'gsap';
  import { cases } from '../../data/cases.ts';

  const overlay   = document.getElementById('case-modal-overlay')!;
  const modal     = document.getElementById('case-modal')!;
  const backdrop  = document.getElementById('modal-backdrop')!;
  const closeBtn  = document.getElementById('modal-close')!;

  // Cache modal fields
  const fType     = document.getElementById('modal-type')!;
  const fModel    = document.getElementById('modal-model')!;
  const fMeta     = document.getElementById('modal-meta')!;
  const fServices = document.getElementById('modal-services')!;
  const fNotes    = document.getElementById('modal-notes-text')!;

  const serviceTextColors: Record<string, string> = {
    'Kalibratie': '#7AAFC4', 'Reparatie': '#C48A64',
    'Certificering': '#64C48A', 'Justeren': '#C4AF64', 'Reiniging': '#9696C4',
  };
  const serviceBgColors: Record<string, string> = {
    'Kalibratie': 'rgba(122,175,196,0.12)', 'Reparatie': 'rgba(196,138,100,0.12)',
    'Certificering': 'rgba(100,196,138,0.12)', 'Justeren': 'rgba(196,175,100,0.12)',
    'Reiniging': 'rgba(150,150,196,0.12)',
  };

  // ── Focus trap state ──
  // Track which card triggered the modal so we can restore focus on close.
  let lastTrigger: HTMLElement | null = null;
  const FOCUSABLE = 'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"]), input, select, textarea';

  function trapFocus(e: KeyboardEvent) {
    if (e.key !== 'Tab') return;
    const focusables = Array.from(
      modal.querySelectorAll<HTMLElement>(FOCUSABLE)
    ).filter(el => el.offsetParent !== null);
    if (focusables.length === 0) return;
    const first = focusables[0];
    const last  = focusables[focusables.length - 1];
    const active = document.activeElement as HTMLElement | null;

    if (e.shiftKey && active === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && active === last) {
      e.preventDefault();
      first.focus();
    }
  }

  function openModal(id: string, trigger?: HTMLElement) {
    const c = cases.find(x => x.id === id);
    if (!c) return;

    lastTrigger = trigger ?? (document.activeElement as HTMLElement | null);

    // Populate fields
    fType.textContent     = c.type;
    fModel.textContent    = c.model;
    fMeta.textContent     = `${c.range} · ${c.date}`;
    fNotes.textContent    = c.notes;

    fServices.innerHTML = c.services.map(s =>
      `<span style="background:${serviceBgColors[s] ?? 'rgba(122,175,196,0.1)'};color:${serviceTextColors[s] ?? '#7AAFC4'};padding:4px 10px;border-radius:6px;font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;">${s}</span>`
    ).join('');

    // Tabs: reset to 'before'
    document.querySelectorAll('.ba-tab-btn').forEach(btn => btn.classList.remove('active'));
    document.querySelector('[data-tab="before"]')?.classList.add('active');
    document.getElementById('modal-before-img')?.classList.add('active');
    document.getElementById('modal-after-img')?.classList.remove('active');

    // Open overlay
    overlay.classList.add('open');
    document.body.style.overflow = 'hidden';

    // Keyboard: trap Tab inside the modal while open
    document.addEventListener('keydown', trapFocus);

    gsap.fromTo(modal,
      { scale: 0.92, opacity: 0, y: 20 },
      {
        scale: 1, opacity: 1, y: 0, duration: 0.4, ease: 'power3.out',
        onComplete: () => {
          // Move focus into the modal (close button is the first predictable target)
          (document.getElementById('modal-close') as HTMLElement | null)?.focus();
        },
      }
    );
  }

  function closeModal() {
    gsap.to(modal, {
      scale: 0.94, opacity: 0, y: 16, duration: 0.25, ease: 'power2.in',
      onComplete: () => {
        overlay.classList.remove('open');
        document.body.style.overflow = '';
        document.removeEventListener('keydown', trapFocus);
        // Restore focus to the trigger so keyboard/SR users land where they were
        lastTrigger?.focus?.();
        lastTrigger = null;
      }
    });
  }

  // Click — handled on the real <button> inside each card. Enter/Space are
  // native to <button> so no keydown handler is needed.
  document.querySelectorAll<HTMLButtonElement>('.case-open-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.caseId;
      if (!id) return;
      openModal(id, btn);
    });
  });

  // Scroll-in: IntersectionObserver fires immediately for cards already in viewport
  const allCards = Array.from(document.querySelectorAll<HTMLElement>('.case-card'));

  // Reliable hover state for fast cursor sweeps.
  //
  // CSS :hover alone is fragile here: the card lifts 6px on hover via
  // translateY, and during fast horizontal movement the browser can drop a
  // :hover update when an edge pixel briefly slips out from under the cursor
  // as the card animates. Result: "Bekijk details" doesn't appear even
  // though the mouse is visibly over a card.
  //
  // Solution: track hover via pointerenter/pointerleave and mirror the state
  // with an .is-hover class. The CSS treats :hover and .is-hover as equal
  // triggers, so whichever channel fires first reveals the label. A short
  // leave-timeout prevents flicker when the translateY briefly steals the
  // cursor off the card edge.
  allCards.forEach(card => {
    let leaveTimer: number | undefined;
    const setHover = () => {
      if (leaveTimer !== undefined) {
        window.clearTimeout(leaveTimer);
        leaveTimer = undefined;
      }
      card.classList.add('is-hover');
    };
    const clearHover = () => {
      if (leaveTimer !== undefined) window.clearTimeout(leaveTimer);
      leaveTimer = window.setTimeout(() => {
        card.classList.remove('is-hover');
        leaveTimer = undefined;
      }, 40);
    };
    card.addEventListener('pointerenter', setHover);
    card.addEventListener('pointerover',  setHover); // belt-and-suspenders: covers re-entries
    card.addEventListener('pointerleave', clearHover);
    card.addEventListener('pointercancel', clearHover);
  });

  const cardObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      cardObserver.unobserve(entry.target);
      const card = entry.target as HTMLElement;
      const delay = parseInt(card.dataset.staggerDelay ?? '0');

      setTimeout(() => {
        card.classList.add('is-animated');

        const finish = () => {
          card.classList.remove('is-animated');
          card.classList.add('is-done');
        };
        // animationend is the clean path; setTimeout is a safety fallback
        card.addEventListener('animationend', finish, { once: true });
        setTimeout(finish, 700);
      }, delay);
    });
  }, { threshold: 0.05 });

  allCards.forEach(c => cardObserver.observe(c));

  // Close
  closeBtn.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

  // BA tabs
  document.querySelectorAll('.ba-tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.ba-tab-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const tab = (btn as HTMLElement).dataset.tab;
      document.querySelectorAll('.ba-panel').forEach(p => p.classList.remove('active'));
      document.getElementById(`modal-${tab}-img`)?.classList.add('active');
    });
  });
</script>
