---
/**
 * TextBlock, a rich text content section.
 *
 * Props:
 *  eyebrow , small label above heading (optional)
 *  heading , main section heading
 *  body    , paragraph text
 *  align   , 'left' | 'center' | 'right' (default 'left')
 *  dark    , true = black bg white text, false = white bg black text (default false)
 *  maxWidth, tailwind max-w class for the text container (default 'max-w-3xl')
 */
interface Props {
  eyebrow?: string;
  heading: string;
  body: string;
  align?: 'left' | 'center' | 'right';
  dark?: boolean;
  maxWidth?: string;
}

const {
  eyebrow,
  heading,
  body,
  align = 'left',
  dark = false,
  maxWidth = 'max-w-3xl',
} = Astro.props;

const alignClass = {
  left:   'text-left mr-auto',
  center: 'text-center mx-auto',
  right:  'text-right ml-auto',
}[align];
---

<section class={`py-28 px-6 ${dark ? 'bg-black text-white' : 'bg-white text-black'}`}>
  <div class={`${maxWidth} ${alignClass}`} data-animate>
    {eyebrow && (
      <p class={`text-xs font-semibold tracking-[0.25em] uppercase mb-5 ${dark ? 'text-neutral-500' : 'text-neutral-400'}`}>
        {eyebrow}
      </p>
    )}
    <h2 class="text-4xl md:text-6xl font-black leading-[1.05] tracking-tight">
      {heading}
    </h2>
    <p class={`mt-6 text-lg leading-relaxed ${dark ? 'text-neutral-400' : 'text-neutral-500'}`}>
      {body}
    </p>
    <slot />
  </div>
</section>
