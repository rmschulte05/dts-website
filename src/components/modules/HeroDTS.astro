---
// Hero — full-viewport, everything above the fold
---

<section class="hero-section">

  <!-- ── BACKGROUND LAYERS ── -->
  <!-- Dot grid -->
  <div class="hero-bg" aria-hidden="true"></div>
  <!-- Dark zone protecting text legibility -->
  <div class="hero-overlay" aria-hidden="true"></div>
  <!-- Radial glow — warm halo behind text column -->
  <div class="hero-glow" aria-hidden="true"></div>
  <!-- Bottom fade into next section -->
  <div class="hero-bottom-fade" aria-hidden="true"></div>

  <!-- Scroll progress line -->
  <div class="scroll-line absolute top-0 left-0 h-px w-0 z-20"
    style="background: linear-gradient(to right, transparent, #7AAFC4, transparent);"
    id="hero-progress-line"></div>

  <!-- ── MAIN CONTENT ── -->
  <div class="hero-body">
    <div class="hero-container">

      <!-- Left accent bar -->
      <div class="hero-accent-bar" aria-hidden="true"></div>

      <!-- Eyebrow -->
      <div class="eyebrow-wrap overflow-hidden mb-5">
        <div class="hero-eyebrow flex items-center gap-3">
          <span class="block w-6 h-px" style="background:#7AAFC4; opacity:0.8;"></span>
          <span class="text-[10px] font-semibold tracking-[0.36em] uppercase" style="color:#7AAFC4;">
            Dutch Torque Service
          </span>
          <span class="block w-6 h-px hidden sm:block" style="background:#7AAFC4; opacity:0.35;"></span>
        </div>
      </div>

      <!-- Headline -->
      <h1 class="hero-headline" style="margin-bottom: 1.75rem;">
        <span class="word-reveal block">
          <span class="hero-word block text-white">PRECISIE</span>
        </span>
        <span class="word-reveal block">
          <span class="hero-word block text-white">IN ELKE</span>
        </span>
        <span class="word-reveal block">
          <span class="hero-word block hero-word-gradient">NEWTON METER.</span>
        </span>
        <span class="word-reveal block">
          <span class="hero-word hero-word-sub block text-white">Momentsleutel kalibratie, reparatie &amp; certificering.</span>
        </span>
      </h1>

      <!-- Subtitle + CTAs — side by side on desktop -->
      <div class="hero-mid">
        <p class="hero-sub">
          Professionele momentsleutel kalibratie, reparatie en certificering conform ISO&nbsp;6789:2017.
          Binnen 48&nbsp;uur gecertificeerd — voor werkplaatsen door heel Nederland.
        </p>
        <div class="hero-ctas">
          <a href="#diensten" class="btn btn-primary">
            Kalibratie &amp; Reparatie
            <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
              <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="#cases" class="btn btn-outline">Bekijk Ons Werk</a>
        </div>
      </div>

    </div>
  </div>

  <!-- ── STATS BAR — pinned to bottom of hero ── -->
  <div class="hero-stats-bar">
    <div class="hero-stats-inner">
      {[
        { value: '±2%',  label: 'Koppelmoment',         color: '#7AAFC4' },
        { value: 'Snelle', label: 'Doorlooptijd',          color: '#C4AF64' },
        { value: 'ISO',  label: '6789 Gecertificeerd', color: '#64C48A' },
      ].map((stat, i) => (
        <Fragment>
          <div class="hero-stat">
            <span class="hero-stat-val" style={`color:${stat.color};`}>{stat.value}</span>
            <span class="hero-stat-label">{stat.label}</span>
          </div>
          {i < 2 && <div class="hero-stat-divider" aria-hidden="true"></div>}
        </Fragment>
      ))}

      <!-- Scroll indicator -->
      <div class="hero-scroll-hint">
        <div class="scroll-arrow-line"></div>
        <span>Scroll</span>
      </div>
    </div>
  </div>

</section>

<style>
  /* ── SECTION ── */
  .hero-section {
    position: relative;
    height: 100vh;       /* fallback for older Safari / unsupported browsers */
    height: 100dvh;      /* dynamic viewport — excludes mobile browser chrome */
    min-height: 580px;
    background: transparent;
    z-index: 1;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* ── BACKGROUND ── */
  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(122,175,196,0.04) 1px, transparent 1px);
    background-size: 44px 44px;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    /* Strong left zone for text + fades to clear right where wrench lives */
    background:
      radial-gradient(ellipse 55% 90% at 18% 45%,
        rgba(8,9,11,0.96) 0%,
        rgba(8,9,11,0.80) 45%,
        transparent 75%
      ),
      linear-gradient(108deg,
        rgba(8,9,11,0.85) 0%,
        rgba(8,9,11,0.50) 38%,
        rgba(8,9,11,0.10) 58%,
        transparent 72%
      );
  }
  /* On mobile the wrench fills ~64vw from right, so make overlay fully opaque */
  @media (max-width: 767px) {
    .hero-overlay {
      background:
        linear-gradient(to bottom,
          rgba(8,9,11,0.92) 0%,
          rgba(8,9,11,0.88) 60%,
          rgba(8,9,11,0.75) 100%
        );
    }
  }

  .hero-glow {
    position: absolute;
    inset: 0;
    /* Soft teal halo behind where the text sits */
    background: radial-gradient(ellipse 40% 60% at 16% 42%,
      rgba(122,175,196,0.055) 0%,
      transparent 65%
    );
  }

  .hero-bottom-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 180px;
    background: linear-gradient(to bottom, transparent, rgba(8,9,11,0.75));
    pointer-events: none;
    z-index: 5;
  }

  /* ── CONTENT BODY ── */
  .hero-body {
    position: relative;
    z-index: 10;
    flex: 1;
    display: flex;
    align-items: center;
    padding-top: clamp(4.5rem, 10vw, 7.5rem);
    padding-bottom: 1.5rem;
  }
  @media (max-width: 480px) {
    .hero-body {
      align-items: flex-start;
      padding-top: 5.5rem; /* below nav (56px + 20px padding + buffer) */
      padding-bottom: 1rem;
    }
  }

  .hero-container {
    width: 100%;
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: var(--page-px);
    position: relative;
  }

  /* Left accent bar */
  .hero-accent-bar {
    position: absolute;
    left: calc(var(--page-px) - 1.25rem);
    top: 0.5rem;
    bottom: 0.5rem;
    width: 2px;
    background: linear-gradient(to bottom,
      transparent,
      rgba(122,175,196,0.55) 20%,
      rgba(122,175,196,0.55) 80%,
      transparent
    );
    border-radius: 2px;
    display: none;
  }
  @media (min-width: 1100px) { .hero-accent-bar { display: block; } }

  /* ── EYEBROW ── */
  /* (no extra style needed — uses inline/utility classes) */

  /* ── HEADLINE ── */
  .hero-headline {
    font-weight: 900;
    line-height: 0.90;
    letter-spacing: -0.025em;
    font-size: clamp(3rem, 7.5vw, 6.25rem);
    max-width: 10ch;
  }

  .hero-word-sub {
    font-size: 0.35em;
    font-weight: 600;
    letter-spacing: -0.01em;
    opacity: 0.75;
    margin-top: 0.5em;
  }

  .hero-word-gradient {
    background: linear-gradient(90deg, #7AAFC4 0%, #9BC5D8 55%, #B8C4CC 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ── MIDDLE ROW: subtitle + CTAs ── */
  .hero-mid {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    max-width: 640px;
  }
  @media (min-width: 860px) {
    .hero-mid {
      flex-direction: row;
      align-items: center;
      gap: 3rem;
      max-width: none;
    }
  }

  .hero-sub {
    font-size: clamp(0.9rem, 1.4vw, 1.05rem);
    line-height: 1.75;
    color: #9AAEB8;
    max-width: 38ch;
    flex-shrink: 0;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    flex-shrink: 0;
  }

  /* ── STATS BAR ── */
  .hero-stats-bar {
    position: relative;
    z-index: 10;
    border-top: 1px solid rgba(122,175,196,0.12);
    background: rgba(8,9,11,0.55);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .hero-stats-inner {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: var(--page-px);
    padding-top: 1rem;
    padding-bottom: 1.25rem;
    gap: 1rem 0;
  }
  @media (max-width: 480px) {
    .hero-stats-inner {
      justify-content: space-between;
      gap: 0.5rem 0;
      padding-top: 0.875rem;
      padding-bottom: 1rem;
    }
    .hero-stat {
      flex: 1;
      justify-content: center;
      gap: 0.5rem;
    }
  }

  .hero-stat {
    display: flex;
    align-items: center;
    gap: 1rem;
    position: relative;
  }

  .hero-stat-val {
    font-size: clamp(1.3rem, 2.5vw, 1.7rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .hero-stat-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(184,196,204,0.45);
    line-height: 1.3;
    white-space: nowrap;
  }

  .hero-stat-divider {
    display: none;
    flex-shrink: 0;
    width: 1px;
    height: 2rem;
    background: rgba(122,175,196,0.14);
    /* padding-inline instead of margin keeps spacing inside the outer
       flex context — prevents Chrome vs Safari margin-collapse divergence */
    padding-inline: 2rem;
    box-sizing: content-box;
    background-clip: content-box;
  }
  @media (min-width: 540px) {
    .hero-stat-divider { display: block; }
    .hero-stats-inner  { flex-wrap: nowrap; gap: 0; }
  }

  /* Scroll hint — right side of stats bar */
  .hero-scroll-hint {
    display: none;
    margin-left: auto;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(122,175,196,0.40);
    flex-direction: row-reverse;
  }
  @media (min-width: 640px) { .hero-scroll-hint { display: flex; } }

  .scroll-arrow-line {
    width: 1.5rem;
    height: 1px;
    background: linear-gradient(to right, #7AAFC4, transparent);
    animation: scrollPulse 2.2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.7; transform: scaleX(1); }
    50%       { opacity: 0.25; transform: scaleX(0.6); }
  }

  /* Progress line */
  .scroll-line { pointer-events: none; }

  /* ─────────────────────────────────────────
     ENTRANCE ANIMATIONS — CSS keyframes only.
     Never use gsap.from() for these: GSAP sets
     opacity:0 as an inline style immediately,
     and iOS Safari can freeze the element there
     if the animation frame is dropped or the
     module script is throttled.
     CSS animations run on the compositor thread
     and are guaranteed to reach their end state.
  ───────────────────────────────────────── */
  @keyframes heroFadeUp {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes heroFadeUpSm {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Eyebrow */
  .hero-eyebrow {
    animation: heroFadeUpSm 0.75s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 0.08s;
  }

  /* Headline words — each child gets a slightly longer delay */
  .word-reveal:nth-child(1) .hero-word {
    animation: heroFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 0.12s;
  }
  .word-reveal:nth-child(2) .hero-word {
    animation: heroFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 0.24s;
  }
  .word-reveal:nth-child(3) .hero-word {
    animation: heroFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 0.36s;
  }
  .word-reveal:nth-child(4) .hero-word {
    animation: heroFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 0.48s;
  }

  /* Sub-copy, CTAs, stats bar */
  .hero-sub {
    animation: heroFadeUpSm 0.85s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 0.72s;
  }
  .hero-ctas {
    animation: heroFadeUpSm 0.85s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 0.84s;
  }
  .hero-stats-bar {
    animation: heroFadeUpSm 0.85s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 0.96s;
  }

  /* Respect user motion preference */
  @media (prefers-reduced-motion: reduce) {
    .hero-eyebrow,
    .word-reveal .hero-word,
    .hero-sub,
    .hero-ctas,
    .hero-stats-bar {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // ── Accent bar grows in (not a visibility-critical element) ──
  gsap.from('.hero-accent-bar', {
    scaleY: 0, transformOrigin: 'top center', duration: 1.2, ease: 'power3.out', delay: 0.5,
  });

  // ── Parallax on scroll — desktop only, NO opacity.
  //    On mobile Safari, ScrollTrigger.refresh() (called in Base.astro) can
  //    run while window.scrollY > 0 (URL-bar collapse effect), which would
  //    immediately apply a fractional opacity and make the hero invisible.
  //    Solution: only animate transform on desktop, never opacity.
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isDesktop = window.innerWidth >= 768;

  if (isDesktop && !prefersReduced) {
    gsap.to('.hero-body', {
      scrollTrigger: {
        trigger: '.hero-section',
        start: 'top top',
        end: 'bottom top',
        scrub: 1.8,
      },
      y: -80,
      // opacity intentionally removed — see comment above
    });
  }

  // ── Progress bar ──
  const bar = document.getElementById('hero-progress-line');
  if (bar) {
    window.addEventListener('scroll', () => {
      bar.style.width = (window.scrollY / (document.body.scrollHeight - window.innerHeight) * 100) + '%';
    }, { passive: true });
  }
</script>
