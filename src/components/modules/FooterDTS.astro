---
const year = new Date().getFullYear();

const footerLinks = {
  Diensten: [
    { label: 'Justeren',      href: '/diensten#justeren' },
    { label: 'Kalibratie',    href: '/diensten#kalibratie' },
    { label: 'Reparatie',     href: '/diensten#reparatie' },
    { label: 'Certificering', href: '/diensten#certificering' },
  ],
  Navigatie: [
    { label: 'Home',     href: '/' },
    { label: 'Werk',     href: '/werk' },
    { label: 'Over Ons', href: '/over-ons' },
    { label: 'Contact',  href: '/contact' },
  ],
  Contact: [
    { label: 'info@dutchtorqueservice.nl', href: 'mailto:info@dutchtorqueservice.nl' },
    { label: '+31 (0)6 — — — —',           href: 'tel:+31600000000' },
    { label: 'Nederland',                  href: '#' },
  ],
};
---

<footer class="footer-section relative page-wrap-sm overflow-hidden" style="padding-top: clamp(4rem, 7vw, 6rem); padding-bottom: clamp(2rem, 3vw, 3rem);">

  <!-- Top separator -->
  <div class="absolute top-0 left-0 right-0 h-px"
    style="background: linear-gradient(90deg, transparent 0%, rgba(122,175,196,0.2) 30%, rgba(122,175,196,0.2) 70%, transparent 100%);"></div>

  <!-- Background glow -->
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-96 h-96 rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(122,175,196,0.05) 0%, transparent 70%);"></div>

  <div class="relative page-container">

    <!-- Main footer grid — 12 cols: brand=5, diensten=2, nav=2, contact=3 -->
    <div class="page-grid mb-16">

      <!-- Brand column — 5 cols on desktop -->
      <div class="col-span-12 md:col-span-5">
        <!-- DTS Logo text -->
        <div class="flex items-center gap-3 mb-5">
          <span class="footer-logo-text text-3xl font-black tracking-[0.05em]">DTS</span>
        </div>
        <p class="text-sm leading-relaxed mb-6 max-w-xs" style="color: #7A8A94;">
          Dutch Torque Service — Specialist in professionele kalibratie, service
          en reparatie van momentsleutels. Gecertificeerd conform ISO 6789:2017.
        </p>

        <!-- ISO badge -->
        <div class="inline-flex items-center gap-2.5 px-4 py-2 rounded-xl" style="background: rgba(122,175,196,0.07); border: 1px solid rgba(122,175,196,0.15);">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <rect x="1" y="1" width="14" height="14" rx="2" stroke="#7AAFC4" stroke-width="1"/>
            <path d="M4 8l2.5 2.5L12 5" stroke="#7AAFC4" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="text-xs font-semibold tracking-wider" style="color: #7AAFC4;">ISO 6789:2017</span>
        </div>
      </div>

      <!-- Link columns — 2 cols each (Diensten, Navigatie), 3 for Contact -->
      {Object.entries(footerLinks).map(([section, links]) => (
        <div class={`col-span-6 md:col-span-${section === 'Contact' ? '3' : '2'}`}>
          <h4 class="text-xs font-bold tracking-[0.22em] uppercase mb-5" style="color: rgba(184,196,204,0.5);">{section}</h4>
          <ul class="flex flex-col gap-3">
            {links.map(link => (
              <li>
                <a
                  href={link.href}
                  class="text-sm transition-colors duration-200"
                  style="color: #7A8A94;"
                  onmouseover="this.style.color='rgba(184,196,204,0.9)'"
                  onmouseout="this.style.color='#7A8A94'"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-8"
      style="border-top: 1px solid rgba(122,175,196,0.08);">

      <p class="text-xs" style="color: rgba(122,175,196,0.35);">
        © {year} Dutch Torque Service. Alle rechten voorbehouden.
      </p>

      <div class="flex items-center gap-5">
        <a href="/privacy" class="text-xs transition-colors duration-200"
          style="color: rgba(122,175,196,0.35);"
          onmouseover="this.style.color='rgba(122,175,196,0.7)'"
          onmouseout="this.style.color='rgba(122,175,196,0.35)'"
        >
          Privacybeleid
        </a>
        <a href="/algemene-voorwaarden" class="text-xs transition-colors duration-200"
          style="color: rgba(122,175,196,0.35);"
          onmouseover="this.style.color='rgba(122,175,196,0.7)'"
          onmouseout="this.style.color='rgba(122,175,196,0.35)'"
        >
          Algemene voorwaarden
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-section {
    position: relative;
    z-index: 1;
    background: transparent;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .footer-logo-text {
    background: linear-gradient(135deg, #9BC5D8 0%, #7AAFC4 40%, #B8C4CC 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>
