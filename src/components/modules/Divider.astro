---
/**
 * Divider — a visual spacer / separator between modules.
 *
 * Props:
 *  style  — 'line' | 'space' | 'gradient' (default 'space')
 *  size   — 'sm' | 'md' | 'lg' (default 'md')
 *  dark   — background color (default true)
 */
interface Props {
  style?: 'line' | 'space' | 'gradient';
  size?: 'sm' | 'md' | 'lg';
  dark?: boolean;
}

const { style = 'space', size = 'md', dark = true } = Astro.props;

const sizeClass = { sm: 'py-8', md: 'py-16', lg: 'py-32' }[size];
---

{style === 'line' && (
  <div class={`${sizeClass} ${dark ? 'bg-black' : 'bg-white'} px-6`}>
    <hr class={`border-0 border-t ${dark ? 'border-neutral-800' : 'border-neutral-200'}`} />
  </div>
)}

{style === 'space' && (
  <div class={`${sizeClass} ${dark ? 'bg-black' : 'bg-white'}`} />
)}

{style === 'gradient' && (
  <div class={`${sizeClass} ${dark ? 'bg-gradient-to-b from-black to-neutral-900' : 'bg-gradient-to-b from-white to-neutral-50'}`} />
)}
